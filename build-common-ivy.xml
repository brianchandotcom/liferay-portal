<?xml version="1.0"?>
<!DOCTYPE project>

<project name="build-common-ivy" xmlns:antelope="antlib:ise.antelope.tasks" xmlns:ivy="antlib:org.apache.ivy.ant">
	<macrodef name="get-dest">
		<attribute name="dest" />
		<attribute name="src" />

		<sequential>
			<var name="dest.dir" unset="true" />
			<var name="dest.file" unset="true" />

			<propertyregex
				input="@{dest}"
				property="dest.file.exists"
				regexp="\w+\.\w+"
				replace=""
			/>

			<if>
				<isset property="dest.file.exists" />
				<then>
					<propertyregex
						input="@{dest}"
						property="dest.dir"
						regexp="(.*)/.*"
						replace="\1"
					/>

					<if>
						<not>
							<isset property="dest.dir" />
						</not>
						<then>
							<var name="dest.dir" value="." />
						</then>
					</if>

					<propertyregex
						input="@{dest}"
						property="dest.file"
						regexp=".*/(.*)"
						replace="\1"
					/>

					<if>
						<not>
							<isset property="dest.file" />
						</not>
						<then>
							<var name="dest.file" value="@{dest}" />
						</then>
					</if>
				</then>
				<else>
					<var name="dest.dir" value="@{dest}" />

					<propertyregex
						input="@{src}"
						property="dest.file"
						regexp=".*/(.*)"
						replace="\1"
					/>
				</else>
			</if>

			<var name="dest" value="${dest.dir}/${dest.file}" />

			<var name="dest.dir" unset="true" />
			<var name="dest.file" unset="true" />
			<var name="dest.file.exists" unset="true" />
		</sequential>
	</macrodef>

	<macrodef name="mirrors-get">
		<attribute name="dest" />
		<attribute default="false" name="ignoreerrors" />
		<attribute default="false" name="skipexisting" />
		<attribute name="src" />
		<attribute default="false" name="verbose" />

		<sequential>
			<if>
				<available file="/opt/dev/cache" />
				<then>
					<propertyregex
						input="@{src}"
						property="mirrors.get.cache.file"
						regexp="[:/]"
						replace="_"
					/>

					<if>
						<not>
							<available file="/opt/dev/cache/${mirrors.get.cache.file}" />
						</not>
						<then>
							<mirrors-get-cmd
								dest="/opt/dev/cache/${mirrors.get.cache.file}"
								ignoreerrors="@{ignoreerrors}"
								skipexisting="@{skipexisting}"
								src="@{src}"
								verbose="@{verbose}"
							/>
						</then>
					</if>

					<get-dest dest="@{dest}" src="@{src}" />

					<copy
						file="/opt/dev/cache/${mirrors.get.cache.file}"
						overwrite="true"
						tofile="${dest}"
					/>

					<var name="dest" unset="true" />
					<var name="mirrors.get.cache.file" unset="true" />
				</then>
				<else>
					<mirrors-get-cmd
						dest="@{dest}"
						ignoreerrors="@{ignoreerrors}"
						skipexisting="@{skipexisting}"
						src="@{src}"
						verbose="@{verbose}"
					/>
				</else>
			</if>
		</sequential>
	</macrodef>

	<macrodef name="mirrors-get-cmd">
		<attribute name="dest" />
		<attribute default="false" name="ignoreerrors" />
		<attribute default="false" name="skipexisting" />
		<attribute name="src" />
		<attribute default="false" name="verbose" />

		<sequential>
			<propertyregex
				input="@{src}"
				override="true"
				property="mirrors.src"
				regexp="http://"
				replace="http://mirrors/"
			/>

			<trycatch>
				<try>
					<get
						dest="@{dest}"
						ignoreerrors="@{ignoreerrors}"
						skipexisting="@{skipexisting}"
						src="${mirrors.src}"
						verbose="@{verbose}"
					/>
				</try>
				<catch>
					<get
						dest="@{dest}"
						ignoreerrors="@{ignoreerrors}"
						skipexisting="@{skipexisting}"
						src="@{src}"
						verbose="@{verbose}"
					/>
				</catch>
			</trycatch>
		</sequential>
	</macrodef>

	<if>
		<not>
			<available file="${ivy.home}/ivy-${ivy.version}.jar" />
		</not>
		<then>
			<mkdir dir="${ivy.home}" />

			<mirrors-get
				dest="${ivy.home}/ivy-${ivy.version}.jar"
				src="${ivy.jar.url}"
			/>
		</then>
	</if>

	<path id="ivy.lib.path">
		<fileset
			dir="${ivy.home}"
			includes="ivy-${ivy.version}.jar"
		/>
	</path>

	<taskdef classpathref="ivy.lib.path" resource="org/apache/ivy/ant/antlib.xml" uri="antlib:org.apache.ivy.ant" />

	<ivy:settings file="${project.dir}/ivy-settings.xml" />
</project>