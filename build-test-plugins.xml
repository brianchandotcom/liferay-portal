<?xml version="1.0"?>

<project name="portal-test-plugins" basedir="." default="test" xmlns:antelope="antlib:ise.antelope.tasks">
	<import file="build-test.xml" />

	<target name="deploy-simple-server-plugin">
		<if>
			<isset property="portlet.properties.${plugin}" />
			<then>
				<propertycopy
					from="portlet.properties.${plugin}"
					name="portlet.properties"
					override="true"
				/>

				<echo file="${plugins.dir}/${plugin.types}/${plugin}/docroot/WEB-INF/src/portlet-ext.properties">${portlet.properties}</echo>
			</then>
			<else>
				<delete file="${plugins.dir}/${plugin.types}/${plugin}/docroot/WEB-INF/src/portlet-ext.properties" />
			</else>
		</if>

		<if>
			<equals arg1="${java.security}" arg2="true" />
			<then>
				<if>
					<not>
						<resourcecontains
							resource="${plugins.dir}/${plugin.types}/${plugin}/docroot/WEB-INF/liferay-plugin-package.properties"
							substring="security-manager-enabled=true"
						/>
					</not>
					<then>
						<echo append="true" file="${plugins.dir}/${plugin.types}/${plugin}/docroot/WEB-INF/liferay-plugin-package.properties">

security-manager-enabled=true</echo>
					</then>
				</if>
			</then>
		</if>

		<ant dir="${plugins.dir}/${plugin.types}/${plugin}" inheritAll="false">
			<target name="clean" />
			<target name="deploy" />
		</ant>
	</target>

	<target name="deploy-simple-server-plugins">
		<antcall target="prepare-build-properties">
			<param name="plugins.dir" value="${lp.plugins.dir}" />
		</antcall>

		<if>
			<isset property="plugins.additional.dir" />
			<then>
				<antcall target="prepare-build-properties">
					<param name="plugins.dir" value="${plugins.additional.dir}" />
				</antcall>
			</then>
		</if>

		<if>
			<matches pattern="http" string="${test.build.plugins.war.zip.url}" />
			<then>
				<for list="${plugins.includes}" param="plugin.includes">
					<sequential>
						<pathconvert pathsep="," property="plugin.war" setonempty="false">
							<path>
								<fileset
									dir="plugins"
									includes="@{plugin.includes}*.war"
								/>
							</path>
						</pathconvert>

						<propertyregex
							input="${plugin.war}"
							override="true"
							property="plugin.war"
							regexp=",.*"
							replace=""
						/>

						<if>
							<isset property="plugin.war" />
							<then>
								<copy file="${plugin.war}" todir="${liferay.home}/deploy" />

								<var name="plugin.war" unset="true" />
							</then>
							<else>
								<ant dir="${lp.plugins.dir}/${plugin.types}/@{plugin.includes}" inheritAll="false">
									<target name="clean" />
									<target name="deploy" />
								</ant>
							</else>
						</if>
					</sequential>
				</for>
			</then>
			<else>
				<ant dir="${lp.plugins.dir}/${plugin.types}" inheritAll="false">
					<target name="clean" />
					<target name="deploy" />
				</ant>
			</else>
		</if>

		<delete dir="${lp.plugins.dir}/dist" />
		<mkdir dir="${lp.plugins.dir}/dist" />
	</target>

	<target name="prepare-build-properties">
		<echo file="${plugins.dir}/build.${user.name}.properties">app.server.parent.dir=${app.server.parent.dir}
app.server.type=${app.server.type}

auto.deploy.dir=${liferay.home}/deploy</echo>

		<if>
			<equals arg1="${app.server.type}" arg2="jboss" />
			<then>
				<echo append="true" file="${plugins.dir}/build.${user.name}.properties">

app.server.jboss.dir=${app.server.dir}</echo>
			</then>
		</if>
	</target>
</project>