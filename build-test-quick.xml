	<target name="hashi">
		<delete dir="/home/me/Downloads/bundle" />
		<delete dir="/home/me/Downloads/bundle-dist" />

		<decompress
			dest="/home/me/Downloads/bundle"
			src="/home/me/Downloads/liferay-dxp-tomcat-7.4.13-u92-e8fd53aaf6b02.7z"
		/>

		<!--<decompress
			dest="/home/me/Downloads/bundle"
			src="/home/me/Downloads/liferay-dxp-tomcat-7.4.13.u94-20230913160210550.7z"
		/>-->

		<var name="app.server.parent.dir" unset="true" />

		<property name="app.server.parent.dir" value="/home/me/Downloads/bundle-dist" />

		<move
			todir="${app.server.parent.dir}"
		>
			<fileset
				dir="/home/me/Downloads/bundle"
				includes="liferay-*/**"
			/>
			<mapper
				from="[^/]+/(.*)"
				to="\1"
				type="regexp"
			/>
		</move>

		<execute>
			mv ${app.server.parent.dir}/tomcat ${app.server.parent.dir}/tomcat-9.0.75
		</execute>
	</target>

