        "portal-impl/test/integration/com/liferay/portlet/documentlibrary/service/persistence/DLFileEntryFinderTest.java",
        "portal-kernel/test/unit/com/liferay/portal/log/assertor/PortalLogAssertorTest.java",
        "portal-kernel/test/unit/com/liferay/portal/modules/ModulesStructureTest.java",
        "**/*ServiceHttpTest.java",
        "**/*ServiceJsonTest.java",
        "**/*ServiceSoapTest.java"
      ],
      "test_includes": [
        "**/src/test/**/*Test.java",
        "**/src/testIntegration/**/*Test.java",
        "**/test/integration/**/*Test.java",
        "**/test/unit/**/*Test.java"
      ]
    },
    {
      "name": "modules_integration",
      "test_excludes": "base:test_excludes",
      "test_includes": [
        "**/src/testIntegration/**/*Test.java"
      ],
      "test_per_node_max": 35
    },
    {
      "name": "modules_unit",
      "test_excludes": "base:test_excludes",
      "test_includes": [
        "**/src/test/**/*Test.java"
      ],
      "test_per_node_max": 250
    },
    {
      "name": "integration",
      "test_excludes": "base:test_excludes",
      "test_includes": [
        "**/test/integration/**/*Test.java"
      ]
    },
    {
      "name": "unit",
      "test_excludes": "base:test_excludes",
      "test_includes": [
        "**/test/unit/**/*Test.java"
      ]
    },
    {
      "name": "functional_portal_smoke",
      "poshi_query": "portal.smoke == true",
      "test_per_node_max": 7
    },
    {
      "name": "functional_portal_upgrade",
      "poshi_query": "portal.upgrade == true",
      "test_per_node_max": 7
    }
