          ],
          "test_filter": {
            "test_includes": "modules_integration:test_includes",
            "test_includes_module_changes_only": true,
            "test_per_node_max": 35
          }
        },
        {
          "name": "modules-unit-jdk8",
          "enable_on_change": [
            "modules/**"
          ],
          "test_filter": {
            "test_includes": "modules_unit:test_includes",
