{
	"params": {
		"ctx": {
			"apiextensions.crossplane.io/environment": {
				"deploymentName": "liferay-cluster",
				"projectId": "gcp-infra-project",
				"projectNumber": "987654321",
				"vpcName": "liferay-vpc"
			}
		},
		"obs": {
			"resources": {
				"liferay-db-grant-job": {
					"resource": {
						"status": {
							"conditions": [
								{
									"status": "True",
