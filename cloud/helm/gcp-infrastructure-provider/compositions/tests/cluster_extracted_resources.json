											"capabilities": {
												"drop": [
													"ALL"
												]
											},
											"runAsNonRoot": true,
											"runAsUser": 1000,
											"seccompProfile": {
												"type": "RuntimeDefault"
											}
										}
									}
								],
								"initContainers": [
									{
										"args": [
											"--auto-iam-authn",
											"--port=5432",
											"--private-ip",
											"--structured-logs",
											"cne-development:us-central1:arz-dev2025-infra-db-instance-blue"
