							"spec": {
								"containers": [
									{
										"args": [
											"set -e\nuntil pg_isready -h 127.0.0.1 -p 5432 -U postgres; do sleep 2; done\npsql -h 127.0.0.1 -v \"ON_ERROR_STOP=1\" -U postgres -d lportal <<EOF\nGRANT ALL PRIVILEGES ON DATABASE \"lportal\" TO \"arz-dev2025-infra-sa@cne-development.iam\";\nGRANT ALL ON ALL TABLES IN SCHEMA public TO \"arz-dev2025-infra-sa@cne-development.iam\";\nGRANT cloudsqlsuperuser TO \"arz-dev2025-infra-sa@cne-development.iam\";\nGRANT \"arz-dev2025-infra-sa@cne-development.iam\" to postgres;\nEOF\n"
