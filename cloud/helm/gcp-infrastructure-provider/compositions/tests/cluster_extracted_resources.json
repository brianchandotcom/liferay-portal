  {
    "apiVersion": "kubernetes.m.crossplane.io/v1alpha1",
    "kind": "Object",
    "name": "liferay-db-grant-job",
    "spec": {
      "forProvider": {
        "manifest": {
          "apiVersion": "batch/v1",
          "kind": "Job",
          "metadata": {
            "labels": {
              "app": "liferay",
              "deployment-name": "liferay-portal-poc",
              "environment-id": "dev2025",
              "environment_id": "dev2025",
              "project-id": "arz",
              "project_id": "arz"
            },
            "name": "arz-dev2025-infra-db-grant",
            "namespace": "liferay-arz-dev2025"
          },
          "spec": {
            "template": {
              "spec": {
                "containers": [
                  {
                    "args": [
                      "set -e\nuntil pg_isready -h 127.0.0.1 -p 5432 -U postgres; do sleep 2; done\npsql -h 127.0.0.1 -v \"ON_ERROR_STOP=1\" -U postgres -d lportal <<EOF\nGRANT ALL PRIVILEGES ON DATABASE \"lportal\" TO \"arz-dev2025-infra-sa@cne-development.iam\";\nGRANT ALL ON ALL TABLES IN SCHEMA public TO \"arz-dev2025-infra-sa@cne-development.iam\";\nGRANT cloudsqlsuperuser TO \"arz-dev2025-infra-sa@cne-development.iam\";\nEOF\n"
                    ],
                    "command": [
                      "/bin/sh",
                      "-c"
                    ],
                    "env": [
                      {
                        "name": "PGPASSWORD",
                        "valueFrom": {
                          "secretKeyRef": {
                            "key": "password",
                            "name": "arz-dev2025-infra-db-root-password"
                          }
                        }
                      }
                    ],
                    "image": "postgres:18-alpine",
                    "name": "sql-runner",
                    "resources": {
                      "limits": {
                        "cpu": "200m",
                        "memory": "256Mi"
                      },
                      "requests": {
                        "cpu": "100m",
                        "memory": "128Mi"
                      }
                    },
                    "securityContext": {
                      "allowPrivilegeEscalation": false,
                      "capabilities": {
                        "drop": [
                          "ALL"
                        ]
                      },
                      "runAsNonRoot": true,
                      "runAsUser": 1000,
                      "seccompProfile": {
                        "type": "RuntimeDefault"
                      }
                    }
                  }
                ],
                "initContainers": [
                  {
                    "args": [
                      "--auto-iam-authn",
                      "--port=5432",
                      "--private-ip",
                      "--structured-logs",
                      "cne-development:us-central1:arz-dev2025-infra-db-instance"
                    ],
                    "image": "gcr.io/cloud-sql-connectors/cloud-sql-proxy:2.14.1",
                    "name": "cloud-sql-proxy",
                    "resources": {
                      "limits": {
                        "cpu": "200m",
                        "memory": "256Mi"
                      },
                      "requests": {
                        "cpu": "100m",
                        "memory": "128Mi"
                      }
                    },
                    "restartPolicy": "Always",
                    "securityContext": {
                      "allowPrivilegeEscalation": false,
                      "capabilities": {
                        "drop": [
                          "ALL"
                        ]
                      },
                      "runAsNonRoot": true,
                      "runAsUser": 65532,
                      "seccompProfile": {
                        "type": "RuntimeDefault"
                      }
                    }
                  }
                ],
                "restartPolicy": "OnFailure",
                "securityContext": {
                  "fsGroup": 1000,
                  "runAsNonRoot": true,
                  "seccompProfile": {
                    "type": "RuntimeDefault"
                  }
                },
                "serviceAccountName": "liferay-default",
                "volumes": [
                  {
                    "emptyDir": {},
                    "name": "term-log"
                  }
                ]
              }
            }
          }
        }
      },
      "managementPolicies": [
        "Create",
        "Observe",
        "Delete"
      ],
      "providerConfigRef": {
        "kind": "ClusterProviderConfig",
        "name": "default"
      },
      "readiness": {
        "celQuery": "object.status.succeeded == 1",
        "policy": "DeriveFromCelQuery"
      },
      "watch": false
    },
