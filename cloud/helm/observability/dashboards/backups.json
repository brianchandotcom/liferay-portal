			"targets": [
				{
					"editorMode": "code",
					"exemplar": false,
					"expr": "avg by (name) (avg_over_time({\"__name__\"=\"kube_customresource_liferay_backup_start_time_seconds\", \"exported_namespace\"=\"$environment\"}[$__range])) * 1000",
					"format": "table",
					"instant": true,
					"legendFormat": "__auto",
					"range": false,
					"refId": "started"
				},
				{
					"datasource": {
						"type": "prometheus",
						"uid": "${DS_PROMETHEUS}"
					},
					"editorMode": "code",
					"exemplar": false,
					"expr": "avg by (name) (avg_over_time({\"__name__\"=\"kube_customresource_liferay_backup_completion_time_seconds\", \"exported_namespace\"=\"$environment\"}[$__range])) * 1000",
					"format": "table",
					"instant": true,
					"legendFormat": "__auto",
					"range": false,
					"refId": "finished"
				},
				{
					"datasource": {
						"type": "prometheus",
						"uid": "${DS_PROMETHEUS}"
					},
					"editorMode": "code",
					"exemplar": false,
					"expr": "(\n  avg by (name, reason) (\n    avg_over_time(kube_customresource_liferay_backup_status_condition{reason!=\"initiated\", exported_namespace=\"$environment\"}[$__range])\n  )\n)\nOR\n(\n  (\n    avg by (name, reason) (\n      avg_over_time(kube_customresource_liferay_backup_status_condition{reason=\"initiated\", exported_namespace=\"$environment\"}[$__range])\n    )\n    unless on(name)\n    avg by (name) (\n      avg_over_time(kube_customresource_liferay_backup_status_condition{reason!=\"initiated\", exported_namespace=\"$environment\"}[$__range])\n    )\n  ) + 0.5\n)",
					"format": "table",
					"instant": true,
					"legendFormat": "__auto",
					"range": false,
					"refId": "status"
				}
			],
			"title": "Backups",
			"transformations": [
				{
					"id": "joinByField",
					"options": {
						"byField": "name",
						"mode": "outerTabular"
					}
