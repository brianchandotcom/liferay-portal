@component-name = "portal-commerce"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Account";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			Account.tearDownCP();
		}
	}

	@description = "This tests that an admin can invite a new user with the same domain."
	@priority = 4
	test CanInviteNewUserToAccount {
		property test.smtp.server.enabled = "true";

		task ("Given an account with a domain set") {
			AccountConfiguration.enableAccountEmailDomain();

			Account.openAccountsAdmin();

			Account.addAccountWithDomain(
				accountName = "Acme Inc.",
				domainNames = "liferay.com");
		}

		task ("When admin invites a user with the same domain") {
			Account.inviteUser(
				accountName = "Acme Inc.",
				userEmailAddress = "userea@liferay.com");

			Alert.viewSuccessMessage();

			User.logoutPG();
		}

		task ("Then the user receives an email to create an account") {
			MockMock.viewMail(
				asset = "Test Test has invited you to join Acme Inc.",
				content = "Test Test has invited you to join Acme Inc.",
				recipient = "userea@liferay.com",
				sender = "Test Test",
				subject = "Test Test has invited you to join Acme Inc.");

			MockMock.openMockMock();

			MockMock.clickBodyLink(
				asset = "Test Test has invited you to join Acme Inc.",
				bodyLink = "Create Account",
				recipient = "userea@liferay.com");
		}

		task ("When the user creates an account") {
			Account.createAccount(
				newPassword = PropsUtil.get("default.admin.password"),
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");
		}

		task ("Then the user is successfully added to the business account") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "test@liferay.com",
				userLoginFullName = "Test Test");

			Account.openAccountsAdmin();

			LexiconEntry.gotoEntryMenuItem(
				menuItem = "Manage Users",
				rowEntry = "Acme Inc.");

			LexiconEntry.viewEntryName(rowEntry = "userfn userln");
		}
	}

}