{
	"browserslist": [
		"extends browserslist-config-clay-components"
	],
	"bugs": {
		"url": "https://github.com/liferay/liferay-portal/issues"
	},
	"dependencies": {
		"browser-tabs-lock": "^1.2.7",
		"core-js": "^2.5.6",
		"hash.js": "^1.1.7",
		"uuid": "9.0.0"
	},
	"description": "Javascript client to capture and send analytics data to server",
	"devDependencies": {
		"browserslist-config-clay-components": "^2.0.3",
		"fetch-mock": "^5.13.1",
		"isomorphic-fetch": "^2.2.1"
	},
	"homepage": "https://github.com/liferay/liferay-portal#readme",
	"jest": {
		"setupFilesAfterEnv": [
			"<rootDir>/test/setup.ts"
		],
		"testPathIgnorePatterns": [
			"<rootDir>/test/.eslintrc.js",
			"<rootDir>/test/setup.ts",
			"<rootDir>/test/helpers.ts"
		]
	},
	"keywords": [
		"Analytics"
	],
	"license": "MIT",
	"name": "analytics-client-js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/liferay/liferay-portal.git"
	},
	"scripts": {
		"build": "node-scripts build:custom",
		"checkFormat": "node-scripts format --check && tsc",
		"format": "node-scripts format && tsc",
		"start": "node-scripts build:custom --serve",
		"test": "USE_REACT_16=true node-scripts test"
	},
	"version": "1.0.0"
}
