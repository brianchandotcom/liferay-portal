{
	"$ref": "#/definitions/group",
	"$schema": "http://json-schema.org/draft-07/schema#",
	"definitions": {
		"group": {
			"additionalProperties": false,
			"properties": {
				"conjunction": {
					"enum": [
						"AND",
						"OR"
					]
				},
				"rules": {
					"items": {
						"$ref": "#/definitions/rule"
					},
					"type": "array"
				}
			},
			"required": [
				"conjunction",
				"rules"
			],
			"type": "object"
		},
		"leafRule": {
			"additionalProperties": false,
			"allOf": [
				{
					"if": {
						"properties": {
							"attribute": {
								"const": "user_authentication"
							}
						},
						"required": [
							"attribute"
						]
					},
					"then": {
						"properties": {
							"operator": {
								"enum": [
									"eq",
									"not_eq"
								]
							},
							"value": {
