							}
						},
						"required": [
							"attribute"
						]
					},
					"then": {
						"properties": {
							"operator": {
								"enum": [
									"includes",
									"not_includes"
								]
							},
							"value": {
								"type": "string"
							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"attribute": {
								"enum": [
									"language",
									"user_language"
								]
							}
						},
						"required": [
							"attribute"
						]
					},
					"then": {
						"properties": {
							"operator": {
								"enum": [
									"eq",
									"not_eq"
								]
							},
							"value": {
								"type": "string"
							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"attribute": {
								"anyOf": [
									{
										"enum": [
											"browser_name",
											"browser_version",
											"device_type",
											"geolocation",
											"hostname",
											"pathname",
											"referrer",
											"timezone",
											"url",
											"user_agent"
										]
									},
									{
										"pattern": "^custom:.+",
										"type": "string"
									}
								]
							}
						},
						"required": [
							"attribute"
						]
					},
					"then": {
						"properties": {
							"operator": {
								"enum": [
									"eq",
									"includes",
									"not_eq",
									"not_includes"
								]
							},
							"value": {
