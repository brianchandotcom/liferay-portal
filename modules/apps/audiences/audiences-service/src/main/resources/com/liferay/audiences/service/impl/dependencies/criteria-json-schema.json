							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"attribute": {
								"const": "local_hour"
							}
						},
						"required": [
							"attribute"
						]
					},
					"then": {
						"properties": {
							"operator": {
								"enum": [
									"eq",
									"gt",
									"gte",
									"lt",
									"lte",
									"not_eq"
								]
							},
							"value": {
								"type": "number"
							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"attribute": {
								"const": "local_date"
							}
						},
						"required": [
							"attribute"
						]
					},
					"then": {
						"properties": {
							"operator": {
								"enum": [
									"eq",
									"gt",
									"gte",
									"lt",
									"lte",
									"not_eq"
								]
							},
							"value": {
								"type": "string"
							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"attribute": {
								"enum": [
									"cookies",
									"request_parameters"
