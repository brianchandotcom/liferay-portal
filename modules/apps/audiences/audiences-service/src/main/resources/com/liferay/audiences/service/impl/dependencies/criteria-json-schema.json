				},
				"value": {
				}
			},
			"required": [
				"attribute",
				"operator",
				"value"
			],
			"type": "object"
		},
		"rule": {
			"oneOf": [
				{
					"$ref": "#/definitions/group"
				},
				{
					"$ref": "#/definitions/leafRule"
				}
			]
		}
	},
	"type": "object"
}