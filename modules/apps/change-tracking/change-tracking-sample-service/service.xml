<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder auto-import-default-references="false" auto-namespace-tables="false" dependency-injector="ds" mvcc-enabled="true" package-path="com.liferay.change.tracking.sample">
	<namespace>CTS</namespace>
	<entity change-tracking-enabled="true" local-service="true" name="Child" remote-service="false" trash-enabled="false" uuid="false">

		<!-- PK fields -->

		<column name="childId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="grandParentId" type="long" />
		<column name="parentChildId" type="long" />
		<column name="parentName" type="String" />

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
		<finder name="C_G" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="grandParentId" />
		</finder>
		<finder name="C_P" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="parentChildId" />
		</finder>
	</entity>
	<entity local-service="true" name="GrandParent" remote-service="false" trash-enabled="false" uuid="false">

		<!-- PK fields -->

		<column name="grandParentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="parentGrandParentId" type="long" />

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
	</entity>
	<entity change-tracking-enabled="true" local-service="true" name="Parent" remote-service="false" trash-enabled="false" uuid="false">

		<!-- PK fields -->

		<column name="parentId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />

		<!-- Other fields -->

		<column name="name" type="String" />
		<column name="grandParentId" type="long" />

		<!-- Finder methods -->

		<finder name="CompanyId" return-type="Collection">
			<finder-column name="companyId" />
		</finder>
		<finder name="C_G" return-type="Collection">
			<finder-column name="companyId" />
			<finder-column name="grandParentId" />
		</finder>
	</entity>
</service-builder>