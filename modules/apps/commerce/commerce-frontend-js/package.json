	},
	"devDependencies": {
		"faker": "^5.1.0",
		"fetch-mock": "5.13.1"
	},
	"jest": {
		"collectCoverageFrom": [
			"!<rootDir>/node_modules/",
			"<rootDir>/src/**/components/**/*.js",
			"<rootDir>/src/**/ServiceProvider/composeAPI.js",
			"<rootDir>/src/**/utilities/**/*.js",
			"!<rootDir>/src/**/constants.js",
			"!<rootDir>/src/**/entry.js"
		],
		"setupFiles": [
			"<rootDir>/test/tests_utilities/setup.spec.ts"
		],
		"testPathIgnorePatterns": [
			"<rootDir>/test/tests_utilities/"
		]
	},
	"main": "index.js",
	"name": "commerce-frontend-js",
	"private": true,
	"scripts": {
		"build": "node-scripts build",
		"checkFormat": "node-scripts format --check",
		"coverage": "node-scripts test --coverage --silent --verbose",
		"format": "node-scripts format",
		"test": "USE_REACT_16=true node-scripts test",
		"test:watch": "USE_REACT_16=true node-scripts test --watch"
	},
	"version": "4.0.148"
}
