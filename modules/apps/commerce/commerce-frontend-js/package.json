		"@liferay/frontend-data-set-web": "*",
		"@liferay/frontend-js-react-web": "*",
		"@liferay/frontend-js-state-web": "*",
		"classnames": "2.3.1",
		"fetch-mock": "5.13.1",
		"frontend-js-components-web": "*",
