exports[`MiniCart Item by data flow if the cart item has errors renders a div with icon and error text 1`] = `"<div class=\\"row\\"><div class=\\"col-auto\\"><svg class=\\"lexicon-icon lexicon-icon-exclamation-circle\\" role=\\"presentation\\"><use href=\\"#exclamation-circle\\"></use></svg></div><div class=\\"col\\"><div>error</div></div></div>"`;

exports[`MiniCart Item by default ...also with the item's thumbnail 1`] = `"<div class=\\"mini-cart-item-details position-relative\\"><a class=\\"h-100 mini-cart-item-anchor position-absolute w-100\\" data-senna-off=\\"true\\" href=\\"http://localhost:8080/group/siteDefaultUrl/p/u-joint\\"><span class=\\"sr-only\\">go-to-x</span></a><div class=\\"mini-cart-item-thumbnail\\"><picture><img src=\\"http://some.url/thumbnail.png\\"></picture></div><div class=\\"mini-cart-item-info ml-3 w-100 options\\"><div class=\\"item-info-base\\"><div class=\\"h5 item-name\\">An Item</div><p class=\\"item-sku\\">ITEM0001</p></div><div class=\\"child-items\\"></div></div></div><div class=\\"align-items-center d-flex mini-cart-item-quantity mini-cart-item-alignment\\"><div class=\\"form-group mb-0\\"><input aria-label=\\"quantity-selector\\" max=\\"2\\" min=\\"1\\" step=\\"1\\" class=\\"form-control quantity-selector\\" type=\\"number\\" value=\\"1\\"></div><div class=\\"ml-2\\"></div></div><div class=\\"mini-cart-item-price mini-cart-item-alignment\\"><div class=\\"compact price\\"><span class=\\"price-label\\">list-price</span><span class=\\"price-value price-value-inactive\\">$ 8.00</span><span class=\\"price-label\\">promotion-price</span><span class=\\"price-value price-value-promo\\">$ 8.00</span></div></div><div class=\\"mini-cart-item-actions mini-cart-item-alignment\\"><button class=\\"d-inline-flex btn btn-monospaced btn-unstyled\\" type=\\"button\\" aria-label=\\"delete-x\\" title=\\"delete-x\\"><svg class=\\"lexicon-icon lexicon-icon-times-circle-full\\" role=\\"presentation\\"><use href=\\"#times-circle-full\\"></use></svg></button></div><div class=\\"mini-cart-item-is-removing-wrapper\\"><div class=\\"mini-cart-item-is-removing\\"><span>the-item-will-be-removed</span><span><button class=\\"btn btn-sm btn-link\\" type=\\"button\\">undo</button></span></div></div>"`;

exports[`MiniCart Item by default renders the cart item with its information (ItemInfoView), quantity (QuantitySelector), price (Price), and a button to remove it from the cart, plus a hidden div to handle the item removal cancellation 1`] = `"<div class=\\"mini-cart-item-details position-relative\\"><a class=\\"h-100 mini-cart-item-anchor position-absolute w-100\\" data-senna-off=\\"true\\" href=\\"http://localhost:8080/group/siteDefaultUrl/p/u-joint\\"><span class=\\"sr-only\\">go-to-x</span></a><div class=\\"mini-cart-item-info ml-3 w-100 options\\"><div class=\\"item-info-base\\"><div class=\\"h5 item-name\\">An Item</div><p class=\\"item-sku\\">ITEM0001</p></div><div class=\\"child-items\\"></div></div></div><div class=\\"align-items-center d-flex mini-cart-item-quantity mini-cart-item-alignment\\"><div class=\\"form-group mb-0\\"><input aria-label=\\"quantity-selector\\" max=\\"2\\" min=\\"1\\" step=\\"1\\" class=\\"form-control quantity-selector\\" type=\\"number\\" value=\\"1\\"></div><div class=\\"ml-2\\"></div></div><div class=\\"mini-cart-item-price mini-cart-item-alignment\\"><div class=\\"compact price\\"><span class=\\"price-label\\">list-price</span><span class=\\"price-value price-value-inactive\\">$ 8.00</span><span class=\\"price-label\\">promotion-price</span><span class=\\"price-value price-value-promo\\">$ 8.00</span></div></div><div class=\\"mini-cart-item-actions mini-cart-item-alignment\\"><button class=\\"d-inline-flex btn btn-monospaced btn-unstyled\\" type=\\"button\\" aria-label=\\"delete-x\\" title=\\"delete-x\\"><svg class=\\"lexicon-icon lexicon-icon-times-circle-full\\" role=\\"presentation\\"><use href=\\"#times-circle-full\\"></use></svg></button></div><div class=\\"mini-cart-item-is-removing-wrapper\\"><div class=\\"mini-cart-item-is-removing\\"><span>the-item-will-be-removed</span><span><button class=\\"btn btn-sm btn-link\\" type=\\"button\\">undo</button></span></div></div>"`;

exports[`MiniCart Item by interaction if the cart item delete button is clicked unhides the div to handle the item removal cancellation 1`] = `"<div class=\\"mini-cart-item-details position-relative\\"><a class=\\"h-100 mini-cart-item-anchor position-absolute w-100\\" data-senna-off=\\"true\\" href=\\"http://localhost:8080/group/siteDefaultUrl/p/u-joint\\"><span class=\\"sr-only\\">go-to-x</span></a><div class=\\"mini-cart-item-info ml-3 w-100 options\\"><div class=\\"item-info-base\\"><div class=\\"h5 item-name\\">An Item</div><p class=\\"item-sku\\">ITEM0001</p></div><div class=\\"child-items\\"></div></div></div><div class=\\"align-items-center d-flex mini-cart-item-quantity mini-cart-item-alignment\\"><div class=\\"form-group mb-0\\"><input aria-label=\\"quantity-selector\\" max=\\"2\\" min=\\"1\\" step=\\"1\\" class=\\"form-control quantity-selector\\" type=\\"number\\" value=\\"1\\"></div><div class=\\"ml-2\\"></div></div><div class=\\"mini-cart-item-price mini-cart-item-alignment\\"><div class=\\"compact price\\"><span class=\\"price-label\\">list-price</span><span class=\\"price-value price-value-inactive\\">$ 8.00</span><span class=\\"price-label\\">promotion-price</span><span class=\\"price-value price-value-promo\\">$ 8.00</span></div></div><div class=\\"mini-cart-item-actions mini-cart-item-alignment\\"><button class=\\"d-inline-flex btn btn-monospaced btn-unstyled\\" type=\\"button\\" aria-label=\\"delete-x\\" title=\\"delete-x\\"><svg class=\\"lexicon-icon lexicon-icon-times-circle-full\\" role=\\"presentation\\"><use href=\\"#times-circle-full\\"></use></svg></button></div><div class=\\"active mini-cart-item-is-removing-wrapper\\"><div class=\\"mini-cart-item-is-removing\\"><span>the-item-will-be-removed</span><span><button class=\\"btn btn-sm btn-link\\" type=\\"button\\">undo</button></span></div></div>"`;
