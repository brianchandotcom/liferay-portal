definition {

	macro assertWarehouseDetails {
		if (isSet(name)) {
			AssertTextEquals(
				key_fieldLabel = "Name",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${name});
		}

		if (isSet(description)) {
			AssertTextEquals(
				locator1 = "TextArea#DESCRIPTION",
				value1 = ${description});
		}

		if (isSet(active)) {
			if (${active} == "true") {
				AssertChecked.assertCheckedNotVisible(
					key_toggleSwitchLabel = "Active",
					locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");
			}
			else if (${active} == "false") {
				AssertNotChecked.assertNotCheckedNotVisible(
					key_toggleSwitchLabel = "Active",
					locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");
			}
		}

		if (isSet(latitude)) {
			AssertTextEquals(
				key_fieldLabel = "Latitude",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${latitude});
		}

		if (isSet(longitude)) {
			AssertTextEquals(
				key_fieldLabel = "Longitude",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${longitude});
		}

		if (isSet(street1)) {
			AssertTextEquals(
				key_fieldLabel = "Street 1",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${street1});
		}

		if (isSet(street2)) {
			AssertTextEquals(
				key_fieldLabel = "Street 2",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${street2});
		}

		if (isSet(street3)) {
			AssertTextEquals(
				key_fieldLabel = "Street 3",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${street3});
		}

		if (isSet(country)) {
			AssertSelectedLabel(
				key_fieldLabel = "Country",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${country});
		}

		if (isSet(region)) {
			AssertSelectedLabel(
				key_fieldLabel = "Region",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${region});
		}

		if (isSet(postalCode)) {
			AssertTextEquals(
				key_fieldLabel = "Postal Code",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${postalCode});
		}

		if (isSet(city)) {
			AssertTextEquals(
				key_fieldLabel = "City",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${city});
		}
	}

	macro editWarehouseDetails {
		if (isSet(name)) {
			Type(
				key_fieldLabel = "Name",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${name});
		}

		if (isSet(description)) {
			Type(
				locator1 = "TextArea#DESCRIPTION",
				value1 = ${description});
		}

		if (isSet(active)) {
			if (${active} == "true") {
				Check.checkToggleSwitch(
					key_toggleSwitchLabel = "Active",
					locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");
			}
			else if (${active} == "false") {
				Uncheck.uncheckToggleSwitch(
					key_toggleSwitchLabel = "Active",
					locator1 = "ToggleSwitch#ANY_TOGGLE_SWITCH");
			}
		}

		if (isSet(latitude)) {
			Type(
				key_fieldLabel = "Latitude",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${latitude});
		}

		if (isSet(longitude)) {
			Type(
				key_fieldLabel = "Longitude",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${longitude});
		}

		if (isSet(street1)) {
			Type(
				key_fieldLabel = "Street 1",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${street1});
		}

		if (isSet(street2)) {
			Type(
				key_fieldLabel = "Street 2",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${street2});
		}

		if (isSet(street3)) {
			Type(
				key_fieldLabel = "Street 3",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${street3});
		}

		if (isSet(country)) {
			Select(
				key_fieldLabel = "Country",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${country});
		}

		if (isSet(region)) {
			Select(
				key_fieldLabel = "Region",
				locator1 = "Select#GENERIC_SELECT_FIELD",
				value1 = ${region});
		}

		if (isSet(postalCode)) {
			Type(
				key_fieldLabel = "Postal Code",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${postalCode});
		}

		if (isSet(city)) {
			Type(
				key_fieldLabel = "City",
				locator1 = "TextInput#GENERIC_TEXT_INPUT",
				value1 = ${city});
		}

		Button.clickSave();

		Alert.viewSuccessMessage();
	}

}