@component-name = "portal-commerce"
definition {

	property browser.chrome.version = "139.0";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Order Management";

	setUp {
		CommerceConfiguration.commerceSetUp();

		task ("Enable private pages") {
			PagesAdmin.enablePrivatePages();
		}
	}

	tearDown {
		CommerceConfiguration.commerceTearDown();
	}

	@description = "COMMERCE-11821 | Discount is applied correctly when a tax category is enabled"
	@priority = 4
	test CanApplyDiscountWithTaxCategoryEnabled {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site is created") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And an account associated with a buyer user") {
			CommerceEntry.addAccountEntryUser(
				accountName = "Commerce Account",
				accountType = "Business",
				agreeToTermsAndAnswerReminderQuery = "true",
				createNewAccount = "true",
				requireReset = "false",
				userEmailAddress = "buyer@liferay.com",
				userFirstName = "Buyer",
				userLastName = "User",
				userRole = "Buyer",
				userScreenName = "buyeruser",
				userSiteMembership = "Minium");
		}

		task ("And a discount with a rule is created") {
			CommerceJSONDiscountsAPI._addDiscount(
				active = "true",
				level = "L1",
				percentageLevel1 = 15,
				target = "shipping",
				title = "Discount 1",
				usePercentage = "false");

			CommerceNavigator.goToDiscountAdmin();

			CommerceNavigator.gotoEntry(entryName = "Discount 1");

			CommerceDiscounts.addNewDiscountsRule(
				name = "FREESHIPPING",
				type = "Cart Total");

			LexiconEntry.gotoEntryMenuItem(
				menuItem = "Edit",
				rowEntry = "FREESHIPPING");

			CommerceDiscounts.editDiscountRule(
				key_fieldLabel = "Cart Total Minimum Amount",
				quantity = 200);
		}

		task ("And a Tax Categories entry is created") {
			CommerceNavigator.goToTaxCategoriesAdmin();

			CommerceEntry.addTaxCategory(
				keyDescription = "Test Description",
				keyName = "Test",
				keyReferenceCode = "Test Reference");
		}

		task ("And Tax Rate is configurated") {
			CommerceChannels.openChannelsAdmin();

			CommerceNavigator.gotoEntry(entryName = "Minium Portal");

			CommerceChannels.editTaxCalculation(
				active = "true",
				fieldLabel = "Rate",
				percentage = "true",
				quantity = 10,
				taxCalculationName = "Fixed Tax Rate",
				taxCategory = "Test");
		}

		task ("And product configuration is set with tax category") {
			CommerceProducts.openProductsAdmin();

			CommerceProducts.searchAndGoToProductEntry(entryProductName = "U-Joint");

			CommerceEntry.gotoMenuTab(menuTab = "Configuration");

			Select(
				key_title = "Tax Category",
				locator1 = "CommerceEntry#CATALOGS_FORM",
				value1 = "Test");

			Button.clickPublish();
		}

		task ("And the buyer user logs in") {
			User.logoutPG();

			CommerceLogin.miniumLogin(
				password = PropsUtil.get("default.admin.password"),
				urlAppend = "web/minium",
				userEmailAddress = "buyer@liferay.com");
		}

		task ("When a buyer user adds a product to the cart") {
			FrontStore.addInitializerProductToCart(
				productName = "U-Joint",
				productQuantity = 10);
		}

		task ("Then the user completes the checkout process and tax and discount are correctly applied") {
			CommerceCheckout.gotoCheckoutViaMiniCart();

			CommerceCheckout.initializersCheckout(
				deliveryDiscountFixedAmount = 15,
				newAddressAddress = "Test Address",
				newAddressCity = "Test City",
				newAddressCountry = "United States",
				newAddressName = "Address Name",
				newAddressZipCode = "Test Zip Code",
				productName = "U-Joint",
				productQuantity = 10,
				productUnitPrice = 24,
				shippingMethod = "Standard",
				taxValue = 24,
				totalValue = 264);
		}
	}

	@description = "This is a test for COMMERCE-10663. Single Approver workflow for Commerce Discounts is triggered once the user clicks on 'Submit for Workflow'"
	@priority = 3
	test CanAssertCommerceDiscountSingleApproverWorkflowIsApplied {
		property portal.acceptance = "false";

		task ("Given Single Approver workflow is set for Commerce Discount") {
			Workflow.openWorkflowProcessBuilderConfiguration();

			Workflow.configureWorkflow(
				workflowDefinition = "Single Approver",
				workflowResourceValue = "Discount");
		}

		task ("When a new discount is created") {
			CommerceNavigator.goToDiscountAdmin();

			Click(locator1 = "Button#PLUS");

			CommerceEntry.addNewDiscountsEntry(
				discountName = "Test Discount",
				discountTarget = "Products",
				discountType = "Percentage",
				publish = "false");
		}

		task ("Then the discount status is Draft") {
			AssertElementPresent(
				key_status = "Draft",
				locator1 = "CommerceEntry#WORKFLOW_STATUS");
		}

		task ("When the user submits the discount for publication") {
			Click(
				key_text = "Submit for Workflow",
				locator1 = "Button#ANY");
		}

		task ("Then status for the discount is changed to PENDING") {
			AssertElementPresent(
				key_status = "Pending",
				locator1 = "CommerceEntry#WORKFLOW_STATUS");
		}
	}

	@description = "This is a test case for COMMERCE-10819. User with Discount Manager role can access Discounts from Control Panel"
	@priority = 3
	test CanDiscountManagerAccessDiscountsPanel {
		property custom.properties = "company.security.strangers.verify=false${line.separator}jsonws.web.service.paths.excludes=";
		property portal.acceptance = "false";

		task ("Given a Minium site") {
			CommerceAccelerators.initializeNewSiteViaAccelerator(siteName = "Minium");
		}

		task ("And a user with Discount Manager role is created") {
			JSONUser.addUserWithRole(
				roleTitle = "Discount Manager",
				userEmailAddress = "discount.manager@liferay.com",
				userFirstName = "Discount",
				userLastName = "Manager",
				userScreenName = "discount.manager");
		}

		task ("When Discount Manager logs in") {
			User.logoutAndLoginPG(
				userLoginEmailAddress = "discount.manager@liferay.com",
				userLoginFullName = "Discount Manager");
		}

		task ("Then Discounts panel is shown") {
			CommerceNavigator.goToDiscountAdmin();

			AssertTextEquals(
				locator1 = "ControlMenu#HEADING",
				value1 = "Discounts");
		}
	}

}