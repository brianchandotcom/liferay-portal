	@description = "This is a test for LPS-122278. As Content Creator, I want to define reusable translations when creating WEM Structures without nested fields or fieldsets"
	@priority = "4"
	test VerifyDefaultLanguageIsFirstShown {
		property portal.acceptance = "false";

		ProductMenu.gotoPortlet(
			category = "Content & Data",
			portlet = "Web Content");

		NavItem.gotoStructures();

		WebContentStructures.addCP(
			structureDescription = "Test",
			structureName = "Test");

		DataEngine.addField(
			fieldFieldLabel = "Text Test",
			fieldName = "Text");

		DataEngine.editFieldTip(
			fieldFieldLabel = "Text Test",
			fieldHelp = "Help Text test");

		PortletEntry.changeLocale(locale = "pt-BR");

		DataEngine.editFieldTip(
			fieldFieldLabel = "Text Test",
			fieldHelp = "Texto teste ajuda");

		WebContentStructures.addName(structureName = "Teste");

		FormViewBuilder.editFieldLabel(
			fieldLabel = "Text Test",
			label = "Texto Teste");

		WebContentStructures.saveCP(structureName = "Test");

		WebContentStructures.viewCP(
			structureDescription = "Test",
			structureName = "Test");

		LexiconEntry.gotoEntry(rowEntry = "Test");

		PortletEntry.viewLocale(locale = "en-US");

		WebContentStructures.saveCP(structureName = "Test");

		WebContentStructures.deleteCP(structureName = "Test");
	}

}