<html>
<head>
<title>DigitalSignatureConfiguration</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">DigitalSignatureConfiguration</td></tr>
</thead>

<tbody>
<tr>
	<td>CHECK_INPUT_ENABLED</td>
	<td>//input[contains(@id, 'SiteSettingsPortlet_enabled') and @checked]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_ACCOUNT_ID</td>
	<td>//input[contains(@name,'apiAccountId')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_BASE_URI</td>
	<td>//input[contains(@name,'accountBaseURI')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_INTEGRATION_KEY</td>
	<td>//input[contains(@name,'integrationKey')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_RSA_PRIVATE_KEY</td>
	<td>//textarea[contains(@name,'rsaPrivateKey')]</td>
	<td></td>
</tr>
<tr>
	<td>DIGITAL_SIGNATURE_USER_ID</td>
	<td>//input[contains(@name,'apiUsername')]</td>
	<td></td>
</tr>
<tr>
	<td>SITE_SETTINGS_STRATEGY</td>
	<td>//select[contains(@name,'siteSettingsStrategy')]</td>
	<td></td>
</tr>
<tr>
	<td>SITE_SETTINGS_STRATEGY_CHOOSEN</td>
	<td>//div[contains(@class, 'form-group')]//div[contains(@class, 'col-md-12') and contains(., '${siteSettingsStrategy}')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>