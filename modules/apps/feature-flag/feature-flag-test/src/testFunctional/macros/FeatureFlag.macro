definition {

	@summary = "Default summary"
	macro disableFeatureFlag(configurationScope = null, featureFlag = null, scope = null) {
		FeatureFlag.toggleFeatureFlag(
			configurationScope = ${configurationScope},
			featureFlag = ${featureFlag},
			scope = ${scope},
			toggleState = "Disabled");
	}

	@summary = "Default summary"
	macro enableFeatureFlag(configurationScope = null, featureFlag = null, scope = null) {
		FeatureFlag.toggleFeatureFlag(
			configurationScope = ${configurationScope},
			featureFlag = ${featureFlag},
			scope = ${scope},
			toggleState = "Enabled");
	}

	@summary = "Default summary"
	macro toggleFeatureFlag(toggleState = null, configurationScope = null, featureFlag = null, scope = null) {
		if (!(isSet(configurationScope))) {
			var configurationScope = "Virtual Instance Scope";
		}

		if (isSet(scope)) {
			Click(
				key_configurationName = ${scope},
				key_configurationScope = ${configurationScope},
				locator1 = "SystemSettings#SCOPED_CONFIGURATION_NAME");
		}

		if (IsElementNotPresent(locator1 = "FeatureFlag#TOGGLE_ROW", title_row = ${featureFlag}, toggle_state = "")) {
			Search.searchCP(searchTerm = ${featureFlag});
		}

		if (IsElementNotPresent(locator1 = "FeatureFlag#TOGGLE_ROW", title_row = ${featureFlag}, toggle_state = ${toggleState})) {
			Check.checkToggleSwitch(
				locator1 = "FeatureFlag#TOGGLE_ROW",
				title_row = ${featureFlag},
				toggle_state = "");

			WaitForElementPresent(
				locator1 = "FeatureFlag#TOGGLE_ROW",
				title_row = ${featureFlag},
				toggle_state = ${toggleState});
		}
	}

}