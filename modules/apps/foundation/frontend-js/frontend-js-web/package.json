{
	"dependencies": {
		"liferay-amd-loader": "2.1.0",
		"svg4everybody": "^2.1.8"
	},
	"devDependencies": {
		"babel-preset-env": "^1.6.0",
		"eslint": "^4.6.1",
		"eslint-config-liferay": "^1.0.2",
		"jest": "^20.0.4",
		"liferay-jest-junit-reporter": "0.0.3",
		"liferay-module-config-generator": "^1.2.1",
		"metal": "^2.5.12",
		"metal-cli": "^4.2.0",
		"metal-component": "^2.5.13",
		"metal-dom": "^2.5.13",
		"metal-events": "^2.5.16",
		"prettier": "^1.6.1"
	},
	"jest": {
		"globals": {
			"Liferay": {}
		},
		"testMatch": [
			"**/test/**/*.js"
		],
		"testResultsProcessor": "./node_modules/liferay-jest-junit-reporter",
		"transformIgnorePatterns": [
			"<rootDir>.*(node_modules)(?!.*metal.*).*$"
		]
	},
	"name": "frontend-js-web",
	"scripts": {
		"format": "prettier --write src/**/*.es.js test/**/*.es.js",
		"lint": "eslint src/**/*.es.js test/**/*.es.js",
		"test": "jest"
	},
	"version": "1.0.61"
}
