<?xml version="1.0"?>

<beans
	default-destroy-method="destroy"
	default-init-method="afterPropertiesSet"
	xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
>
	<bean class="com.liferay.portal.security.service.access.policy.internal.permission.SAPEntryPermissionChecker" factory-method="create" id="com.liferay.portal.security.service.access.policy.internal.permission.SAPEntryPermissionChecker">
		<constructor-arg ref="com.liferay.portal.security.service.access.policy.service.SAPEntryLocalService" />
		<constructor-arg ref="com.liferay.portal.security.service.access.policy.internal.permission.SAPPortletPermissionChecker" />
	</bean>
	<bean class="com.liferay.portal.security.service.access.policy.internal.permission.SAPPortletPermissionChecker" id="com.liferay.portal.security.service.access.policy.internal.permission.SAPPortletPermissionChecker" />
</beans>