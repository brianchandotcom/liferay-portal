<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.1.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_1_0.dtd">

<service-builder auto-namespace-tables="false" package-path="com.liferay.meris">
	<author>Eduardo Garcia</author>
	<namespace>Meris</namespace>
	<entity local-service="true" name="MerisSegment" remote-service="true">

		<!-- PK fields -->

		<column name="merisSegmentId" primary="true" type="long" />

		<!-- Group instance -->

		<column name="groupId" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column localized="true" name="name" type="String" />
		<column localized="true" name="description" type="String" />
		<column name="key" type="String" />
		<column name="active" type="boolean" />
		<column name="type" type="String" />
		<column name="criteria" type="String" />

		<!-- Order -->

		<order by="desc">
			<order-column name="modifiedDate" />
		</order>

		<!-- Finder methods -->

		<finder name="GroupId" return-type="Collection">
			<finder-column name="groupId" />
		</finder>
		<finder name="G_K" return-type="MerisSegment" unique="true">
			<finder-column name="groupId" />
			<finder-column name="key" />
		</finder>
		<finder name="G_A" return-type="Collection">
			<finder-column name="groupId" />
			<finder-column name="active" />
		</finder>
	</entity>
	<entity local-service="true" name="MerisSegmentRel" remote-service="false">

		<!-- PK fields -->

		<column name="merisSegmentRelId" primary="true" type="long" />

		<!-- Group instance -->

		<column name="groupId" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column name="merisSegmentId" type="long" />
		<column name="classNameId" type="long" />
		<column name="classPK" type="long" />

		<!-- Finder methods -->

		<finder name="MerisSegmentId" return-type="Collection">
			<finder-column name="merisSegmentId" />
		</finder>
		<finder name="CN_CPK" return-type="Collection">
			<finder-column name="classNameId" />
			<finder-column name="classPK" />
		</finder>
	</entity>
</service-builder>