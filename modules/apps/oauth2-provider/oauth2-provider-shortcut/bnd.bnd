Bundle-Name: Liferay OAuth2 Provider Shortcut
Bundle-SymbolicName: com.liferay.oauth2.provider.shortcut
Bundle-Version: 2.0.0
Provide-Capability:\
	liferay.resource.bundle;\
		resource.bundle.aggregate:String="(bundle.symbolic.name=com.liferay.oauth2.provider.shortcut),(bundle.symbolic.name=com.liferay.oauth2.provider.web)";\
		resource.bundle.base.name="content.Language";\
		service.ranking="1";\
		servlet.context.name=oauth2-provider-web
Web-ContextPath: /oauth2-provider-shortcut