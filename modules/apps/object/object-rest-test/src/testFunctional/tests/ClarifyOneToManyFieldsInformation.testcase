@component-name = "portal-headless"
definition {

	property custom.properties = "feature.flag.LPS-161364=true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Object";
	property testray.main.component.name = "Headless";

	setUp {
		TestCase.setUpPortalInstanceNoSelenium();

		task ("Given object definitions Student, Subject, University with text field name created") {
			ObjectUtils.staticObjectDefinitionIdStudent();

			ObjectUtils.staticObjectDefinitionIdSubject();

			ObjectUtils.staticObjectDefinitionIdUniversity();
		}

		task ("And Given universityStudents oneToMany relationship is created") {
			ObjectDefinitionAPI.createRelationship(
				deletionType = "cascade",
				en_US_label = "UniversityStudents",
				name = "universityStudents",
				objectDefinitionId1 = "${staticObjectDefinitionIdUniversity}",
				objectDefinitionId2 = "${staticObjectDefinitionIdStudent}",
				type = "oneToMany");
		}

		task ("And Given subjectStudents oneToMany relationship is created") {
			ObjectDefinitionAPI.createRelationship(
				deletionType = "cascade",
				en_US_label = "SubjectStudents",
				name = "subjectStudents",
				objectDefinitionId1 = "${staticObjectDefinitionIdSubject}",
				objectDefinitionId2 = "${staticObjectDefinitionIdStudent}",
				type = "oneToMany");
		}

		task ("And Given a Student entry, Subject entry, University entry created") {
			ObjectUtils.staticStudentEntry();

			ObjectUtils.staticUniversityEntry();

			ObjectUtils.staticSubjectEntry();
		}

		task ("And Given University entry related to the Student entry") {
			ObjectDefinitionAPI.relateObjectEntries(
				en_US_plural_label = "universities",
				objectEntry1 = "${staticUniversityEntryId}",
				objectEntry2 = "${staticStudentEntryId}",
				relationshipName = "universityStudents");
		}

		task ("And Given Student entry related to the Subject entry") {
			ObjectDefinitionAPI.relateObjectEntries(
				en_US_plural_label = "subjects",
				objectEntry1 = "${staticSubjectEntryId}",
				objectEntry2 = "${staticStudentEntryId}",
				relationshipName = "subjectStudents");
		}
	}

	tearDown {
		for (var objectName : list "University,Student,Subject") {
			ObjectAdmin.deleteObjectViaAPI(objectName = "${objectName}");
		}

		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if ("${testPortalInstance}" == "true") {
			PortalInstances.tearDownCPNoSelenium();
		}
	}

	@disable-webdriver = "true"
	@priority = "4"
	test CanGetMultipleNestedFieldsInOneToManyRelationshipFromChild {
		property portal.acceptance = "true";
		property test.name.skip.portal.instance = "ClarifyOneToManyFieldsInformation#CanGetMultipleNestedFieldsInOneToManyRelationshipFromChild";

		task ("When requesting GET /o/c/students/{studentId}?nestedFields=universityStudents,subjectStudents") {
			var response = ObjectDefinitionAPI.getObjectEntryById(
				en_US_plural_label = "students",
				objectEntryId = "${staticStudentEntryId}",
				parameter = "nestedFields",
				parameterValue = "universityStudents,subjectStudents");
		}

		task ("Then nodes subjectStudents,universityStudents contain related student entry data") {
			var universityEntryErc = JSONUtil.getWithJSONPath("${response}", "$..universityStudents[?(@.id==${staticUniversityEntryId})].externalReferenceCode");
			var subjectEntryErc = JSONUtil.getWithJSONPath("${response}", "$..subjectStudents[?(@.id==${staticSubjectEntryId})].externalReferenceCode");

			TestUtils.assertEquals(
				actual = "${universityEntryErc}",
				expected = "${staticUniversityEntryErc}");

			TestUtils.assertEquals(
				actual = "${subjectEntryErc}",
				expected = "${staticSubjectEntryErc}");
		}
	}

	@disable-webdriver = "true"
	@priority = "4"
	test CanGetNestedFieldsNodeInOneToManyRelationshipFromParent {
		property portal.acceptance = "true";
		property test.name.skip.portal.instance = "ClarifyOneToManyFieldsInformation#CanGetNestedFieldsNodeInOneToManyRelationshipFromParent";

		task ("When requesting GET /o/c/subjects/{subjectId}?nestedFields=subjectStudents") {
			var response = ObjectDefinitionAPI.getObjectEntryById(
				en_US_plural_label = "subjects",
				objectEntryId = "${staticSubjectEntryId}",
				parameter = "nestedFields",
				parameterValue = "subjectStudents");
		}

		task ("Then subjectStudents node contains related student entry data") {
			var studentEntryIdFromNode = JSONUtil.getWithJSONPath("${response}", "$..subjectStudents.[?(@.externalReferenceCode=='${staticStudentEntryErc}')].id");

			TestUtils.assertEquals(
				actual = "${studentEntryIdFromNode}",
				expected = "${staticStudentEntryId}");
		}
	}

	@disable-webdriver = "true"
	@priority = "4"
	test CanGetRelatedObjectEntryIdInOneToManyRelationshipFromChild {
		property portal.acceptance = "true";
		property test.name.skip.portal.instance = "ClarifyOneToManyFieldsInformation#CanGetRelatedObjectEntryIdInOneToManyRelationshipFromChild";

		task ("When requesting GET /o/c/students/{studentId}") {
			var response = ObjectDefinitionAPI.getObjectEntryById(
				en_US_plural_label = "students",
				objectEntryId = "${staticStudentEntryId}");
		}

		task ("Then the response contains r_universityStudents_c_universityId,r_universityStudents_c_universityERC,universityStudentsERC values") {
			var r_universityStudents_c_universityErc = JSONUtil.getWithJSONPath("${response}", "$..r_universityStudents_c_universityERC");
			var r_universityStudents_c_universityId = JSONUtil.getWithJSONPath("${response}", "$..r_universityStudents_c_universityId");
			var universityStudentsErcValue = JSONUtil.getWithJSONPath("${response}", "$..universityStudentsERC");

			TestUtils.assertEquals(
				actual = "${r_universityStudents_c_universityErc}",
				expected = "${universityStudentsErcValue}");

			TestUtils.assertEquals(
				actual = "${r_universityStudents_c_universityId}",
				expected = "${staticUniversityEntryId}");
		}
	}

}