definition {

	@summary = "Default summary"
	macro editRelationshipsParameter(parameterOption = null) {
		Click(locator1 = "ObjectRelationships#SELECT_PARAMETER_FORM");

		ClickNoError.clickNoMouseOver(
			key_parameterOption = ${parameterOption},
			locator1 = "ObjectRelationships#SELECT_PARAMETER_OPTION");
	}

}