Bundle-Name: Polls Services
Bundle-SymbolicName: com.liferay.portlet.polls.service
Bundle-Version: 1.0.0
Export-Package:\
	com.liferay.portlet.polls.lar
Include-Resource: classes
Liferay-Service: true
Require-Capability :\
	liferay.extender;\
	filter:="(&(liferay.extender=spring.extender)(Version=1.0))"
Spring-Context: META-INF/spring/*.xml