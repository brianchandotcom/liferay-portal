Bundle-Version: 1.0.0
Import-Package:\
	!com.sun.jna.*,\
	\
	!javax.annotation.*,\
	\
	!jdk.internal.misc.*,\
	\
	*
-fixupmessages: Classes found in the wrong directory: ...;is:=ignore
-includeresource:\
	@byte-buddy-*.jar;lib:=true,\
	@byte-buddy-agent-*.jar;lib:=true