<?xml version="1.0"?>

<workflow-definition
	xmlns="urn:liferay.com:liferay-workflow_7.4.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="urn:liferay.com:liferay-workflow_7.4.0 http://www.liferay.com/dtd/liferay-workflow-definition_7_4_0.xsd"
>
	<name>Order Completion</name>
	<description>Complete the order after payment.</description>
	<version>1</version>
	<state>
		<name>StartNode</name>
		<metadata>
			<![CDATA[
				{
					"xy": [
						100,
						40
					]
				}
			]]>
		</metadata>
		<initial>true</initial>
		<transitions>
			<transition>
				<name>validation</name>
				<target>EndNode</target>
				<default>true</default>
			</transition>
		</transitions>
	</state>
	<state>
		<name>EndNode</name>
		<metadata>
			<![CDATA[
				{
					"terminal": true,
					"xy": [
						501,
						45
					]
				}
			]]>
		</metadata>
		<actions>
			<action>
				<name>Approve Commerce Order</name>
				<description>Approve Commerce Order</description>
				<script>
					<![CDATA[site.initializer.raylife.d2c.workflow.definitions.order.completion.action.executor.ApproveCommerceOrderActionExecutor]]>
				</script>
				<script-language>java</script-language>
				<priority>1</priority>
				<execution-type>onEntry</execution-type>
			</action>
			<action>
				<name>Approve Workflow Instance</name>
				<description>Approve Workflow Instance</description>
				<status>0</status>
				<priority>2</priority>
				<execution-type>onEntry</execution-type>
			</action>
		</actions>
	</state>
</workflow-definition>