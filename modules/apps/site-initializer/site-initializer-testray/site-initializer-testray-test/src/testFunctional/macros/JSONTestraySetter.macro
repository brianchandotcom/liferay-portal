definition {

	@summary = "Default summary"
	macro getBuildId(buildName = null) {
		var buildId = JSONTestrayAPI._getObjectId(
			object = "builds",
			objectName = ${buildName});

		return ${buildId};
	}

	@summary = "Default summary"
	macro getCaseId(caseName = null) {
		var caseId = JSONTestrayAPI._getObjectId(
			object = "cases",
			objectName = ${caseName});

		return ${caseId};
	}

	@summary = "Default summary"
	macro getCaseResultId(caseResultName = null) {
		var caseResultId = JSONTestrayAPI._getObjectId(
			object = "caseresults",
			objectName = ${caseResultName});

		return ${caseResultId};
	}

	@summary = "Default summary"
	macro getCaseTypeId(caseType = null) {
		var caseTypeId = JSONTestrayAPI._getObjectId(
			object = "casetypes",
			objectName = ${caseType});

		return ${caseTypeId};
	}

	@summary = "Default summary"
	macro getComponentId(componentName = null) {
		var componentId = JSONTestrayAPI._getObjectId(
			object = "components",
			objectName = ${componentName});

		return ${componentId};
	}

