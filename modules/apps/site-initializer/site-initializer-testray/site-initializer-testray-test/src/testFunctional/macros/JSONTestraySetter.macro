	macro getRunId(runName = null) {
		var runId = JSONTestrayAPI._getObjectId(
			object = "runs",
			objectName = ${runName});

		return ${runId};
	}

	@summary = "Default summary"
	macro getSubtaskId(subtaskName = null) {
		var subtaskId = JSONTestrayAPI._getObjectId(
