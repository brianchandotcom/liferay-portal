			object = "productversions",
			objectName = ${productVersion});

		return ${productVersionId};
	}

	@summary = "Default summary"
	macro getProjectId(projectName = null) {
		Variables.assertDefined(parameterList = ${projectName});

		var projectId = JSONTestrayAPI._getProjectId(projectName = ${projectName});

		return ${projectId};
	}

	@summary = "Default summary"
	macro getRequirementId(requirementName = null) {
		var requirementId = JSONTestrayAPI._getObjectId(
