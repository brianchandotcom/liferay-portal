definition {

	@summary = "Default summary"
	macro createRoutine(routineName = null) {
		Click(locator1 = "Button#PLUS");

		if (isSet(routineName)) {
			PortletEntry.inputName(name = ${routineName});
		}

		Button.clickSave();
	}

	@summary = "Default summary"
	macro editRoutine(newName = null) {
		if (isSet(newName)) {
			PortletEntry.inputName(name = ${newName});
		}

		Button.clickSave();
	}

}