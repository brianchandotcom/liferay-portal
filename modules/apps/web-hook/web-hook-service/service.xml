<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.4.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_4_0.dtd">

<service-builder auto-import-default-references="false" auto-namespace-tables="false" dependency-injector="ds" mvcc-enabled="true" package-path="com.liferay.web.hook">
	<namespace>WebHook</namespace>
	<entity local-service="true" name="WebHookEntry" remote-service="false" trash-enabled="false" uuid="true">

		<!-- PK fields -->

		<column container-model="true" name="webHookEntryId" primary="true" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" uad-anonymize-field-name="fullName" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />

		<!-- Other fields -->

		<column localized="true" name="name" type="String" />
		<column name="destination" type="String" />
		<column name="url" type="String" uad-nonanonymizable="true" />

		<!-- Order -->

		<order by="asc">
			<order-column case-sensitive="false" name="name" />
		</order>

		<!-- Finder methods -->

		<finder name="C_D_U" return-type="WebHookEntry" unique="true">
			<finder-column name="companyId" />
			<finder-column name="destination" />
			<finder-column name="url" />
		</finder>

		<!-- References -->

		<reference entity="User" package-path="com.liferay.portal" />
	</entity>
	<exceptions>
		<exception>DuplicateWebHookEntry</exception>
	</exceptions>
</service-builder>