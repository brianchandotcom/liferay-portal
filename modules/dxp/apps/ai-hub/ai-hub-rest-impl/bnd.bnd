Bundle-Name: Liferay AI Hub REST Implementation
Bundle-SymbolicName: com.liferay.ai.hub.rest.impl
Bundle-Version: 1.0.6
Import-Package:\
	!com.aayushatharva.brotli4j.*,\
	\
	!com.fasterxml.jackson.datatype.*,\
	\
	!com.github.luben.zstd.*,\
	\
	!com.google.api.*,\
	!com.google.appengine.*,\
	!com.google.apphosting.*,\
	!com.google.auth.*,\
	!com.google.cloud.*,\
	!com.google.common.*,\
	!com.google.errorprone.annotations.*,\
	!com.google.j2objc.annotations.*,\
	!com.google.protobuf.*,\
	\
	!com.jcraft.jzlib.*,\
	\
	!com.ning.compress.*,\
	\
	!com.oracle.svm.*,\
	\
	!com.sun.jna.*,\
	\
	!io.grpc.*,\
	\
	!io.netty.internal.tcnative.*,\
	\
	!io.opencensus.*,\
	\
	!io.opentelemetry.*,\
	\
	!io.perfmark.*,\
	\
	!javax.annotation,\
	!javax.annotation.meta,\
	!javax.annotation.meta.*,\
	\
	!lzma.sdk.*,\
	\
	!net.jpountz.*,\
	\
	!org.apache.avalon.framework.logger.*,\
	!org.apache.log.*,\
	!org.apache.log4j.*,\
	\
	!org.bouncycastle.*,\
	\
	!org.brotli.dec.*,\
	\
	!org.checkerframework.*,\
	\
	!org.conscrypt.*,\
	\
	!org.eclipse.jetty.alpn.*,\
	!org.eclipse.jetty.npn.*,\
	\
	!org.graalvm.*,\
	\
	!org.jboss.marshalling.*,\
	\
	!org.openjsse.javax.net.ssl.*,\
	!org.openjsse.net.ssl.*,\
	\
	!org.slf4j.impl.*,\
	\
	!org.tukaani.xz.*,\
	\
	!reactor.blockhound.*,\
	\
	!sun.security.x509,\
	\
	android.*;resolution:=optional,\
	\
	*
-dsannotations-options: inherit
-fixupmessages:\
	"Classes found in the wrong directory: ...";is:=ignore,\
	"Exporting an empty package 'io.grpc.netty.shaded.*'";is:=warning