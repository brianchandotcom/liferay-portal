Bundle-Name: Liferay AI Hub Site Initializer
Bundle-SymbolicName: com.liferay.ai.hub.site.initializer
Bundle-Version: 1.0.4
Import-Package:\
	!org.bouncycastle.jsse.*,\
	\
	!org.conscrypt.*,\
	\
	!org.openjsse.javax.net.ssl.*,\
	!org.openjsse.net.ssl.*,\
	\
	android.*;resolution:=optional,\
	\
	*
Web-ContextPath: /ai-hub-site-initializer
-dsannotations-options: inherit
-fixupmessages: Classes found in the wrong directory: ...;is:=ignore