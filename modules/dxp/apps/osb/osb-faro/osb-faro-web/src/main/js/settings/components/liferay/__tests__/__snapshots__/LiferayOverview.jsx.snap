// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`LiferayOverview should render 1`] = `
<div>
  <div
    class="sheet liferay-data-source-root"
  >
    <div
      class="sheet-header mb-1"
    >
      <h2
        class="sheet-title"
      >
        Data Source Information
      </h2>
    </div>
    <div
      class="sheet-body"
    >
      <div
        class="sheet-section"
      >
        <div
          class="input-with-edit-toggle-root definition-item-root"
        >
          <div
            class="d-inline-flex"
          >
            <span
              class="text-8 font-weight-bold"
            >
              Liferay1
            </span>
            <button
              aria-label="Edit"
              class="button-root btn btn-outline-borderless btn-sm btn-outline-secondary"
              data-testid="edit"
              type="button"
            >
              <svg
                class="lexicon-icon lexicon-icon-pencil icon-root"
                role="presentation"
              >
                <use
                  href="#pencil"
                />
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div
        class="sheet-section"
      >
        <form
          class="form-root dxp-instance-id-root"
        >
          <div
            class="form-group"
          >
            <div
              class="form-group-item d-flex mb-3"
            >
              <div
                class=""
                style="flex-basis: 100%; flex-grow: 0;"
              >
                <label
                  class="form-control-label label-root"
                  for="dxpInstanceId"
                >
                  <span
                    class="content-container"
                  >
                    DXP Instance ID
                  </span>
                </label>
                <input
                  class="input-root form-control"
                  id="dxpInstanceId"
                  name="dxpInstanceId"
                  readonly=""
                  type="text"
                  value="1"
                />
              </div>
            </div>
            <div
              class="form-group-item"
            >
              <button
                class="button-root btn btn-secondary"
                data-testid="disconnect-button"
                type="button"
              >
                Disconnect
              </button>
            </div>
          </div>
        </form>
      </div>
      <div
        class="sheet-section has-last-child-margin"
      >
        <div
          class="mb-1 d-flex align-items-center"
        >
          <div
            class="h4 mb-0 mr-2"
          >
            Synced Sites
          </div>
          <div
            class="label label-root label-secondary label-lg label-uppercase"
          >
            <span
              class="label-item"
            >
              Unconfigured
            </span>
          </div>
        </div>
        <p
          class="description-secondary"
        >
          To configure sites, go to the Analytics Cloud configuration in your DXP Instance Settings, then select the sites you would like to start tracking.
        </p>
      </div>
      <div
        class="sheet-section has-last-child-margin"
      >
        <div
          class="mb-1 d-flex align-items-center"
        >
          <div
            class="h4 mb-0 mr-2"
          >
            Synced Contacts
          </div>
          <div
            class="label label-root label-secondary label-lg label-uppercase"
          >
            <span
              class="label-item"
            >
              Unconfigured
            </span>
          </div>
        </div>
        <p
          class="description-secondary"
        >
          To configure contacts, go to the Analytics Cloud configuration in your DXP Instance Settings, then select which contacts you would like to sync.
        </p>
      </div>
    </div>
  </div>
</div>
`;
