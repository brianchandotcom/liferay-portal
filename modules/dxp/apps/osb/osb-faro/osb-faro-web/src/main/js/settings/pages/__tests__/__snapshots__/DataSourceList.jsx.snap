exports[`DataSourceList should render toast for multiple data sources with invalid credentials 1`] = `
<div
  class="embedded-alert-list-root"
>
  <div
    class="alert alert-warning"
    role="alert"
  >
    <span
      class="alert-indicator"
    >
      <svg
        class="lexicon-icon lexicon-icon-warning-full icon-root"
        role="presentation"
      >
        <use
          href="#warning-full"
        />
      </svg>
    </span>
    <strong
      class="lead"
    >
      Warning:
    </strong>
    Some of your authorization tokens have expired. Please reauthorize the account credentials on these data sources to prevent syncing interruptions.
  </div>
</div>
`;

