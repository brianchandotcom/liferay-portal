definition {

	@summary = "Default summary"
	macro assertActiveBreadcrumb(activeItem = null) {
		AssertElementPresent(
			locator1 = "Breadcrumb#BREADCRUMB_ENTRY_ACTIVE_ENTRY",
			value1 = ${activeItem});
	}

	@summary = "Default summary"
	macro gotoClaim(claimId = null) {
		if (!(isSet(siteName))) {
			var siteName = "Partner Portal";
		}

		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});

		if (!(isSet(baseURL))) {
			var baseURL = PropsUtil.get("portal.url");
		}

		Open(value1 = "${baseURL}/web/${siteNameURL}/l/${claimId}");

		echo("${baseURL}/web/${siteNameURL}/l/${claimId}");

		WaitForVisible(
			key_title = "MDF Claim",
			locator1 = "Header#H1_TITLE");
	}

	@summary = "Default summary"
	macro gotoMDF(requestId = null) {
		if (!(isSet(siteName))) {
			var siteName = "Partner Portal";
		}

		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});

		if (!(isSet(baseURL))) {
			var baseURL = PropsUtil.get("portal.url");
		}

		Open(value1 = "${baseURL}/web/${siteNameURL}/l/${requestId}");

		echo("${baseURL}/web/${siteNameURL}/l/${requestId}");

		WaitForVisible(
			key_title = "Campaign MDF Request",
			locator1 = "Header#H1_TITLE");
	}

	@summary = "Default summary"
	macro goToNavItem(navItem = null) {
		Click(
			key_navItem = ${navItem},
			locator1 = "PRMNavigation#NAV_LINK");

		WaitForPageLoad();
	}

	@summary = "Default summary"
	macro openSitePage(pageName = null) {
		if (!(isSet(siteName))) {
			var siteName = "Partner Portal";
		}

		var siteNameURL = StringUtil.replace(${siteName}, " ", "-");

		var siteNameURL = StringUtil.lowerCase(${siteNameURL});
		var baseURL = ${baseURL};

		if (!(isSet(baseURL))) {
			var baseURL = PropsUtil.get("portal.url");
		}

		var pageNameURL = StringUtil.replace(${pageName}, " ", "-");

		var pageNameURL = StringUtil.lowerCase(${pageNameURL});

		if ((${pageName} == "MDF Requests") || (${pageName} == "MDF Claims")) {
			Open(value1 = "${baseURL}/web/${siteNameURL}/marketing/${pageNameURL}");
		}
		else if (${pageName} == "Deal Registrations") {
			Open(locator1 = "${baseURL}/web/${siteNameURL}/sales/${pageNameURL}");
		}
		else {
			Open(value1 = "${baseURL}/web/${siteNameURL}/${pageNameURL}");
		}
	}

}