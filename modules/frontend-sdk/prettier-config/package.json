{
	"author": "Liferay Frontend Infrastructure Team <pt-frontend-infrastructure@liferay.com>",
	"dependencies": {
		"@liferay/prettier-plugin": "^1.1.3"
	},
	"description": "Prettier config for the Liferay JavaScript Style",
	"exports": {
		".": {
			"import": "./index.js",
			"require": "./index.cjs"
		}
	},
	"license": "MIT",
	"main": "index.js",
	"name": "@liferay/prettier-config",
	"repository": {
		"directory": "projects/prettier-config",
		"type": "git",
		"url": "https://github.com/liferay/liferay-frontend-projects.git"
	},
	"scripts": {
		"build": "true",
		"format": "node-scripts format",
		"format:check": "node-scripts format --check",
		"postversion": "npx liferay-js-publish",
		"preversion": "yarn run format:check"
	},
	"type": "module",
	"version": "1.1.1"
}
