<?xml version="1.0"?>
<!DOCTYPE project>

<project>
	<import file="../../../tools/sdk/build-common-osgi-plugin.xml" />

	<!--<property name="auto.deploy.dir" value="${liferay.home}/osgi/modules" />-->

	<target name="start-poshi-runner">
		<if>
			<isset property="test.case.name" />
			<then>
				<echo file="src/poshi-runner-ext.properties">
					test.case.name=${test.case.name}
				</echo>
			</then>
			<else>
				<fail message="Please give me the test case name!" />
			</else>
		</if>

		<antcall target="compile" />

		<mkdir dir="test-results" />

		<junit printsummary="on" showoutput="true">
			<classpath refid="plugin.classpath" />
			<formatter type="xml" />
			<test name="com.liferay.poshi.runner.PoshiRunner" todir="test-results" />
		</junit>
	</target>
</project>