Bundle-SymbolicName: jakarta.json.bind
Bundle-Version: 1.0.2.LIFERAY-PATCHED-1
Export-Package: javax.json.bind.*
Provide-Capability:\
	osgi.contract;\
		osgi.contract=JavaJSONB;\
		uses:="javax.json.bind,javax.json.bind.serializer,javax.json.bind.config,javax.json.bind.annotation,javax.json.bind.adapter,javax.json.bind.spi";\
		version:Version=1.0
Require-Capability:\
	osgi.contract;\
		filter:="(&(osgi.contract=JavaJSONP)(version=1.1.0))";\
		osgi.contract=JavaJSONP,\
	osgi.extender;\
		filter:="(osgi.extender=osgi.serviceloader.processor)",\
	osgi.serviceloader;\
		cardinality:=multiple;\
		filter:="(osgi.serviceloader=javax.json.bind.spi.JsonbProvider)"