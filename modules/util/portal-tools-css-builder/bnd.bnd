Bundle-Name: Liferay CSS Builder
Bundle-SymbolicName: com.liferay.portal.tools.css.builder
Bundle-Version: 1.0.0
Export-Package: com.liferay.portal.tools.css.builder
Include-Resource:\
	classes,\
	@lib/ant.jar,\
	@lib/com.liferay.rtl.css.jar,\
	@lib/com.liferay.sass.compiler.api.jar,\
	@lib/com.liferay.sass.compiler.jni.jar,\
	@lib/com.liferay.sass.compiler.ruby.jar,\
	@../../../portal-service/portal-service.jar!/com/liferay/portal/model/ModelHintsConstants.class,\
	@../../../portal-service/portal-service.jar!/com/liferay/portal/kernel/util/StringUtil.class,\
	@../../../portal-service/portal-service.jar!/com/liferay/portal/kernel/io/unsync/UnsyncStringReader.class,\
	@../../../portal-service/portal-service.jar!/com/liferay/portal/kernel/log/LogFactoryUtil
Main-Class: com.liferay.portal.tools.css.builder.CSSBuilder