Bundle-Name: Liferay Portal Tools REST Builder
Bundle-SymbolicName: com.liferay.portal.tools.rest.builder
Bundle-Version: 1.0.11
Import-Package:\
	!org.apache.maven.plugin.*,\
	!org.apache.tools.ant.*,\
	\
	*
Main-Class: com.liferay.portal.tools.rest.builder.RESTBuilder
-includeresource:\
	@com.liferay.portal.impl-[0-9]*.jar!/com/liferay/portal/tools/ArgumentsMap.class,\
	@com.liferay.portal.impl-[0-9]*.jar!/com/liferay/portal/tools/ArgumentsUtil.class,\
