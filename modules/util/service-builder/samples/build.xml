<?xml version="1.0"?>
<!DOCTYPE project>

<project name="sample-build-service">

	<path id="sample.sb.classpath">

		<!--
		../lib/jalopy.jar
		../lib/org.freemarker.jar
		../lib/log4j.jar
		../lib/jaxen.jar
		../lib/qdox.jar
		../lib/dom4j.jar
		../lib/commons-io.jar
		 -->

		<fileset dir="../lib" includes="*.jar" />
		<fileset dir="../../../../tools/sdk/dist" includes="com.liferay.tools.servicebuilder-*.jar" />
	</path>

	<taskdef classpathref="sample.sb.classpath" resource="com/liferay/portal/tools/servicebuilder/ant/taskdefs.properties" />

	<target name="build-service">
		<mkdir dir="../tmp/sql" />

		<service-builder
			apiDir="../tmp/api"
			hbmFileName="../tmp/src/META-INF/portal-hbm.xml"
			implDir="../tmp/src"
			inputFileName="service.xml"
			modelHintsFileName="../tmp/src/META-INF/portal-model-hints.xml"
			resourcesDir="../tmp/src"
			springFileName="../tmp/src/META-INF/portal-spring.xml"
			sqlDir="../tmp/sql"
			testDir="../tmp/test/integration"
		/>
	</target>
</project>