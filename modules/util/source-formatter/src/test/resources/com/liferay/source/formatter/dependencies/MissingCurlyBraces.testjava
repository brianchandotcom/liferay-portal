package com.liferay.source.formatter.dependencies;

/**
 * @author Hugo Huijser
 */
public class MissingCurlyBraces {

	public void method() {
		int count = 0;

		for (int i = 0; i < 10; i++)
			count++;

		String s1 = "hello";

		if (s1 != null)
			s1 = "world";

		while (count < 10)
			count++;
	}

}