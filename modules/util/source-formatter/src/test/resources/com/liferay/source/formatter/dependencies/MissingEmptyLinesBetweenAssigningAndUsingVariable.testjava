package com.liferay.source.formatter.dependencies;

/**
 * @author Alan Huang
 */
public class MissingEmptyLinesBetweenAssigningAndUsingVariable {

	public void method(String content, int beginPos) {
		int jsonBeginPos = StringUtil.lastIndexOfAny(
			content, new String[] {"<![CDATA["}, beginPos);
		jsonBeginPos = StringUtil.indexOfAny(
			content, new char[] {'{'}, jsonBeginPos);

		System.out.println(jsonBeginPos);
	}

}