package com.liferay.source.formatter.dependencies;

import com.liferay.petra.string.StringBundler;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;

/**
 * @author Alan Huang
 */
public class MissingParameterizedSQLStatement {

	protected ResultSet method(
			Connection connection, String portletId, int ownerType)
		throws Exception {

		try (PreparedStatement preparedStatement = connection.prepareStatement(
				StringBundler.concat(
					"select companyId, preferences from PortletPreferences ",
					"where portletId = '", portletId, "' AND ownerType = ",
					ownerType))) {

			return preparedStatement.executeQuery();
		}
	}

}