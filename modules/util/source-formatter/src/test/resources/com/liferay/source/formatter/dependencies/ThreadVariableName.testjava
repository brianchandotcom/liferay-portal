package com.liferay.source.formatter.dependencies;

/**
 * @author Alan Huang
 */
public class ThreadVariableName {

	public Thread method1(Runnable runnable) {
		Thread thread = new Thread(runnable, "LockCreateThread");

		thread.setDaemon(true);

		return thread;
	}

	public Thread method2(Runnable runnable) {
		Thread thread = new Thread(runnable, "");

		thread.setDaemon(true);

		return thread;
	}

}