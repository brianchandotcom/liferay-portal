package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.portal.kernel.util.HtmlParser;

import com.liferay.portal.kernel.search.Sort;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Nícolas Moura
 */
public class UpgradeCatchAllCheck {

	public void method() {
		_htmlParser.extractText(testEntry.getContent());

		if (true) {
			String contentVariableLineBreak = _htmlParser.extractText(
				testEntry.getContent());
		}
	}

	public void method(CommerceAddress commerceAddress) {
		Region region = commerceAddress.getCountry();

		region.getRegionCode();

		commerceAddress.getRegion().getRegionCode();

		commerceAddress.getRegion(
		).getRegionCode();
	}

	public void method(
		long companyId, long groupId, String title, int start, int end) {

		_assetVocabularyService.searchVocabularies(companyId, new long[]{groupId}, title, new int[]{}, start, end, new Sort());

		return _assetVocabularyLocalService.searchVocabularies(companyId, new long[]{groupId}, title, new int[]{}, start, end, new Sort());

		_assetVocabularyService.searchVocabularies(
			companyId, 551, "test", start, end);
	}

	@Reference
	private AssetVocabularyLocalService _assetVocabularyLocalService;

	@Reference
	private AssetVocabularyService _assetVocabularyService;


	@Reference
	private HtmlParser _htmlParser;

}