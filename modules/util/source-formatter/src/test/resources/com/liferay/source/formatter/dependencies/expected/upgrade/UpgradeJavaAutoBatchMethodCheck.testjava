package com.liferay.source.formatter.dependencies.upgrade;

/**
 * @author Regisson Aguiar
 */
public class UpgradeJavaAutoBatchMethodCheck {

	public void method(Connection connection) {
		AutoBatchPreparedStatementUtil.autoBatch(
			connection, "update Layout set typeSettings = ? where plid = ?");
	}

	public void method(PreparedStatement preparedStatement) {
		preparedStatement = connection.prepareStatement(
			"select serverproperty('collation')");

		AutoBatchPreparedStatementUtil.autoBatch(
			connection, "select serverproperty('collation')");
	}

}