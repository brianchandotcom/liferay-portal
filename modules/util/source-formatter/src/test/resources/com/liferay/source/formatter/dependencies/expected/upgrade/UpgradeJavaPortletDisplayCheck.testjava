package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.portal.configuration.module.configuration.ConfigurationProviderUtil;

public class UpgradeJavaPortletDisplayCheck {

	public void method1() {
		ThemeDisplay themeDisplay = (ThemeDisplay)portletRequest.getAttribute(
			WebKeys.THEME_DISPLAY);

		ConfigurationProviderUtil.getPortletInstanceConfiguration(
			AssetPublisherPortletInstanceConfiguration.class, themeDisplay);
	}

	public void method2() {
		PortletDisplay portletDisplay =
			commerceCartContentRequestHelper.getPortletDisplay();

		ConfigurationProviderUtil.getPortletInstanceConfiguration(
			AssetPublisherPortletInstanceConfiguration.class, portletDisplay.getThemeDisplay());
	}

}