package com.liferay.source.formatter.dependencies.upgrade;

import com.liferay.portal.kernel.language.LanguageUtil;

import java.util.HashMap;
import java.util.Locale;
import java.util.Map;

/**
 * @author Jessyca Ferreira
 */
@Component(
	immediate = true,
	property = "commerce.low.stock.activity.key=" + LPD_48704.KEY,
	service = CommerceLowStockActivity.class
)
public class LPD_48704 implements CommerceLowStockActivity {

	@Override
	public Map<Locale,String> getLabelMap() {
		Map<Locale, String> labelMap = new HashMap<>();

		for (Locale locale : LanguageUtil.getAvailableLocales()) {
			labelMap.put(locale, getLabel(locale));
		}

		return labelMap;
	}

}