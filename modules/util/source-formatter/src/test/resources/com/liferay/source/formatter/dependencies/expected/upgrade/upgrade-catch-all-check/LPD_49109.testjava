package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Regisson Aguiar
 */
public class LPD_49109 {

	public void method(
		long userId, long groupId, long repositoryId, long folderId,
		String sourceFileName, String mimeType, String title,
		String description, String changeLog, long fileEntryTypeId,
		Map<String, DDMFormValues> ddmFormValuesMap, File file,
		InputStream inputStream, long size, ServiceContext serviceContext) {

		DLFileEntryLocalServiceUtil.addFileEntry(123, groupId, repositoryId, folderId, sourceFileName, mimeType, title, description, changeLog, fileEntryTypeId, ddmFormValuesMap, file, inputStream, size, serviceContext);
		DLFileEntryLocalServiceUtil.addFileEntry(null, userId, groupId, repositoryId, folderId, sourceFileName, mimeType, title, null, description, changeLog, fileEntryTypeId, ddmFormValuesMap, file, inputStream, size, null, null, null, serviceContext);
		_dlFileEntryLocalService.addFileEntry(null, userId, groupId, repositoryId, folderId, sourceFileName, mimeType, title, null, description, changeLog, fileEntryTypeId, ddmFormValuesMap, file, inputStream, size, null, null, null, serviceContext);
	}

	public void method(
		long groupId, long repositoryId, long folderId, String sourceFileName,
		String mimeType, String title, String description, String changeLog,
		long fileEntryTypeId, Map<String, DDMFormValues> ddmFormValuesMap,
		File file, InputStream inputStream, long size,
		ServiceContext serviceContext) {

		DLFileEntryServiceUtil.addFileEntry(123, repositoryId, folderId, sourceFileName, mimeType, title, description, changeLog, fileEntryTypeId, ddmFormValuesMap, file, inputStream, size, serviceContext);
		DLFileEntryServiceUtil.addFileEntry(null, groupId, repositoryId, folderId, sourceFileName, mimeType, title, null, description, changeLog, fileEntryTypeId, ddmFormValuesMap, file, inputStream, size, null, null, null, serviceContext);
		_dlFileEntryService.addFileEntry(null, groupId, repositoryId, folderId, sourceFileName, mimeType, title, null, description, changeLog, fileEntryTypeId, ddmFormValuesMap, file, inputStream, size, null, null, null, serviceContext);
	}

	@Reference
	private DLFileEntryLocalService _dlFileEntryLocalService;

	@Reference
	private DLFileEntryService _dlFileEntryService;

}
