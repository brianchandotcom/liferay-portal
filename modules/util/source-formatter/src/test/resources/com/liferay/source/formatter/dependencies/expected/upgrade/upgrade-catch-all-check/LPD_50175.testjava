package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Micaelle Silva
 */
public class LPD_50175 {

	public void method(long companyId, String externalReferenceCode) {
		AccountEntryLocalServiceUtil.fetchByExternalReferenceCode(123, externalReferenceCode);
		AccountEntryLocalServiceUtil.fetchAccountEntryByExternalReferenceCode(externalReferenceCode, companyId);
		AccountEntryServiceUtil.fetchAccountEntryByExternalReferenceCode(externalReferenceCode, companyId);
		_accountEntryLocalService.fetchAccountEntryByExternalReferenceCode(externalReferenceCode, companyId);
		_accountEntryService.fetchAccountEntryByExternalReferenceCode(externalReferenceCode, companyId);
	}

	@Reference
	private AccountEntryLocalService _accountEntryLocalService;

	@Reference
	private AccountEntryService _accountEntryService;

}