package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

/**
 * @author Mateus Xavier
 */
public class LPD_58438 {

	public void method(
		long groupId, String classExternalReferenceCode, long classNameId,
		long classPK, String containerKey, long containerType, long plid) {

		LayoutClassedModelUsageLocalServiceUtil.fetchLayoutClassedModelUsage(
			123, classPK, containerKey, containerType, plid);
		LayoutClassedModelUsageLocalServiceUtil.fetchLayoutClassedModelUsage(null, null, classNameId, classPK, containerKey, containerType, plid);
		_layoutClassedModelUsageLocalService.fetchLayoutClassedModelUsage(null, null, classNameId, classPK, containerKey, containerType, plid);
	}

	public void method(
		long groupId, String classExternalReferenceCode, long classNameId,
		long classPK, String containerKey, long containerType, long plid,
		ServiceContext serviceContext) {

		LayoutClassedModelUsageLocalServiceUtil.addLayoutClassedModelUsage(
			123, classNameId, classPK, containerKey, containerType, plid,
			serviceContext);
		LayoutClassedModelUsageLocalServiceUtil.addLayoutClassedModelUsage(groupId, null, classNameId, classPK, containerKey, containerType, plid, serviceContext);
		_layoutClassedModelUsageLocalService.addLayoutClassedModelUsage(groupId, null, classNameId, classPK, containerKey, containerType, plid, serviceContext);
	}

	@Reference
	private LayoutClassedModelUsageLocalService
		_layoutClassedModelUsageLocalService;

}