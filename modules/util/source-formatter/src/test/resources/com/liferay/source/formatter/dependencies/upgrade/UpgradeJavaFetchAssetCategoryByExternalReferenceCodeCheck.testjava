package com.liferay.source.formatter.dependencies.upgrade;

import org.osgi.service.component.annotations.Reference;

public class UpgradeJavaFetchAssetCategoryByExternalReferenceCodeCheck {

	public void method(
		long companyId, String externalReferenceCode, long groupId) {

		_assetCategoryLocalService.fetchAssetCategoryByExternalReferenceCode(
			companyId, externalReferenceCode);

		AssetCategoryLocalServiceUtil.fetchAssetCategoryByExternalReferenceCode(
			companyId, externalReferenceCode);

		AssetCategoryLocalServiceUtil.fetchAssetCategoryByExternalReferenceCode(
			externalReferenceCode, groupId);
	}

	@Reference
	private AssetCategoryLocalService _assetCategoryLocalService;

}