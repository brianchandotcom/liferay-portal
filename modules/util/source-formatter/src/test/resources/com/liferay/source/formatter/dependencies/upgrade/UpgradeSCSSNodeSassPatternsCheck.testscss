$control-panel-spacing-mobile:    ( $spacer / 1.25 );

$line-height-h1: 50 / 44;
$line-height-h2: 5 / 4;
$line-height-h3: 5.4 / 45;
$line-height-h4: 58 / 4.4;
$line-height-h5: 5.8 / 4.4;

$multiplier: nth($value, 1) / $spacer;

@each {
	.bg-#{$color} {
	}
}

@mixin make($list: ".col-xs-#{$i}, .col-sm-#{$i}") {
}

(#{$prop}: var(--btn-#{$key}-#{$prefix}#{$prop}))

(#{$prop}: var(--btn-#{$key}-#{$prefix}--btn-))

.another-element {
	background-color: rgba(255 0 0 / 0.75);
}

.col-#{$class}-push-#{$index} {
}

.col-#{$class}-push-0 {
}

.my-div {
	background-color: hsl(0, 100%, 50% / 0.5);
	color: hsla(240 100% 50% / 0.5);
}

.test-class {
	color: rgb(0 0 0 / 40%);
}