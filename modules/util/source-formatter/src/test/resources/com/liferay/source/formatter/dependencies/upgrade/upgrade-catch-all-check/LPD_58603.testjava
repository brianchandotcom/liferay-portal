/**
 * @author Jessyca Ferreira
 */
public class LPD_58603 {

	public void method(
		long userId, long groupId, long originalFragmentEntryLinkId,
		long fragmentEntryId, long segmentsExperienceId, long plid, String css,
		String htmlUtil, String js, String configuration, String editableValues,
		String namespace, int position, String rendererKey, int type,
		ServiceContext serviceContext) {

		FragmentEntryLinkLocalServiceUtil.addFragmentEntryLink(
			123, groupId, originalFragmentEntryLinkId, fragmentEntryId,
			segmentsExperienceId, plid, css, htmlUtil, js, configuration,
			editableValues, namespace, position, rendererKey, type,
			serviceContext)
		FragmentEntryLinkLocalServiceUtil.addFragmentEntryLink(
			userId, groupId, originalFragmentEntryLinkId, fragmentEntryId,
			segmentsExperienceId, plid, css, htmlUtil, js, configuration,
			editableValues, namespace, position, rendererKey, type,
			serviceContext);
		_fragmentEntryLinkLocalService.addFragmentEntryLink(
			userId, groupId, originalFragmentEntryLinkId, fragmentEntryId,
			segmentsExperienceId, plid, css, htmlUtil, js, configuration,
			editableValues, namespace, position, rendererKey, type,
			serviceContext);
	}

	public void method(
		long groupId, long originalFragmentEntryLinkId, long fragmentEntryId,
		long segmentsExperienceId, long plid, String css, String htmlUtil,
		String js, String configuration, String editableValues,
		String namespace, int position, String rendererKey, int type,
		ServiceContext serviceContext) {

		FragmentEntryLinkServiceUtil.addFragmentEntryLink(
			123, originalFragmentEntryLinkId, fragmentEntryId,
			segmentsExperienceId, plid, css, htmlUtil, js, configuration,
			editableValues, namespace, position, rendererKey, type,
			serviceContext)
		FragmentEntryLinkServiceUtil.addFragmentEntryLink(
			groupId, originalFragmentEntryLinkId, fragmentEntryId,
			segmentsExperienceId, plid, css, htmlUtil, js, configuration,
			editableValues, namespace, position, rendererKey, type,
			serviceContext);
		_fragmentEntryLinkService.addFragmentEntryLink(
			groupId, originalFragmentEntryLinkId, fragmentEntryId,
			segmentsExperienceId, plid, css, htmlUtil, js, configuration,
			editableValues, namespace, position, rendererKey, type,
			serviceContext);
	}

	@Reference
	private FragmentEntryLinkLocalService _fragmentEntryLinkLocalService;

	@Reference
	private FragmentEntryLinkService _fragmentEntryLinkService;

}