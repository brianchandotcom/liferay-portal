<?xml version="1.0"?>

<beans
	default-destroy-method="destroy"
	default-init-method="afterPropertiesSet"
	xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd"
>
	<bean id="ldapToPortalConverter" class="com.liferay.portal.security.ldap.DefaultLDAPToPortalConverter" />
	<bean id="portalToLDAPConverter" class="com.liferay.portal.security.ldap.DefaultPortalToLDAPConverter" />
	<bean id="com.liferay.portal.security.ldap.LDAPPortalUserExporterImpl" class="com.liferay.portal.security.ldap.LDAPPortalUserExporterImpl">
		<property name="portalToLDAPConverter" ref="portalToLDAPConverter" />
	</bean>
	<bean id="com.liferay.portal.security.PortalUserExporterUtil" class="com.liferay.portal.security.PortalUserExporterUtil">
		<property name="portalUserExporter">
			<bean class="com.liferay.portal.security.ldap.LDAPPortalUserExporterImpl">
				<property name="portalToLDAPConverter" ref="portalToLDAPConverter" />
			</bean>
		</property>
	</bean>
	<bean id="com.liferay.portal.security.PortalUserImporterUtil" class="com.liferay.portal.security.PortalUserImporterUtil">
		<property name="portalUserImporter" ref="com.liferay.portal.security.ldap.LDAPPortalUserExporterImpl" />
	</bean>
	<bean id="com.liferay.portal.security.ldap.PortalLDAPUserImporterUtil" class="com.liferay.portal.security.ldap.PortalLDAPUserImporterUtil">
		<property name="portalLDAPUserImporter" ref="com.liferay.portal.security.ldap.LDAPPortalUserExporterImpl" />
	</bean>
</beans>