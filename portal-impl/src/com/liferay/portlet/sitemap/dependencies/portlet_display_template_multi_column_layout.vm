#if (!$entries.isEmpty())
	#set ($layoutTag = $taglibLiferay.getLayoutTag())
	#silently($layoutTag.doStartTag())

	#foreach ($entry in $entries)
		#set ($columnTag = $taglibLiferay.getColumnTag())
		$columnTag.setColumnWidth(25)
		#silently($columnTag.doStartTag())

		#set ($layoutURL = $portalUtil.getLayoutURL($entry, $themeDisplay))
		<div class="results-header">
			<h3>
				<a href="$layoutURL">$entry.getName($locale)</a>
			</h3>
		</div>

		#set ($pages = $entry.getChildren())

		#page_tree($pages)

		#silently($columnTag.doEndTag())
	#end
	#silently($layoutTag.doEndTag())
#end

#macro (page_tree $pages)
	#if (!$pages.isEmpty())
		<ul class="child-pages">
			#foreach ($page in $pages)
				#set ($pageLayoutURL = $portalUtil.getLayoutURL($page, $themeDisplay))
				<li>
					<a href="$pageLayoutURL">$page.getName($locale)</a>

					#set ($childPages = $page.getChildren())
					#page_tree($childPages)
				</li>
			#end
		</ul>
	#end
#end