	<mysql>
		<device-name></device-name>
		<family>mysql</family>
		<driver>com.mysql.jdbc.Driver</driver>
		<schema>lportal</schema>
		<url><![CDATA[jdbc:mysql://${db.mysql.host}/${db.mysql.schema}?useUnicode=true&characterEncoding=UTF-8&useFastDateParsing=false]]></url>
		<vm-vmdk-suffix></vm-vmdk-suffix>
		<arg>
			<copy-remote-file></copy-remote-file>
			<create-remote-schema></create-remote-schema>
			<token>
				<drop-schema>drop database if exists lportal;</drop-schema>
				<create-schema>create database lportal character set utf8;</create-schema>
				<create-schema-secondary></create-schema-secondary>
				<use-schema>use lportal;</use-schema>
			</token>
			<value>
				<drop-schema>drop database if exists ${db.schema};</drop-schema>
				<create-schema>create database ${db.schema} character set utf8;</create-schema>
				<create-schema-collate>create database ${db.schema} character set utf8 collate utf8_bin;</create-schema-collate>
				<create-schema-secondary></create-schema-secondary>
				<use-schema>use ${db.schema};</use-schema>
			</value>
		</arg>
	</mysql>

