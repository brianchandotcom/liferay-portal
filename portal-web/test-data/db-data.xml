	<sybase>
		<device-name>lportal</device-name>
		<family>sybase</family>
		<driver>net.sourceforge.jtds.jdbc.Driver</driver>
		<schema>lportal</schema>
		<url>jdbc:jtds:sybase://${db.sybase.host}:5000/${db.sybase.schema}</url>
		<vm-vmdk-suffix>sybase-15.0.2</vm-vmdk-suffix>
		<arg>
			<copy-remote-file>-pw ${vm.password} ${sql.file} ${vm.username}@${db.host}:\${tstamp.value}</copy-remote-file>
			<create-remote-schema>-pw ${vm.password} ${vm.username}@${db.host} isql -U ${db.username} -P ${db.password} -i C:\${tstamp.value}\${sql.file}</create-remote-schema>
			<token>
				<drop-schema>use master</drop-schema>
				<create-schema>exec sp_dboption 'lportal', 'allow nulls by default' , true</create-schema>
				<create-schema-secondary>exec sp_dboption 'lportal', 'select into/bulkcopy/pllsort' , true</create-schema-secondary>
				<use-schema>use lportal</use-schema>
			</token>
			<value>
				<drop-schema><![CDATA[use master${line.separator}dump transaction master with no_log${line.separator}go${line.separator}if exists (select * from master.dbo.sysdatabases where name = &quot;${db.schema}&quot;)${line.separator}begin${line.separator}drop database ${db.schema}${line.separator}end${line.separator}go${line.separator}create database ${db.schema} on ${db.device.name} = &quot;250m&quot;${line.separator}go]]></drop-schema>
				<create-schema>exec sp_dboption '${db.schema}', 'allow nulls by default' , true</create-schema>
				<create-schema-collate></create-schema-collate>
				<create-schema-secondary>exec sp_dboption '${db.schema}', 'select into/bulkcopy/pllsort' , true</create-schema-secondary>
				<use-schema>use ${db.schema}${line.separator}go</use-schema>
			</value>
		</arg>
	</sybase>
