<?xml version="1.0" encoding="utf-8"?>

<db>
	<db2>
		<device-name></device-name>
		<family>db2</family>
		<driver>com.ibm.db2.jcc.DB2Driver</driver>
		<schema>lportal</schema>
		<url>jdbc:db2://${db.db2.host}:50000/${db.db2.schema}:deferPrepares=false;fullyMaterializeInputStreams=true;fullyMaterializeLobData=true;progresssiveLocators=2;progressiveStreaming=2;</url>
		<vm-vmdk-suffix>db2-9.7</vm-vmdk-suffix>
		<arg>
			<copy-remote-file>-pw ${vm.password} ${sql.file} ${vm.username}@${db.host}:\${tstamp.value}</copy-remote-file>
			<create-remote-schema>-pw ${vm.password} ${vm.username}@${db.host} cmd.exe /c db2cmd /c /w /i /t db2 -f C:\${tstamp.value}\${sql.file} -td;</create-remote-schema>
			<token>
				<drop-schema>drop database lportal;</drop-schema>
				<create-schema>create database lportal;</create-schema>
				<create-schema-secondary>create database lportal pagesize 8192;</create-schema-secondary>
				<use-schema>connect to lportal;</use-schema>
			</token>
			<value>
				<drop-schema>drop database ${schema};</drop-schema>
				<create-schema>create database ${db.schema} pagesize 8192;</create-schema>
				<create-schema-collate></create-schema-collate>
				<create-schema-secondary>create database ${db.schema} pagesize 8192;</create-schema-secondary>
				<use-schema>connect to ${db.schema} USER ${db.username} USING ${db.password};</use-schema>
			</value>
		</arg>
	</db2>

	<hsql>
		<device-name></device-name>
