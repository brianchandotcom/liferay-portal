		<schema></schema>
		<url>jdbc:hsqldb:${liferay.home}/data/hsql/lportal</url>
		<vm-vmdk-suffix></vm-vmdk-suffix>
		<arg>
			<copy-remote-file></copy-remote-file>
			<create-remote-schema></create-remote-schema>
			<token>
				<drop-schema></drop-schema>
				<create-schema></create-schema>
				<create-schema-secondary></create-schema-secondary>
				<use-schema></use-schema>
			</token>
			<value>
				<drop-schema></drop-schema>
				<create-schema></create-schema>
				<create-schema-collate></create-schema-collate>
				<create-schema-secondary></create-schema-secondary>
