<actions object="BaseLiferay">
	<actiondef command="assertChecked" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; is checked.">
		<conditional default="true">
			<function object="AssertChecked" command="assertChecked" />
		</conditional>
	</actiondef>

	<actiondef command="assertElementNotPresent" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; is NOT present.">
		<conditional default="true">
			<function object="AssertElementNotPresent" command="assertElementNotPresent" />
		</conditional>
	</actiondef>

	<actiondef command="assertElementPresent" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; is present.">
		<conditional default="true">
			<function object="AssertElementPresent" command="assertElementPresent" />
		</conditional>
	</actiondef>

	<actiondef command="assertNotChecked" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; is NOT checked.">
		<conditional default="true">
			<function object="AssertNotChecked" command="assertNotChecked" />
		</conditional>
	</actiondef>

	<actiondef command="assertTextEquals" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; has the text value &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt;.">
		<conditional default="true">
			<function object="AssertTextEquals" command="assertText" />
		</conditional>
	</actiondef>

	<actiondef command="assertTextNotEquals" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; DOES NOT have the text value &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt;.">
		<conditional default="true">
			<function object="AssertTextNotEquals" command="assertNotText" />
		</conditional>
	</actiondef>

	<actiondef command="assertTextNotPresent" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the value &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt; DOES NOT show up on the page.">
		<conditional default="true">
			<function object="AssertTextNotPresent" command="assertTextNotPresent" />
		</conditional>
	</actiondef>

	<actiondef command="assertTextPresent" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, assert that the value &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt; shows up on the page.">
		<conditional default="true">
			<function object="AssertTextPresent" command="assertTextPresent" />
		</conditional>
	</actiondef>

	<actiondef command="check" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, checks off the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Check" command="clickAt" />
		</conditional>
	</actiondef>

	<actiondef command="click" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, click on the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; which should have a text value of &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Click" command="textClickAt" />
		</conditional>
	</actiondef>

	<actiondef command="close" description="While navigating the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, close selected window.">
		<conditional default="true">
			<function object="Close" command="close" />
		</conditional>
	</actiondef>

	<actiondef command="confirm" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, click okay on the confirmation window which should state the following: &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Confirm" command="confirm" />
		</conditional>
	</actiondef>

	<actiondef command="copy" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, copy the text found at the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Copy" command="textCopy" />
		</conditional>
	</actiondef>

	<actiondef command="dragAndDrop" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, drag and drop the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="DragAndDrop" command="dragAndDrop" />
		</conditional>
	</actiondef>

	<actiondef command="isElementPresent">
		<conditional default="true">
			<function object="IsElementPresent" command="isElementPresent" />
		</conditional>
	</actiondef>

	<actiondef command="isVisible">
		<conditional default="true">
			<function object="IsVisible" command="isVisible" />
		</conditional>
	</actiondef>

	<actiondef command="mouseOver" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, mouse over the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; which should have a text value of &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt;.">
		<conditional default="true">
			<function object="MouseOver" command="textMouseOver" />
		</conditional>
	</actiondef>

	<actiondef command="open" description="Open a window to &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; (&lt;strong&gt;${PATH.VALUE}&lt;/strong&gt;).">
		<conditional default="true">
			<function object="Open" command="open" />
		</conditional>
	</actiondef>

	<actiondef command="paste" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, paste the copied text to the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Paste" command="paste" />
		</conditional>
	</actiondef>

	<actiondef command="select" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, select &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt; from the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Select" command="select" />
		</conditional>
	</actiondef>

	<actiondef command="selectWindow" description="Select the window to &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt; (&lt;strong&gt;${PATH.VALUE}&lt;/strong&gt;).">
		<conditional default="true">
			<function object="SelectWindow" command="selectWindow" />
		</conditional>
	</actiondef>

	<actiondef command="type" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, type &lt;strong&gt;&quot;${PATH.VALUE}&quot;&lt;/strong&gt; into the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Type" command="type" />
		</conditional>
	</actiondef>

	<actiondef command="uncheck" description="In the &lt;strong&gt;${PATH.PAGE_NAME}&lt;/strong&gt;, unchecks the &lt;strong&gt;${PATH.DESCRIPTION}&lt;/strong&gt;.">
		<conditional default="true">
			<function object="Uncheck" command="clickAt" />
		</conditional>
	</actiondef>
</actions>