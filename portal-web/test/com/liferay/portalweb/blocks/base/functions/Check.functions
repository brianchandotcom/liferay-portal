<functions>
	<functiondef name="click">
		<selenium command="waitForVisible" />

		<if command="isNotChecked">
			<selenium command="click" />
		</if>

		<selenium command="assertChecked" />
	</functiondef>

	<functiondef name="clickAt" default="true">
		<selenium command="waitForVisible" />

		<if command="isNotChecked">
			<selenium command="clickAt" />
		</if>

		<selenium command="assertChecked" />
	</functiondef>

	<functiondef name="clickAtWCMouseOverArticle">
		<selenium command="waitForVisible" target="xpath=(//a[contains(@data-folder,'false')])[1]" />
		<selenium command="mouseOver" target="xpath=(//a[contains(@data-folder,'false')])[1]" />

		<function name="Check" command="clickAt" />
	</functiondef>
</functions>