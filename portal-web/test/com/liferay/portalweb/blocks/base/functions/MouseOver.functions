<functions>
	<functiondef name="mouseOver">
		<selenium command="waitForVisible" />
		<selenium command="mouseOver" />
	</functiondef>

	<functiondef name="partialTextMouseOver">
		<selenium command="waitForVisible" />
		<selenium command="waitForPartialText" />
		<selenium command="assertPartialText" />
		<selenium command="mouseOver" />
	</functiondef>

	<functiondef name="textMouseOver" default="true">
		<selenium command="waitForVisible" />
		<selenium command="waitForText" />
		<selenium command="assertText" />
		<selenium command="mouseOver" />
	</functiondef>

	<functiondef name="textMouseOverHomeClickDockbar">
		<selenium command="clickAt" target="//div[@id='dockbar']" value="" />
		<selenium command="waitForElementPresent" target="//script[contains(@src,'/aui/aui-button-item/aui-button-item-min.js')]" />
		<functions command="textMouseOver" />
	</functiondef>

	<functiondef name="valueMouseOver">
		<selenium command="waitForVisible" />
		<selenium command="waitForValue" />
		<selenium command="assertValue" />
		<selenium command="mouseOver" />
	</functiondef>
</functions>