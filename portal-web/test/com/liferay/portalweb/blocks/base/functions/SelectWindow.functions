<functions>
	<functiondef command="selectFrame">
		<selenium command="waitForVisible" />
		<selenium command="selectFrame" />
	</functiondef>

	<functiondef command="selectFrameTop">
		<selenium command="selectFrame" target="relative=top" />
	</functiondef>

	<functiondef command="selectWindow" default="true">
		<selenium command="pause" target="5000" />
		<selenium command="selectWindow" />
	</functiondef>

	<functiondef command="selectWindowTop" default="true">
		<selenium command="pause" target="5000" />
		<selenium command="selectWindow" target="null" />
	</functiondef>
</functions>