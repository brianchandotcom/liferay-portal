<functions>
	<functiondef command="sendKeys">
		<selenium command="waitForVisible" />
		<selenium command="sendKeys" />
	</functiondef>

	<functiondef command="sendKeysHomeAddApplication">
		<selenium command="waitForElementPresent" target="//script[contains(@src,'/aui/aui-live-search/aui-live-search-min.js')]" />
		<function object="Type" command="sendKeys" />
	</functiondef>

	<functiondef command="type" default="true">
		<selenium command="waitForVisible" />
		<selenium command="type" />
	</functiondef>

	<functiondef command="typeCPBlogsCKEditor">
		<selenium command="waitForElementPresent" target="//textarea[@id='_161_editor' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//span[.='Source']" />
		<selenium command="assertText" target="//span[.='Source']" value="Source" />
		<selenium command="click" target="//span[.='Source']" />

		<selenium command="waitForVisible" target="//a[@class='cke_button_source cke_on']" />
		<selenium command="waitForVisible" target="//td[@id='cke_contents__161_editor']/textarea" />
		<selenium command="type" target="//td[@id='cke_contents__161_editor']/textarea" />

		<selenium command="waitForVisible" target="//span[.='Source']" />
		<selenium command="assertText" target="//span[.='Source']" value="Source" />
		<selenium command="click" target="//span[.='Source']" />

		<selenium command="waitForElementPresent" target="//textarea[@id='_161_editor' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//td[@id='cke_contents__161_editor']/iframe" />
		<selenium command="selectFrame" target="//td[@id='cke_contents__161_editor']/iframe" />

		<selenium command="waitForText" target="//body" />
		<selenium command="assertText" target="//body" />
		<selenium command="selectFrame" target="relative=top" />
	</functiondef>

	<functiondef command="typeCPWebContentCKEditor">
		<selenium command="waitForElementPresent" target="//textarea[@id='_15__15_structure_el_TextAreaField_content' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//span[.='Source']" />
		<selenium command="assertText" target="//span[.='Source']" value="Source" />
		<selenium command="clickAt" target="//span[.='Source']" />

		<selenium command="waitForVisible" target="//a[@class='cke_button_source cke_on']" />
		<selenium command="waitForVisible" target="//td[@id='cke_contents__15__15_structure_el_TextAreaField_content']/textarea" />
		<selenium command="type" target="//td[@id='cke_contents__15__15_structure_el_TextAreaField_content']/textarea" />

		<selenium command="waitForVisible" target="//span[.='Source']" />
		<selenium command="assertText" target="//span[.='Source']" value="Source" />
		<selenium command="clickAt" target="//span[.='Source']" />

		<selenium command="waitForElementPresent" target="//textarea[@id='_15__15_structure_el_TextAreaField_content' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//td[@id='cke_contents__15__15_structure_el_TextAreaField_content']/iframe" />
		<selenium command="selectFrame" target="//td[@id='cke_contents__15__15_structure_el_TextAreaField_content']/iframe" />

		<selenium command="waitForText" target="//body" />
		<selenium command="assertText" target="//body" />
		<selenium command="selectFrame" target="relative=top" />
	</functiondef>

	<functiondef command="uploadCommonFile">
		<selenium command="waitForVisible" />
		<selenium command="uploadCommonFile" />
	</functiondef>
</functions>