<units>
	<unitdef name="assertPartialText">
		<selenium command="waitForVisible" />
		<selenium command="waitForPartialText" />
		<selenium command="assertPartialText" />
	</unitdef>

	<unitdef name="assertText">
		<selenium command="waitForVisible" />
		<selenium command="waitForText" />
		<selenium command="assertText" />
	</unitdef>

	<unitdef name="assertTextCKEditorWebContent">
		<selenium command="waitForElementPresent" target="//textarea[@id='_15__15_structure_el_TextAreaField_content' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//td[@id='cke_contents__15__15_structure_el_TextAreaField_content']/iframe" />
		<selenium command="selectFrame" target="//td[@id='cke_contents__15__15_structure_el_TextAreaField_content']/iframe" />

		<selenium command="waitForText" target="//body" />
		<selenium command="assertText" target="//body" />
		<selenium command="selectFrame" target="relative=top" />
	</unitdef>

	<unitdef name="assertValue">
		<selenium command="waitForVisible" />
		<selenium command="waitForValue" />
		<selenium command="assertValue" />
	</unitdef>
</units>