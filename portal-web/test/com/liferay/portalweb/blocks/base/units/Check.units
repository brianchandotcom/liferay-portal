<units>
	<unitdef name="click">
		<selenium command="waitForVisible" />

		<if command="isNotChecked">
			<selenium command="click" />
		</if>

		<selenium command="assertChecked" />
	</unitdef>

	<unitdef name="clickAt">
		<selenium command="waitForVisible" />

		<if command="isNotChecked">
			<selenium command="clickAt" />
		</if>

		<selenium command="assertChecked" />
	</unitdef>
</units>