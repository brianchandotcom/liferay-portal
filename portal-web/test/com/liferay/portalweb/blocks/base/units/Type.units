<units>
	<unitdef name="sendKeys">
		<selenium command="waitForVisible" />
		<selenium command="sendKeys" />
	</unitdef>

	<unitdef name="type">
		<selenium command="waitForVisible" />
		<selenium command="type" />
	</unitdef>

	<unitdef name="typeCKEditor">
		<selenium command="waitForElementPresent" target="//textarea[@id='_161_editor' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//span[.='Source']" />
		<selenium command="assertText" target="//span[.='Source']" value="Source" />
		<selenium command="click" target="//span[.='Source']" />

		<selenium command="waitForVisible" target="//a[@class='cke_button_source cke_on']" />
		<selenium command="waitForVisible" target="//td[@id='cke_contents__161_editor']/textarea" />
		<selenium command="type" target="//td[@id='cke_contents__161_editor']/textarea" />

		<selenium command="waitForVisible" target="//span[.='Source']" />
		<selenium command="assertText" target="//span[.='Source']" value="Source" />
		<selenium command="click" target="//span[.='Source']" />

		<selenium command="waitForElementPresent" target="//textarea[@id='_161_editor' and @style='display: none;']" />

		<selenium command="waitForVisible" target="//td[@id='cke_contents__161_editor']/iframe" />
		<selenium command="selectFrame" target="//td[@id='cke_contents__161_editor']/iframe" />

		<selenium command="waitForText" target="//body"  />
		<selenium command="assertText" target="//body"  />
		<selenium command="selectFrame" target="relative=top"  />
	</unitdef>
</units>