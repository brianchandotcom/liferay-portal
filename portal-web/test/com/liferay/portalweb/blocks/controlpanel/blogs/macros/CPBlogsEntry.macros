<macros>
	<macrodef
		name="addBlogsEntry"
		description="In the Control Panel Blogs Portlet, add a Blogs Entry with a title of ${title} and the content ${content}."
		params="title,content"
	>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="PORTLET_LINK_ADD" />

		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_TITLE" value="${title}" />
		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_CONTENT" value="${content}" />
		<action name="CPBlogsEntryAdd" command="click" path="CONTENT_LINK_SAVE" />
		<action name="CPBlogsEntryAdd" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS" />

		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE_1" value="${title}" />

		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="${title}" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="${content}" />
	</macrodef>

	<macrodef
		name="saveAsDraftBlogsEntry"
		description="In the Control Panel Blogs Portlet, Save a Blogs Entry as a Draft with a title of ${title} and the content ${content}."
		params="title,content"
	>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="PORTLET_LINK_ADD" />

		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_TITLE" value="${title}" />
		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_CONTENT" value="${content}" />
		<action name="CPBlogsEntryAdd" command="click" path="CONTENT_LINK_DRAFT" />
		<action name="CPBlogsEntryAdd" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS" />

		<action name="CPBlogsEntryEdit" command="assertTextEquals" path="CONTENT_TEXT_STATUS" value="Draft" />

		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE" value="${title}" />
		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_STATUS" value="Draft" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE" value="${title}" />

		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_DRAFT" value="Draft" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="${title}" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="${content}" />
	</macrodef>

	<macrodef
		name="tearDownBlogsEntry"
		description="In the Control Panel Blogs Portlet, Delete all the Blogs Entries."
	>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="portlet" value="Blogs" />
		</macro>

		<while name="CPBlogsPortlet" command="isElementPresent" path="BLOGS_ENTRY_LINK_CHECKBOX_1">
			<action name="CPBlogsPortlet" command="check" path="BLOGS_ENTRY_LINK_CHECKBOX_ALL" />
			<action name="CPBlogsPortlet" command="click" path="PORTLET_LINK_DELETE" />
		</while>
	</macrodef>
</macros>