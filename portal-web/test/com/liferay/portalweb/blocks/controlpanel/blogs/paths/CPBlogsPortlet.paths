<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<title>ControlPanelBlogsPortletPageObject</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">ControlPanelBlogsPortletPageObject</td></tr>
</thead><tbody>
<tr>
	<td>PAGE_NAME</td>
	<td></td>
	<td>Control Panel Blogs Portlet</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--BLOGS_ENTRY-->
<tr>
	<td>BLOGS_ENTRY_LINK_CHECKBOX_ALL</td>
	<td>//input[@name='_161_allRowIds']</td>
	<td>Select All Blog Entries Checkbox</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CHECKBOX</td>
	<td>//tr[contains(.,'Blogs Entry Title')]/td[1]/input[@name='_161_rowIds']</td>
	<td>Blog Entry Select Checkbox</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CHECKBOX_1</td>
	<td>//tr[3]/td[1]/input[@name='_161_rowIds']</td>
	<td>First Blog Entry Select Checkbox</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CHECKBOX_2</td>
	<td>//tr[4]/td[1]/input[@name='_161_rowIds']</td>
	<td>Second Blog Entry Select Checkbox</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CHECKBOX_3</td>
	<td>//tr[5]/td[1]/input[@name='_161_rowIds']</td>
	<td>Third Blog Entry Select Checkbox</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_TITLE</td>
	<td>//tr[contains(.,'Blogs Entry Title')]/td[2]/a</td>
	<td>Blogs Entry Title Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_TITLE_1</td>
	<td>//tr[3]/td[2]/a</td>
	<td>First Blogs Entry Title Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_TITLE_2</td>
	<td>//tr[4]/td[2]/a</td>
	<td>Second Blogs Entry Title Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_TITLE_3</td>
	<td>//tr[5]/td[2]/a</td>
	<td>Third Blogs Entry Title Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_AUTHOR</td>
	<td>//tr[contains(.,'Blogs Entry Title')]/td[3]/a</td>
	<td>Blog Entry Author Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_AUTHOR_1</td>
	<td>//tr[3]/td[3]/a</td>
	<td>First Blog Entry Author Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_AUTHOR_2</td>
	<td>//tr[4]/td[3]/a</td>
	<td>Second Blog Entry Author Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_AUTHOR_3</td>
	<td>//tr[5]/td[3]/a</td>
	<td>Third Blog Entry Author Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CREATED_DATE</td>
	<td>//tr[contains(.,'Blogs Entry Title')]/td[4]/a</td>
	<td>Blog Entry Created Date Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CREATED_DATE_1</td>
	<td>//tr[3]/td[4]/a</td>
	<td>First Blog Entry Created Date Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CREATED_DATE_2</td>
	<td>//tr[4]/td[4]/a</td>
	<td>Second Blog Entry Created Date Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CREATED_DATE_3</td>
	<td>//tr[5]/td[4]/a</td>
	<td>Third Blog Entry Created Date Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_STATUS</td>
	<td>//tr[contains(.,'Blogs Entry Title')]/td[5]/a</td>
	<td>Blog Entry Status Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_STATUS_1</td>
	<td>//tr[3]/td[5]/a</td>
	<td>First Blog Entry Status Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_STATUS_2</td>
	<td>//tr[4]/td[5]/a</td>
	<td>Second Blog Entry Status Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_STATUS_3</td>
	<td>//tr[5]/td[5]/a</td>
	<td>Third Blog Entry Status Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS</td>
	<td>//tr[contains(.,'Blogs Entry Title')]/td/span/ul/li/strong/a/span</td>
	<td>Actions Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_1</td>
	<td>//tr[3]/td/span/ul/li/strong/a/span</td>
	<td>Blog Entry 1 Actions Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_2</td>
	<td>//tr[4]/td/span/ul/li/strong/a/span</td>
	<td>Blog Entry 2 Actions Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_3</td>
	<td>//tr[5]/td/span/ul/li/strong/a/span</td>
	<td>Blog Entry 3 Actions Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_DELETE</td>
	<td>//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'Delete')]</td>
	<td>Actions Menu Delete Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_EDIT</td>
	<td>//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'Edit')]</td>
	<td>Actions Menu Edit Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_PERMISSION</td>
	<td>//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'Permissions')]</td>
	<td>Actions Menu Permissions Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_ACTIONS_VIEW</td>
	<td>//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'View')]</td>
	<td>Actions Menu View Link</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CONFIRM_DELETE_ACTIONS</td>
	<td></td>
	<td>&quot;Are you sure you want to delete this?&quot; Entry Delete Confirm Message</td>
</tr>
<tr>
	<td>BLOGS_ENTRY_LINK_CONFIRM_DELETE_LIST</td>
	<td></td>
	<td>&quot;Are you sure you want to delete the selected entries?&quot;&nbsp;&nbsp;Delete Multiple Entries Confirm Message</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--PORTLET-->
<tr>
	<td>PORTLET_LINK_BREADCRUMB_1</td>
	<td>//nav[@id='breadcrumbs']/ul/li[1]/span/a</td>
	<td>1st Breadcrumb</td>
</tr>
<tr>
	<td>PORTLET_LINK_BREADCRUMB_2</td>
	<td>//nav[@id='breadcrumbs']/ul/li[2]/span/a</td>
	<td>2nd Breadcrumb</td>
</tr>
<tr>
	<td>PORTLET_LINK_BREADCRUMB_3</td>
	<td>//nav[@id='breadcrumbs']/ul/li[3]/span/a</td>
	<td>3rd Breadcrumb</td>
</tr>
<tr>
	<td>PORTLET_TEXT_TITLE</td>
	<td>//span[@class='portlet-title-text']</td>
	<td>Portlet Title</td>
</tr>
<tr>
	<td>PORTLET_LINK_OPTIONS</td>
	<td>//span[@title='Options']/ul/li/strong/a</td>
	<td>Portlet Configuration Options Button</td>
</tr>
<tr>
	<td>PORTLET_LINK_OPTIONS_EXPORT_IMPORT</td>
	<td>//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'Export / Import')]</td>
	<td>Portlet Configuration Options Menu Export / Import Link</td>
</tr>
<tr>
	<td>PORTLET_TEXT_DESCRIPTION</td>
	<td>cpContextPanelTemplate</td>
	<td>Portlet Description</td>
</tr>
<tr>
	<td>PORTLET_LINK_ADD</td>
	<td>//span[contains(@class,'add-button')]/a</td>
	<td>Add New Blog Entry Button</td>
</tr>
<tr>
	<td>PORTLET_LINK_VIEW_ALL</td>
	<td>//span[contains(@class,'view-button')]/a</td>
	<td>Portlet View All Tab</td>
</tr>
<tr>
	<td>PORTLET_FIELD_SEARCH</td>
	<td>//input[@id='_161_keywords']</td>
	<td>Portlet Search Field</td>
</tr>
<tr>
	<td>PORTLET_LINK_SEARCH</td>
	<td>//input[@value='Search']</td>
	<td>Portlet Search Button</td>
</tr>
<tr>
	<td>PORTLET_LINK_DELETE</td>
	<td>//input[@value='Delete']</td>
	<td>Delete Button</td>
</tr>
<tr>
	<td>PORTLET_TEXT_RESULTS</td>
	<td>//div[@class='search-results']</td>
	<td>Portlet Search Results</td>
</tr>
<tr>
	<td>PORTLET_TEXT_INFO</td>
	<td>//div[@class='portlet-msg-info']</td>
	<td>&quot;No entries were found.&quot; Search Results Message</td>
</tr>
<tr>
	<td>PORTLET_TEXT_SUCCESS</td>
	<td>//div[@class='portlet-msg-success']</td>
	<td>&quot;Your request completed successfully.&quot; Success Message</td>
</tr>
</tbody></table>
</body>
</html>