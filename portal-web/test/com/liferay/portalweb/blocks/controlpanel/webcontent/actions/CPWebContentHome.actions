<actions>
	<actiondef name="check">
		<conditional elements="ENTRIES_ARTICLE_1_CHECKBOX">
			<selenium command="waitForVisible" target="xpath=(//a[contains(@data-folder,'false')])[1]" />
			<selenium command="mouseOver" target="xpath=(//a[contains(@data-folder,'false')])[1]" />

			<defaultcommand />
		</conditional>
	</actiondef>

	<actiondef name="click">
		<conditional elements="ADD_BASIC_WEB_CONTENT">
			<units command="clickAtAndWait" target="//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'Basic Web Content')]" />
		</conditional>

		<conditional elements="ADD_FOLDER">
			<units command="clickAtAndWait" target="//div[@class='lfr-component lfr-menu-list']/ul/li/a[contains(.,'Folder')]" />
		</conditional>

		<conditional elements="BUTTONS_ACTIONS">
			<selenium command="pause" target="1000" />
			<units command="clickAt" target="//a[@id='_15_tiym_menuButton']" />
		</conditional>

		<conditional elements="BUTTONS_ADD">
			<selenium command="pause" target="1000" />
			<units command="clickAt" target="//a[@id='_15_actionsButtonContainerButton']/span" />
		</conditional>

		<conditional elements="ENTRIES_FOLDER_1, ENTRIES_FOLDER_2, ENTRIES_FOLDER_3, ENTRIES_ARTICLE_1, ENTRIES_ARTICLE_2, ENTRIES_ARTICLE_3">
			<units command="clickAtAndWait" />
		</conditional>
	</actiondef>
</actions>