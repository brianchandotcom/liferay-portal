<actions object="CPBlogsAddEntry">
	<actiondef name="assertTextEquals">
		<conditional elements="CONTENT_TEXT_SAVE_STATUS">
			<function object="AssertTextEquals" command="assertPartialTextPause" />
		</conditional>
	</actiondef>

	<actiondef name="click">
		<conditional elements="CONTENT_LINK_DRAFT,CONTENT_LINK_PREVIEW,CONTENT_LINK_SAVE,CONTENT_LINK_CANCEL">
			<function object="Click" command="valueClickAtAndWaitCPBlogsCKEditor" />
		</conditional>
	</actiondef>

	<actiondef name="type">
		<conditional elements="CONTENT_FIELD_CONTENT">
			<function object="Type" command="typeCPBlogsCKEditor" />
		</conditional>
	</actiondef>
</actions>