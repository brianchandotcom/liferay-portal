<actions object="CPBlogsHome">
	<actiondef command="assertTextEquals">
		<conditional elements="BLOGS_ENTRY_TEXT_RATING_AVERAGE">
			<function object="AssertTextEquals" command="assertPartialText" />
		</conditional>
	</actiondef>

	<actiondef command="click">
		<conditional elements="PORTLET_LINK_DELETE">
			<function object="Click" command="valueClickAtAndWait" />
		</conditional>
	</actiondef>
</actions>