<actions>
	<actiondef name="assertTextEquals">
		<conditional elements="CONTENT_TEXT_STATUS,CONTENT_TEXT_SAVE_STATUS">
			<units command="assertPartialText" />
		</conditional>
	</actiondef>

	<actiondef name="click">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<selenium command="waitForElementPresent" target="//textarea[@id='_161_editor' and @style='display: none;']" />
			<units command="valueClickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef name="type">
		<conditional elements="CONTENT_FIELD_CONTENT">
			<units command="typeCKEditorBlogs" />
		</conditional>
	</actiondef>
</actions>