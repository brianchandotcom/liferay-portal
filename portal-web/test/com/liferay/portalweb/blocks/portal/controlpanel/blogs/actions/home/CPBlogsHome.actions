<actions>
	<actiondef name="assertTextEquals">
		<conditional elements="BLOGS_ENTRY_TEXT_RATING_AVERAGE">
			<function name="AssertTextEquals" command="assertPartialText" />
		</conditional>
	</actiondef>

	<actiondef name="click">
		<conditional elements="PORTLET_LINK_DELETE">
			<function name="Click" command="valueClickAtAndWait" />
		</conditional>
	</actiondef>
</actions>