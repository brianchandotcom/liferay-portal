<actions>
	<actiondef name="click">
		<conditional elements="SIDEBAR_PUBLISH">
			<functions command="clickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef name="type">
		<conditional elements="ARTICLE_CONTENT">
			<functions command="typeCKEditorWebContent" />
		</conditional>
	</actiondef>
</actions>