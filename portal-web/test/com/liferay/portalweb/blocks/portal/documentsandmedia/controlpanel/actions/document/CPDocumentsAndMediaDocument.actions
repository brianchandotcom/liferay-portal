<actions object="CPDocumentsAndMediaDocument">
	<actiondef name="assertTextEquals">
		<conditional elements="COMMENT_MESSAGE_INFO,DOCUMENT_LOCK_MESSAGE">
			<function object="AssertTextEquals" command="assertPartialText" />
		</conditional>
	</actiondef>

	<actiondef name="click">
		<conditional elements="COMMENT_BUTTON_CANCEL,COMMENT_BUTTON_REPLY">
			<function object="Click" command="valueClickAt" />
		</conditional>
	</actiondef>
</actions>