<actions object="CPDocumentsAndMediaAddDocumentType">
	<actiondef name="click">
		<conditional elements="BUTTON_CANCEL,BUTTON_SAVE">
			<function name="Click" command="valueClickAt" />
		</conditional>
	</actiondef>

	<actiondef name="selectWindow">
		<conditional elements="TOP">
			<function name="SelectWindow" command="selectFrameTop" />
		</conditional>
	</actiondef>
</actions>