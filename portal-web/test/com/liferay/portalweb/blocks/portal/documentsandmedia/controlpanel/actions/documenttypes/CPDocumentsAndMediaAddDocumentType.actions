<actions object="CPDocumentsAndMediaAddDocumentType">
	<actiondef command="click">
		<conditional elements="BUTTON_CANCEL,BUTTON_SAVE">
			<function object="Click" command="valueClickAt" />
		</conditional>
	</actiondef>

	<actiondef command="selectWindow">
		<conditional elements="TOP">
			<function object="SelectWindow" command="selectFrameTop" />
		</conditional>
	</actiondef>
</actions>