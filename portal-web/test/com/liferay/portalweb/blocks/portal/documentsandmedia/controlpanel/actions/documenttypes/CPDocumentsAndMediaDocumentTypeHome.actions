<actions object="CPDocumentsAndMediaDocumentTypeHome">
	<actiondef command="click">
		<conditional elements="SEARCH_BUTTON">
			<function object="Click" command="valueClickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef command="selectWindow">
		<conditional elements="TOP">
			<function object="SelectWindow" command="selectFrameTop" />
		</conditional>
	</actiondef>
</actions>