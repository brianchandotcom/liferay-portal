<actions>
	<actiondef name="click">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<functions command="textClickAtHomeClickDockbar" />
		</conditional>

		<conditional elements="ADD_LINK_APPLICATION">
			<functions command="partialTextClickAt" />
		</conditional>

		<conditional elements="GOTO_LINK_CONTROL_PANEL">
			<functions command="textClickAtAndWait" />
		</conditional>

		<conditional startswith="link=">
			<functions command="textClickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef name="mouseOver">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<functions command="textMouseOverHomeClickDockbar" />
		</conditional>
	</actiondef>

	<actiondef name="type">
		<conditional elements="PORTLET_FIELD_SEARCH">
			<functions command="sendKeysHomeAddApplication" />
		</conditional>
	</actiondef>
</actions>