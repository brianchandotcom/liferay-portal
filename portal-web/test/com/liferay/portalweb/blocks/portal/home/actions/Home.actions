<actions>
	<actiondef name="click">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<selenium command="clickAt" target="//div[@id='dockbar']" value="" />
			<selenium command="waitForElementPresent" target="//script[contains(@src,'/aui/aui-button-item/aui-button-item-min.js')]" />
			<defaultcommand />
		</conditional>

		<conditional elements="ADD_LINK_APPLICATION">
			<functions command="partialTextClickAt" />
		</conditional>

		<conditional elements="GOTO_LINK_CONTROL_PANEL">
			<functions command="textClickAtAndWait" />
		</conditional>

		<conditional startswith="link=">
			<functions command="textClickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef name="mouseOver">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<selenium command="clickAt" target="//div[@id='dockbar']" value="" />
			<selenium command="waitForElementPresent" target="//script[contains(@src,'/aui/aui-button-item/aui-button-item-min.js')]" />
			<defaultcommand />
		</conditional>
	</actiondef>

	<actiondef name="type">
		<conditional elements="PORTLET_FIELD_SEARCH">
			<selenium command="waitForElementPresent" target="//script[contains(@src,'/aui/aui-live-search/aui-live-search-min.js')]" />
			<functions command="sendKeys" />
		</conditional>
	</actiondef>
</actions>