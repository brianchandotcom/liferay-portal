<macros>
	<macrodef
		name="navigateControlPanelPage"
		description="Navigate to the &lt;strong&gt;Control Panel ${portlet} Portlet&lt;/strong&gt; in the &lt;strong&gt;Guest Community&lt;/strong&gt;."
		params="portlet"
	>
		<action name="Home" command="open" path="URL_GUEST" />
		<action name="Home" command="mouseOver" path="GOTO_LINK" />
		<action name="Home" command="click" path="GOTO_LINK_CONTROL_PANEL" />
		<action name="Home" command="click" locator="link=${portlet}" value="${portlet}" />
	</macrodef>

	<macrodef
		name="navigatePortletPage"
		description="Navigate to the &lt;strong&gt;${portlet} Portlet&lt;/strong&gt; in the &lt;strong&gt;Guest Community&lt;/strong&gt;."
		params="portlet"
	>
		<action name="Home" command="open" path="URL_GUEST" />
		<action name="Home" command="click" locator="link=${portlet} Test Page" value="${portlet} Test Page" />
	</macrodef>
</macros>