<macros>
	<macrodef name="addPage" params="portlet">
		<action name="Home" command="open" path="URL_GUEST" />
		<action name="Home" command="mouseOver" path="ADD_LINK" />
		<action name="Home" command="click" path="ADD_LINK_PAGE" />

		<action name="NewPage" command="type" path="NEW_PAGE_FIELD" value="${portlet} Test Page" />
		<action name="NewPage" command="click" path="NEW_PAGE_LINK_SAVE" />

		<action name="Home" command="type" locator="link=${portlet} Test Page" value="${portlet} Test Page" />
	</macrodef>
</macros>