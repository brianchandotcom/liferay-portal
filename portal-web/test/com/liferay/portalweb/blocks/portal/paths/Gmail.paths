<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<title>GmailBot</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">Gmail</td></tr>
</thead><tbody>
<tr>
	<td>LOGIN_FIELD_USERNAME</td>
	<td>//input[@id='Email']</td>
	<td></td>
</tr>
<tr>
	<td>LOGIN_FIELD_PASSWORD</td>
	<td>//input[@id='Passwd']</td>
	<td></td>
</tr>
<tr>
	<td>EMAIL_LINK_DELETE</td>
	<td>//div[@aria-label='Delete']/div/div</td>
	<td></td>
</tr>
<tr>
	<td>LOGIN_LINK_SIGN_IN</td>
	<td>//input[@id='signIn']</td>
	<td>Sign in</td>
</tr>
<tr>
	<td>EMAIL_LIST_LINK_NAME</td>
	<td>//span[@name='Joe Bloggs']</td>
	<td>Joe Bloggs</td>
</tr>
<tr>
	<td>EMAIL_LIST_LINK_TITLE_BLOGS_COMMENT</td>
	<td>//b[contains(.,'New Comments')]</td>
	<td>New Comments by Joe Bloggs</td>
</tr>
</tbody></table>
</body>
</html>