<macros object="CPRecycleBin">
	<macrodef
		name="empty"
		description="In the &lt;strong&gt;Control Panel Recycle Bin Portlet&lt;/strong&gt;, delete all the &lt;em&gt;Entries&lt;/em&gt;."
	>
		<params>
		</params>
		<steps>
			<macro name="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Recycle Bin" />
			</macro>

			<while name="CPRecycleBinPortlet" command="isElementPresent" path="EMPTY_RECYCLE_BIN_LINK" value="Empty the Recycle Bin">
				<action name="CPRecycleBinPortlet" command="click" path="EMPTY_RECYCLE_BIN_LINK" value="Empty the Recycle Bin" />
				<action name="CPRecycleBinPortlet" command="confirm" path="EMPTY_RECYCLE_BIN_CONFIRM" value="Are you sure you want to empty the Recycle Bin?" />
				<action name="CPRecycleBinPortlet" command="assertTextEquals" path="PORTLET_SUCCESS" value="Your request completed successfully." />
			</while>

			<action name="CPRecycleBinPortlet" command="assertTextEquals" path="TABLE_EMPTY_MESSAGE" value="The Recycle Bin is empty." />
		</steps>
	</macrodef>
</macros>