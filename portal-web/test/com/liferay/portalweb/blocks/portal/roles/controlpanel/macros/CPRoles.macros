<macros object="CPRoles">
	<macrodef
		command="addOrgRole"
		description="In the &lt;strong&gt;Control Panel Roles portlet&lt;/strong&gt;, add an Organization Role with Name: &lt;strong&gt;${name}&lt;/strong&gt;, Title: &lt;strong&gt;${title}&lt;/strong&gt;, and Description: &lt;strong&gt;${description}&lt;/strong&gt;."
	>
		<params>
			<param name="name" description="Name of Organization Role" example="Orgrole Name" />
			<param name="title" description="Title of Organization Role" example="orgrole Title" />
			<param name="description" description="Description of Organization Role" example="Orgrole Description" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Roles" />
			</macro>

			<action object="CPRolesHome" command="click" path="TOOLBAR_ADD_BUTTON" value="Add" />
			<action object="CPRolesHome" command="click" path="ADD_ORGANIZATION_ROLE" value="Organization Role" />

			<action object="CPRolesAddRole" command="type" path="ROLE_NAME" value="${name}" />
			<action object="CPRolesAddRole" command="type" path="ROLE_TITLE" value="${title}" />
			<action object="CPRolesAddRole" command="type" path="ROLE_DESCRIPTION" value="${description}" />
			<action object="CPRolesAddRole" command="click" path="BUTTON_SAVE" value="Save" />

			<action object="CPRolesHome" command="assertTextEquals" path="HEADER_SUCCESS_MESSAGE" value="Your request completed successfully." />
		</steps>
	</macrodef>

	<macrodef
		command="addRegRole"
		description="In the &lt;strong&gt;Control Panel Roles portlet&lt;/strong&gt;, add a Regular Role with Name: &lt;strong&gt;${name}&lt;/strong&gt;, Title: &lt;strong&gt;${title}&lt;/strong&gt;, and Description: &lt;strong&gt;${description}&lt;/strong&gt;."
	>
		<params>
			<param name="name" description="Name of Regular Role" example="Regrole Name" />
			<param name="title" description="Title of Regular Role" example="Regrole Title" />
			<param name="description" description="Description of Regular Role" example="Regrole Description" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Roles" />
			</macro>

			<action object="CPRolesHome" command="click" path="TOOLBAR_ADD_BUTTON" value="Add" />
			<action object="CPRolesHome" command="click" path="ADD_REGULAR_ROLE" value="Regular Role" />

			<action object="CPRolesAddRole" command="type" path="ROLE_NAME" value="${name}" />
			<action object="CPRolesAddRole" command="type" path="ROLE_TITLE" value="${title}" />
			<action object="CPRolesAddRole" command="type" path="ROLE_DESCRIPTION" value="${description}" />
			<action object="CPRolesAddRole" command="click" path="BUTTON_SAVE" value="Save" />

			<action object="CPRolesHome" command="assertTextEquals" path="HEADER_SUCCESS_MESSAGE" value="Your request completed successfully." />
		</steps>
	</macrodef>

	<macrodef
		command="addSiteRole"
		description="In the &lt;strong&gt;Control Panel Roles portlet&lt;/strong&gt;, add a Site Role with Name: &lt;strong&gt;${name}&lt;/strong&gt;, Title: &lt;strong&gt;${title}&lt;/strong&gt;, and Description: &lt;strong&gt;${description}&lt;/strong&gt;."
	>
		<params>
			<param name="name" description="Name of Site Role" example="Siterole Name" />
			<param name="title" description="Title of Site Role" example="Siterole Title" />
			<param name="description" description="Description of Site Role" example="Siterole Description" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Roles" />
			</macro>

			<action object="CPRolesHome" command="click" path="TOOLBAR_ADD_BUTTON" value="Add" />
			<action object="CPRolesHome" command="click" path="ADD_SITE_ROLE" value="Site Role" />

			<action object="CPRolesAddRole" command="type" path="ROLE_NAME" value="${name}" />
			<action object="CPRolesAddRole" command="type" path="ROLE_TITLE" value="${title}" />
			<action object="CPRolesAddRole" command="type" path="ROLE_DESCRIPTION" value="${description}" />
			<action object="CPRolesAddRole" command="click" path="BUTTON_SAVE" value="Save" />

			<action object="CPRolesHome" command="assertTextEquals" path="HEADER_SUCCESS_MESSAGE" value="Your request completed successfully." />
		</steps>
	</macrodef>

	<macrodef
		command="advancedSearch"
		description="In the &lt;strong&gt;Control Panel Users and Organizations portlet&lt;/strong&gt;, open Advanced Search."
	>
		<params>
		</params>
		<steps>
		<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Roles" />
		</macro>

		<action object="CPRolesHome" command="type" path="SEARCH_FILED" value="Administrator" />
		<action object="CPRolesHome" command="click" path="SEARCH_BUTTON" value="Search" />

		<action object="CPRolesHome" command="click" path="ROLES_ACTIONS" value="Actions" />
		<action object="CPRolesHome" command="click" path="ACTIONS_ASSIGN_MEMBERS" value="Assign Members" />

		<if object="CPRolesAssignMembersUsers" command="isVisible" path="BASIC_SEARCH_ADVANCED_LINK" >
			<action object="CPRolesAssignMembersUsers" command="click" path="BASIC_SEARCH_ADVANCED_LINK" value="Advanced »" />
		</if>
		</steps>
	</macrodef>

	<macrodef
		command="assignRegrole"
		description="In the &lt;strong&gt;Control Panel Roles portlet&lt;/strong&gt;, assign a Regular Role with Title: &lt;strong&gt;${title}&lt;/strong&gt;to a user with First Name: &lt;strong&gt;${firstName}&lt;/strong&gt;."
	>
		<params>
			<param name="role" description="Title of Regular Role" example="Regrole Title" />
			<param name="firstName" description="First Name of the User" example="userfn" />
		</params>
		<steps>
			<macro object="CPRoles" command="basicSearch" />

			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Roles" />
			</macro>

			<action object="CPRolesHome" command="type" path="SEARCH_FILED" value="${role}" />
			<action object="CPRolesHome" command="click" path="SEARCH_BUTTON" value="Search" />

			<action object="CPRolesHome" command="click" path="ROLES_ACTIONS" value="Actions" />
			<action object="CPRolesHome" command="click" path="ACTIONS_ASSIGN_MEMBERS" value="Assign Members" />

			<action object="CPRolesAssignMembersUsers" command="click" path="STATUS_AVAILABLE" value="Available" />

			<action object="CPRolesAssignMembersUsers" command="type" path="BASIC_SEARCH_FIELD" value="${firstName}" />
			<action object="CPRolesAssignMembersUsers" command="click" path="BASIC_SEARCH_BUTTON" value="Search" />

			<action object="CPRolesAssignMembersUsers" command="check" path="USERS_USER_1_CHECK" />
			<action object="CPRolesAssignMembersUsers" command="click" path="BUTTON_UPDATE_ASSOCIATIONS" value="Update Associations" />

			<action object="CPRolesHome" command="assertTextEquals" path="HEADER_SUCCESS_MESSAGE" value="Your request completed successfully." />
		</steps>
	</macrodef>

	<macrodef
		command="basicSearch"
		description="In the &lt;strong&gt;Control Panel Users and Organizations portlet&lt;/strong&gt;, open Basic Search."
	>
		<params>
		</params>
		<steps>
		<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Roles" />
		</macro>

		<action object="CPRolesHome" command="type" path="SEARCH_FILED" value="Administrator" />
		<action object="CPRolesHome" command="click" path="SEARCH_BUTTON" value="Search" />

		<action object="CPRolesHome" command="click" path="ROLES_ACTIONS" value="Actions" />
		<action object="CPRolesHome" command="click" path="ACTIONS_ASSIGN_MEMBERS" value="Assign Members" />

		<if object="CPRolesAssignMembersUsers" command="isVisible" path="ADVANCED_SEARCH_BASIC_LINK" >
			<action object="CPRolesAssignMembersUsers" command="click" path="ADVANCED_SEARCH_BASIC_LINK" value="« Basic" />
		</if>
		</steps>
	</macrodef>

	<macrodef
		command="delete"
		description="In the &lt;strong&gt;Control Panel Roles portlet&lt;/strong&gt;, delete the role with Title: &lt;strong&gt;${title}&lt;/strong&gt;."
	>
		<params>
			<param name="title" description="Title of the Role to delete" example="Regrole Title" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Roles" />
			</macro>

			<action object="CPRolesHome" command="type" path="SEARCH_FILED" value="${title}*" />
			<action object="CPRolesHome" command="click" path="SEARCH_BUTTON" value="Search" />

			<while object="CPRolesHome" command="isElementPresent" path="ROLES_NAME">
				<action object="CPRolesHome" command="click" path="ROLES_ACTIONS" value="Actions" />
				<action object="CPRolesHome" command="click" path="ACTIONS_DELETE" value="Delete" />
				<action object="CPRolesHome" command="confirm" path="HEADER_CONFIRMATION" value="Are you sure you want to delete this? It will be deleted immediately." />
			</while>

			<action object="CPRolesHome" command="assertTextEquals" path="ROLES_MESSAGE" value="No roles were found." />
		</steps>
	</macrodef>

	<macrodef
		command="tearDown"
		description="In the &lt;strong&gt;Control Panel Roles portlet&lt;/strong&gt;, delete all created roles."
	>
		<params>
		</params>
		<steps>
			<macro object="CPRoles" command="delete">
				<param name="title" value="Orgrole Title*" />
			</macro>

			<macro object="CPRoles" command="delete">
				<param name="title" value="Regrole Title*" />
			</macro>

			<macro object="CPRoles" command="delete">
				<param name="title" value="Siterole Title*" />
			</macro>
		</steps>
	</macrodef>
</macros>