<actions object="CPUsersAndOrganizationsEditUser">
	<actiondef command="assertTextEquals">
		<conditional elements="USER_EMAIL_ADDRESS,USER_FIRST_NAME,USER_LAST_NAME,USER_SCREEN_NAME">
			<function object="AssertTextEquals" command="assertValue" />
		</conditional>
	</actiondef>

	<actiondef command="click">
		<conditional elements="BUTTONS_CANCEL,BUTTONS_SAVE">
			<function object="Click" command="valueClickAtAndWait" />
		</conditional>

		<conditional elements="USER_INFORMATION_PASSWORD,USER_INFORMATION_ROLES">
			<function object="Click" command="partialTextClickAt" />
		</conditional>
	</actiondef>
</actions>