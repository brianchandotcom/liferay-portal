<actions object="CPUsersAndOrganizationsHome">
	<actiondef command="click">
		<conditional elements="ADD_USER,USERS_SEARCH_ALL,USERS_USER_1_FIRST_NAME">
			<function object="Click" command="textClickAndWait" />
		</conditional>

		<conditional elements="SEARCH_BUTTON,USERS_DEACTIVATE">
			<function object="Click" command="valueClickAtAndWait" />
		</conditional>
	</actiondef>
</actions>