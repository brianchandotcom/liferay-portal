<actions>
	<actiondef name="click">
		<conditional elements="SIDEBAR_PUBLISH">
			<function name="Click" command="clickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef name="type">
		<conditional elements="ARTICLE_CONTENT">
			<function name="Type" command="typeCPWebContentCKEditor" />
		</conditional>
	</actiondef>
</actions>