<macros object="CPBlogsEntryComment">
	<macrodef
		command="addBlogsEntryComment1"
		description="In the &lt;strong&gt;Control Panel Blogs Portlet&lt;/strong&gt;, add the first &lt;em&gt;Blogs Entry Comment&lt;/em&gt; with the value &lt;strong&gt;&quot;${blogsEntryComment}&quot;&lt;/strong&gt; to the &lt;em&gt;Blogs Entry&lt;/em&gt; &lt;strong&gt;&quot;${blogsEntry}&quot;&lt;/strong&gt;."
	>
		<params>
			<param name="blogsEntry" description="Title of the Blogs Entry" example="Blogs Entry Title" />
			<param name="blogsEntryComment" description="Comment of the Blogs Entry" example="Blogs Entry Comment Body" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Blogs" />
			</macro>

			<action object="CPBlogsHome" command="click" target="BLOGS_ENTRY_LINK_TITLE" value="${blogsEntry}" />

			<action object="CPBlogsEntryView" command="assertTextEquals" target="PORTLET_TEXT_COMMENT_MESSAGE" value="No comments yet." />
			<action object="CPBlogsEntryView" command="click" target="BLOGS_ENTRY_LINK_ADD_COMMENT_1" />
			<action object="CPBlogsEntryView" command="type" target="BLOGS_COMMENT_ADD_FIELD_BODY" value="${blogsEntryComment}" />
			<action object="CPBlogsEntryView" command="click" target="BLOGS_COMMENT_ADD_LINK_SAVE" />
			<action object="CPBlogsEntryView" command="assertTextEquals" target="BLOGS_COMMENT_ADD_TEXT_SUCCESS" />
			<action object="CPBlogsEntryView" command="assertTextEquals" target="BLOGS_COMMENT_TEXT_BODY" value="${blogsEntryComment}" />
			<action object="CPBlogsEntryView" command="assertTextNotPresent" value="No comments yet." />
		</steps>
	</macrodef>

	<macrodef
		command="addBlogsEntryComment2"
		description="In the &lt;strong&gt;Control Panel Blogs Portlet&lt;/strong&gt;, add another &lt;em&gt;Blogs Entry Comment&lt;/em&gt; with the value &lt;strong&gt;&quot;${blogsEntryComment}&quot;&lt;/strong&gt; to the &lt;em&gt;Blogs Entry&lt;/em&gt; &lt;strong&gt;&quot;${blogsEntry}&quot;&lt;/strong&gt;."
	>
		<params>
			<param name="blogsEntry" description="Title of the Blogs Entry" example="Blogs Entry Title" />
			<param name="blogsEntryComment" description="Comment of the Blogs Entry" example="Blogs Entry Comment Body" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Blogs" />
			</macro>

			<action object="CPBlogsHome" command="click" target="BLOGS_ENTRY_LINK_TITLE" value="${blogsEntry}" />

			<action object="CPBlogsEntryView" command="click" target="BLOGS_ENTRY_LINK_ADD_COMMENT_2" />
			<action object="CPBlogsEntryView" command="type" target="BLOGS_COMMENT_ADD_FIELD_BODY" value="${blogsEntryComment}" />
			<action object="CPBlogsEntryView" command="click" target="BLOGS_COMMENT_ADD_LINK_SAVE" />
			<action object="CPBlogsEntryView" command="assertTextEquals" target="BLOGS_COMMENT_ADD_TEXT_SUCCESS" />
			<action object="CPBlogsEntryView" command="assertTextEquals" target="BLOGS_COMMENT_TEXT_BODY" value="${blogsEntryComment}" />
			<action object="CPBlogsEntryView" command="assertTextNotPresent" value="No comments yet." />
		</steps>
	</macrodef>
</macros>