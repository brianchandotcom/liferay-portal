<testcase
	name="AddBlogsEntryContentNullCP"
	description="In the Control Panel Blogs Portlet, ensure that you can not add a Blogs Entry without content."
>
	<setup>
	</setup>
	<steps>
		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="click" target="PORTLET_LINK_ADD" value="Add" />

		<action object="CPBlogsAddEntry" command="type" target="CONTENT_FIELD_TITLE" value="Blogs Entry Title" />
		<action object="CPBlogsAddEntry" command="type" target="CONTENT_FIELD_CONTENT" value="" />
		<action object="CPBlogsAddEntry" command="click" target="CONTENT_LINK_SAVE" value="Publish" />
		<action object="CPBlogsAddEntry" command="assertTextEquals" target="CONTENT_TEXT_ERROR_MESSAGE_1" value="Your request failed to complete." />
		<action object="CPBlogsAddEntry" command="assertTextEquals" target="CONTENT_TEXT_ERROR_MESSAGE_2" value="Please enter valid content." />

		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Title" />
		<action object="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro object="CPBlogsEntry" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</testcase>