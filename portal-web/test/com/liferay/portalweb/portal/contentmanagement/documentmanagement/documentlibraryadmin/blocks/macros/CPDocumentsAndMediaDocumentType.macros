<macros object="CPDocumentsAndMediaDocumentType">
	<macrodef
		command="add"
		description="In the &lt;strong&gt;Control Panel Documents and Media Portlet&lt;/strong&gt;, add a &lt;em&gt;Document Type&lt;/em&gt; with a name of &lt;strong&gt;&quot;${name}&quot;&lt;/strong&gt;."
	>
		<params>
			<param name="name" description="Title of the Document Type" example="DM DocumentType Name" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Documents and Media" />
			</macro>

			<action object="CPDocumentsAndMediaHome" command="click" target="TOOLBAR_MANAGE_BUTTON" value="Manage" />
			<action object="CPDocumentsAndMediaHome" command="click" target="MANAGE_DOCUMENT_TYPES" value="Document Types" />

			<window object="CPDocumentsAndMediaDocumentTypeHome">
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="BUTTON_ADD" value="Add" />

				<action object="CPDocumentsAndMediaAddDocumentType" command="type" target="CONTENT_NAME" value="${name}" />
				<action object="CPDocumentsAndMediaAddDocumentType" command="dragAndDrop" target1="METADATA_FIELD_TEXT" value1="Text" target2="METADATA_CANVAS_BUILDER" />
				<action object="CPDocumentsAndMediaAddDocumentType" command="click" target="BUTTON_SAVE" value="Save" />

				<action object="CPDocumentsAndMediaDocumentTypeHome" command="assertTextEquals" target="HEADER_SUCCESS_MESSAGE" value="Your request completed successfully." />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="assertTextPresent" value="${name}" />
			</window>
		</steps>
	</macrodef>

	<macrodef
		command="delete"
		description="In the &lt;strong&gt;Control Panel Documents and Media Portlet&lt;/strong&gt;, delete a &lt;em&gt;Document Type&lt;/em&gt; named: &lt;strong&gt;&quot;${name}&quot;&lt;/strong&gt;."
	>
		<params>
			<param name="name" description="Title of the Document Type" example="DM DocumentType Name" />
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Documents and Media" />
			</macro>

			<action object="CPDocumentsAndMediaHome" command="click" target="TOOLBAR_MANAGE_BUTTON" value="Manage" />
			<action object="CPDocumentsAndMediaHome" command="click" target="MANAGE_DOCUMENT_TYPES" value="Document Types" />

			<window object="CPDocumentsAndMediaDocumentTypeHome">
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="type" target="SEARCH_FIELD" value="${name}" />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="SEARCH_BUTTON" value="Search" />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="assertTextEquals" target="TABLE_NAME_1" value="${name}" />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="TABLE_ACTIONS_1" value="Actions" />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="ACTIONS_DELETE" value="Delete" />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="confirm" target="ACTIONS_DELETE_CONFIRMATION" value="Are you sure you want to delete this? It will be deleted immediately." />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="assertTextNotPresent" value="${name}" />
			</window>
		</steps>
	</macrodef>

	<macrodef
		command="tearDown"
		description="In the &lt;strong&gt;Control Panel Documents and Media Portlet&lt;/strong&gt;, delete all the &lt;em&gt;Document Types&lt;/em&gt;."
	>
		<params>
		</params>
		<steps>
			<macro object="Goto" command="controlPanelPortlet">
				<param name="portlet" value="Documents and Media" />
			</macro>

			<action object="CPDocumentsAndMediaHome" command="click" target="TOOLBAR_MANAGE_BUTTON" value="Manage" />
			<action object="CPDocumentsAndMediaHome" command="click" target="MANAGE_DOCUMENT_TYPES" value="Document Types" />

			<window object="CPDocumentsAndMediaDocumentTypeHome">
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="type" target="SEARCH_FIELD" value="DM" />
				<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="SEARCH_BUTTON" value="Search" />

				<while object="CPDocumentsAndMediaDocumentTypeHome" command="isElementPresent" target="TABLE_ACTIONS_1">
					<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="TABLE_ACTIONS_1" value="Actions" />
					<action object="CPDocumentsAndMediaDocumentTypeHome" command="click" target="ACTIONS_DELETE" value="Delete" />
					<action object="CPDocumentsAndMediaDocumentTypeHome" command="confirm" target="ACTIONS_DELETE_CONFIRMATION" value="Are you sure you want to delete this? It will be deleted immediately." />
				</while>
			</window>
		</steps>
	</macrodef>
</macros>