<test
	name="CheckinDMDocument"
	description="In the Control Panel Documents and Media Portlet, ensure that a saved change that was made while a document was checked out will apply once you checkin that Document."
>
	<setup>
		<macro object="CPDocumentsAndMediaDocument" command="add">
			<param name="title" value="DM Document Title" />
			<param name="file" value="Document_1.doc" />
		</macro>

		<macro object="CPDocumentsAndMediaDocument" command="checkout">
			<param name="title" value="DM Document Title" />
		</macro>

		<macro object="CPDocumentsAndMediaDocument" command="editCheckout">
			<param name="oldTitle" value="DM Document Title"  />
			<param name="newTitle" value="DM Document Title Edit"  />
		</macro>
	</setup>
	<steps>
		<macro object="CPDocumentsAndMediaDocument" command="checkin">
			<param name="oldTitle" value="DM Document Title" />
			<param name="newTitle" value="DM Document Title Edit" />
		</macro>

		<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Documents and Media" />
		</macro>

		<action object="CPDocumentsAndMediaHome" command="click" target="DOCUMENT_NAME" value="DM Document Title Edit" />

		<action object="CPDocumentsAndMediaDocument" command="assertElementNotPresent" target="DOCUMENT_LOCK_MESSAGE" />

		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="TOOLBAR_CHECKOUT" value="Checkout" />

		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_INFO_WORKFLOW_STATUS" value="Status: Approved" />
		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_HISTORY_VERSION_1" value="1.1" />
		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_HISTORY_VERSION_2" value="1.0" />
		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_HISTORY_STATUS_1" value="Approved" />
		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_HISTORY_STATUS_2" value="Approved" />
	</steps>
	<teardown>
		<macro object="CPDocumentsAndMediaDocument" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>