<test
	name="DeleteDMFolder"
	description="In the Control Panel Documents and Media Portlet, delete a Folder."
>
	<setup>
		<macro object="CPDocumentsAndMediaFolder" command="add">
			<param name="title" value="DM Folder" />
		</macro>
	</setup>
	<steps>
		<macro object="CPDocumentsAndMediaFolder" command="delete">
			<param name="title" value="DM Folder" />
		</macro>
	</steps>
	<teardown>
		<macro object="CPDocumentsAndMediaFolder" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>