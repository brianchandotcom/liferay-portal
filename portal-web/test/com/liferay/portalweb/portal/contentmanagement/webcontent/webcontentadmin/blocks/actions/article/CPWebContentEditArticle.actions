<actions object="CPWebContentEditArticle">
	<actiondef command="assertTextEquals">
		<conditional elements="ARTICLE_CONTENT">
			<function object="AssertTextEquals" command="assertTextCPWebContenCKEditor" />
		</conditional>

		<conditional elements="ARTICLE_TITLE">
			<function object="AssertTextEquals" command="assertValue" />
		</conditional>
	</actiondef>
</actions>