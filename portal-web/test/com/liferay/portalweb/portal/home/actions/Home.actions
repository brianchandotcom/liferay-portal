<actions object="Home">
	<actiondef command="click">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<function object="Click" command="textClickAtHomeClickDockbar" />
		</conditional>

		<conditional elements="ADD_LINK_APPLICATION">
			<function object="Click" command="partialTextClickAt" />
		</conditional>

		<conditional elements="GOTO_LINK_CONTROL_PANEL">
			<function object="Click" command="textClickAtAndWait" />
		</conditional>

		<conditional startswith="link=">
			<function object="Click" command="textClickAtAndWait" />
		</conditional>
	</actiondef>

	<actiondef command="mouseOver">
		<conditional elements="ADD_LINK,GOTO_LINK,MANAGE_LINK">
			<function object="MouseOver" command="textMouseOverHomeClickDockbar" />
		</conditional>
	</actiondef>

	<actiondef command="type">
		<conditional elements="PORTLET_FIELD_SEARCH">
			<function object="Type" command="sendKeysHomeAddApplication" />
		</conditional>
	</actiondef>
</actions>