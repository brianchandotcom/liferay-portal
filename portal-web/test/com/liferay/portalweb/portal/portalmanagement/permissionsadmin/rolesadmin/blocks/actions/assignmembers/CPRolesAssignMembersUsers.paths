<body>
<table cellpadding="1" cellspacing="1" border="1"><thead><tr><td rowspan="1" colspan="3">CPRolesEditDefinePermissions</td></tr></thead><tbody>
<tr>
	<td>PAGE_NAME</td>
	<td></td>
	<td>Control Panel Roles Assign Members Users</td>
</tr>
<tr>
	<td></td>
