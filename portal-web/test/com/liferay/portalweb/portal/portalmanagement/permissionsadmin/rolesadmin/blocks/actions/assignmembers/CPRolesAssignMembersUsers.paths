</tr>
<tr>
	<td>TOOLBAR_ASSIGN_MEMBERS</td>
	<td>//a[@class='aui-tab-label' and contains(.,'Organizations')]</td>
	<td>Toolbar Organizations Tab</td>
</tr>
<tr>
	<td>TOOLBAR_USER_GROUPS</td>
	<td>//a[@class='aui-tab-label' and contains(.,'User Groups')]</td>
