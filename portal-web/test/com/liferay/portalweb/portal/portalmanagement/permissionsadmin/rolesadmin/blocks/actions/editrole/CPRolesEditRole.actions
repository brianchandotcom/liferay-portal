<actions object="CPRolesEditRole">
	<actiondef command="assertTextEquals">
		<conditional elements="ROLE_NAME,ROLE_TITLE,ROLE_DESCRIPTION">
			<function object="AssertTextEquals" command="assertValue" />
		</conditional>

		<conditional elements="ROLE_TYPE">
			<function object="AssertTextEquals" command="assertPartialText" />
		</conditional>
	</actiondef>
</actions>