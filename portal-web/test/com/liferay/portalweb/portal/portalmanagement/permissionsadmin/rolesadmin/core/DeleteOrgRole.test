<test
	name="DeleteOrgRole"
	description="In the &lt;strong&gt;Control Panel Roles Portlet&lt;/strong&gt;, delete an Organization Role."
>
	<setup>
		<macro object="CPRoles" command="addOrgRole">
			<param name="name" value="Orgrole Name " />
			<param name="title" value="Orgrole Title" />
			<param name="description" value="Orgrole Description" />
		</macro>
	</setup>
	<steps>
		<macro object="CPRoles" command="delete">
			<param name="title" value="Orgrole Title" />
		</macro>
	</steps>
	<teardown>
		<macro object="CPRoles" command="tearDown" />
	</teardown>
</test>