<test
	name="AddBlogsEntryCP"
	description="In the Control Panel Blogs Portlet, add a Blogs Entry."
>
	<setup>
	</setup>
	<steps>
		<macro name="CPBlogsEntry" command="addBlogsEntry">
			<param name="title" value="Blogs Entry Title" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDownBlogsEntry" />
		<macro name="CPRecycleBin" command="emptyRecycleBin" />
	</teardown>
</test>