<test
	name="AddBlogsEntryContentNullCP"
	description="In the Control Panel Blogs Portlet, ensure that you can not add a Blogs Entry without content."
>
	<setup>
	</setup>
	<steps>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="PORTLET_LINK_ADD" value="Add" />

		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_TITLE" value="Blogs Entry Title" />
		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_CONTENT" value="" />
		<action name="CPBlogsEntryAdd" command="click" path="CONTENT_LINK_SAVE" value="Publish" />
		<action name="CPBlogsEntryAdd" command="assertTextEquals" path="CONTENT_TEXT_ERROR_MESSAGE_1" value="Your request failed to complete." />
		<action name="CPBlogsEntryAdd" command="assertTextEquals" path="CONTENT_TEXT_ERROR_MESSAGE_2" value="Please enter valid content." />

		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="assertTextNotPresent" value="Blogs Entry Title" />
		<action name="CPBlogsPortlet" command="assertTextNotPresent" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDownBlogsEntry" />
		<macro name="CPRecycleBin" command="emptyRecycleBin" />
	</teardown>
</test>