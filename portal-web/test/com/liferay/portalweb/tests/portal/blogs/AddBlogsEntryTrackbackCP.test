<xml>
	<setup>
		<macro name="CPBlogsEntry" command="addBlogsEntry">
			<param name="title" value="Blogs Entry1 Title" />
			<param name="title" value="Blogs Entry1 Content" />
		</macro>
	</setup>
	<steps>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="page" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE_1" value="Blogs Entry1 Title" />

		<action name="CPBlogsEntryView" command="copy" path="BLOGS_ENTRY_FIELD_TRACKBACK_URL" />

		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="page" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="PORTLET_LINK_ADD" />

		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_TITLE" value="Blogs Entry2 Title" />
		<action name="CPBlogsEntryAdd" command="type" path="CONTENT_FIELD_CONTENT" value="Blogs Entry2 Content" />
		<action name="CPBlogsEntryAdd" command="paste" path="CONTENT_FIELD_TRACKBACKS" />
		<action name="CPBlogsEntryAdd" command="click" path="CONTENT_LINK_SAVE" />

		<action name="CPBlogsPortlet" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE_1" value="Blogs Entry2 Title" />

		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry2 Title" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry2 Content" />

		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="page" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE_2" value="Blogs Entry1 Title" />

		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry1 Title" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry1 Content" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_COMMENT_TEXT_BODY_1" value="[...] Blogs Entry2 Content [...] Read More" />
		<action name="CPBlogsEntryView" command="click" path="BLOGS_COMMENT_LINK_READ_MORE" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry2 Title" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry2 Content" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDownBlogsEntry" />
		<macro name="CPRecycleBin" command="emptyRecycleBin" />
	</teardown>
</xml>