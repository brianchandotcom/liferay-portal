<xml>
	<setup>
		<macro name="CPBlogsEntry" command="addBlogsEntry">
			<param name="title" value="&lt;!-- --&gt;" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</setup>
	<steps>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="page" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE_1" value="&lt;!-- --&gt;" />
		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_AUTHOR_1" />
		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_STATUS_1" value="Approved" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_ACTIONS_1" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_ACTIONS_DELETE" />
		<action name="CPBlogsPortlet" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS_UNDO" />
		<action name="CPBlogsPortlet" command="assertTextEquals" path="PORTLET_TEXT_INFO" />
		<action name="CPBlogsPortlet" command="assertTextNotPresent" path="" value="&lt;!-- --&gt;" />
		<action name="CPBlogsPortlet" command="assertTextNotPresent" path="" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDownBlogsEntry" />
		<macro name="CPRecycleBin" command="emptyRecycleBin" />
	</teardown>
</xml>