<xml>
	<setup>
		<macro name="CPBlogsEntry" command="addBlogsEntry">
			<param name="title" value="Blogs Entry Title" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</setup>
	<steps>
		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="page" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />

		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry Title" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry Content" />

		<macro name="Navigation" command="navigateControlPanelPage">
			<param name="page" value="Blogs" />
		</macro>

		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_ACTIONS" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_ACTIONS_EDIT" />

		<action name="CPBlogsEntryEdit" command="type" path="CONTENT_FIELD_TITLE" value="Blogs Entry Title Edit" />
		<action name="CPBlogsEntryEdit" command="click" path="CONTENT_LINK_SAVE" />
		<action name="CPBlogsEntryEdit" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS" />

		<action name="CPBlogsPortlet" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title Edit" />
		<action name="CPBlogsPortlet" command="click" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title Edit" />

		<action name="CPBlogsEntryView" command="assertTextNotEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry Title" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry Title Edit" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDownBlogsEntry" />
		<macro name="CPRecycleBin" command="emptyRecycleBin" />
	</teardown>
</xml>