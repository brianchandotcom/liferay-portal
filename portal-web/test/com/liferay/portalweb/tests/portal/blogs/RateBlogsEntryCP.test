<test
	name="RateBlogsEntryCP"
	description="In the Control Panel Blogs Portlet, rate a Blogs Entry."
>
	<setup>
		<macro name="CPBlogsEntry" command="add">
			<param name="title" value="Blogs Entry Title" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</setup>
	<steps>
		`<macro name="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />

		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry Title" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry Content" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_RATING_AVERAGE" value="0 Votes" />
		<action name="CPBlogsEntryView" command="click" path="BLOGS_ENTRY_LINK_RATE_STAR_5" value="" />
		<action name="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_RATING_AVERAGE" value="1 Vote" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDown" />
		<macro name="CPRecycleBin" command="empty" />
	</teardown>
</test>