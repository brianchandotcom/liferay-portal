<test
	name="DeleteBlogsEntryListCP"
	description="In the Control Panel Blogs Portlet, delete a Blogs Entry using the checkbox."
>
	<setup>
		<macro name="CPBlogsEntry" command="add">
			<param name="title" value="Blogs Entry Title" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</setup>
	<steps>
		`<macro name="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />
		<action name="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_STATUS" value="Approved" />
		<action name="CPBlogsHome" command="check" path="BLOGS_ENTRY_LINK_CHECKBOX" value="" />
		<action name="CPBlogsHome" command="click" path="PORTLET_LINK_DELETE" value="Move to the Recycle Bin" />
		<action name="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS_UNDO" value="The selected item was moved to the Recycle Bin. Undo" />
		<action name="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_INFO" value="No entries were found." />
		<action name="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Title" />
		<action name="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDown" />
		<macro name="CPRecycleBin" command="empty" />
	</teardown>
</test>