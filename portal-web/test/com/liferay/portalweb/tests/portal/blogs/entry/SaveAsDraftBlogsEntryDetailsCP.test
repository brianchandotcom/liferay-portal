<test
	name="AddBlogsEntryAutoDraftCP"
	description="In the Control Panel Blogs Portlet, add a Blogs Entry draft."
>
	<setup>
	</setup>
	<steps>
		<macro name="CPBlogsEntry" command="saveAsDraft">
			<param name="title" value="Blogs Entry Title" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDown" />
		<macro name="CPRecycleBin" command="empty" />
	</teardown>
</test>