<test
	name="AddBlogsEntryAutoDraftCP"
	description="In the Control Panel Blogs Portlet, add a Blogs Entry Draft through auto-draft."
>
	<setup>
	</setup>
	<steps>
		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="click" path="PORTLET_LINK_ADD" value="Add" />

		<action object="CPBlogsAddEntry" command="type" path="CONTENT_FIELD_TITLE" value="Blogs Entry Title" />
		<action object="CPBlogsAddEntry" command="type" path="CONTENT_FIELD_CONTENT" value="Blogs Entry Content" />
		<action object="CPBlogsAddEntry" command="assertTextEquals" path="CONTENT_TEXT_SAVE_STATUS" value="Draft saved" />

		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />
		<action object="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_STATUS" value="Draft" />
		<action object="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />

		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_DRAFT" value="Draft" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry Title" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro object="CPBlogsEntry" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>