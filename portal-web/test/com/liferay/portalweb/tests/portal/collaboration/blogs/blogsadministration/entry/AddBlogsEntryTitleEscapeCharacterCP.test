<test
	name="AddBlogsEntryTitleEscapeCharactersCP"
	description="In the Control Panel Blogs Portlet, add a Blogs Entry with a title with escape characters."
>
	<setup>
	</setup>
	<steps>
		<macro object="CPBlogsEntry" command="add">
			<param name="title" value="&lt;!-- --&gt;" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</steps>
	<teardown>
		<macro object="CPBlogsEntry" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>