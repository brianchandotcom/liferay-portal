<test
	name="AddBlogsEntryTitleTrackbackCP"
	description="In the Control Panel Blogs Portlet, add a Blogs Entry with a title with a Trackback URL."
>
	<setup>
		<macro object="CPBlogsEntry" command="add">
			<param name="title" value="Blogs Entry1 Title" />
			<param name="title" value="Blogs Entry1 Content" />
		</macro>
	</setup>
	<steps>
		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_TITLE_1" value="Blogs Entry1 Title" />

		<action object="CPBlogsEntryView" command="copy" path="BLOGS_ENTRY_FIELD_TRACKBACK_URL" />

		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="click" path="PORTLET_LINK_ADD" />

		<action object="CPBlogsAddEntry" command="type" path="CONTENT_FIELD_TITLE" value="Blogs Entry2 Title" />
		<action object="CPBlogsAddEntry" command="type" path="CONTENT_FIELD_CONTENT" value="Blogs Entry2 Content" />
		<action object="CPBlogsAddEntry" command="paste" path="CONTENT_FIELD_TRACKBACKS" />
		<action object="CPBlogsAddEntry" command="click" path="CONTENT_LINK_SAVE" value="Publish" />

		<action object="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS" value="Your request completed successfully." />
		<action object="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_TITLE_1" value="Blogs Entry2 Title" />

		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry2 Title" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry2 Content" />

		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_TITLE_2" value="Blogs Entry1 Title" />

		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry1 Title" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry1 Content" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_COMMENT_TEXT_BODY_1" value="[...] Blogs Entry2 Content [...] Read More" />
		<action object="CPBlogsEntryView" command="click" path="BLOGS_COMMENT_LINK_READ_MORE" value="Read More" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_TITLE" value="Blogs Entry2 Title" />
		<action object="CPBlogsEntryView" command="assertTextEquals" path="BLOGS_ENTRY_TEXT_CONTENT" value="Blogs Entry2 Content" />
	</steps>
	<teardown>
		<macro object="CPBlogsEntry" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>