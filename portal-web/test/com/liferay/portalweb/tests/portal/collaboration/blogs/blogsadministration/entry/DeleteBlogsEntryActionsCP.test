<test
	name="DeleteBlogsEntryActionsCP"
	description="In the Control Panel Blogs Portlet, delete a Blogs Entry using the actions menu."
>
	<setup>
		<macro object="CPBlogsEntry" command="add">
			<param name="title" value="Blogs Entry Title" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</setup>
	<steps>
		`<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action object="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE" value="Blogs Entry Title" />
		<action object="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_AUTHOR" value="Joe Bloggs" />
		<action object="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_STATUS" value="Approved" />
		<action object="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_ACTIONS" value="Actions" />
		<action object="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_ACTIONS_DELETE" value="Move to the Recycle Bin" />
		<action object="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS_UNDO" value="The selected item was moved to the Recycle Bin. Undo"/>
		<action object="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_INFO" value="No entries were found." />
		<action object="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Title" />
		<action object="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro object="CPBlogsEntry" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>