<test
	name="DeleteBlogsEntry150CharactersActionsCP"
	description="In the Control Panel Blogs Portlet, delete a Blogs Entry with a title of escape characters."
>
	<setup>
		<macro name="CPBlogsEntry" command="add">
			<param name="title" value="&lt;!-- --&gt;" />
			<param name="content" value="Blogs Entry Content" />
		</macro>
	</setup>
	<steps>
		`<macro name="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Blogs" />
		</macro>

		<action name="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_TITLE_1" value="&lt;!-- --&gt;" />
		<action name="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_AUTHOR_1" value="Joe Bloggs" />
		<action name="CPBlogsHome" command="assertTextEquals" path="BLOGS_ENTRY_LINK_STATUS_1" value="Approved" />
		<action name="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_ACTIONS_1" value="Actions" />
		<action name="CPBlogsHome" command="click" path="BLOGS_ENTRY_LINK_ACTIONS_DELETE" value="Move to the Recycle Bin" />
		<action name="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_SUCCESS_UNDO" value="The selected item was moved to the Recycle Bin. Undo" />
		<action name="CPBlogsHome" command="assertTextEquals" path="PORTLET_TEXT_INFO" value="No entries were found." />
		<action name="CPBlogsHome" command="assertTextNotPresent" value="&lt;!-- --&gt;" />
		<action name="CPBlogsHome" command="assertTextNotPresent" value="Blogs Entry Content" />
	</steps>
	<teardown>
		<macro name="CPBlogsEntry" command="tearDown" />
		<macro name="CPRecycleBin" command="empty" />
	</teardown>
</test>