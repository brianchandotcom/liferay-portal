<test
	name="AddDMDocumentType"
	description="In the Control Panel Documents and Media Portlet, add a Document Type."
>
	<setup>
	</setup>
	<steps>
		<macro name="CPDocumentsAndMediaDocumentType" command="add">
			<param name="name" value="DM DocumentType Name" />
		</macro>

		<macro name="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Documents and Media" />
		</macro>

		<action name="CPDocumentsAndMediaHome" command="click" path="TOOLBAR_ADD_BUTTON" value="Add" />
		<action name="CPDocumentsAndMediaHome" command="assertTextEquals" locator="//a[contains(.,'DM DocumentType Name') and @role='menuitem']" value="DM DocumentType Name" />
	</steps>
	<teardown>
		<macro name="CPDocumentsAndMediaDocumentType" command="tearDown" />
		<macro name="CPRecycleBin" command="empty" />
	</teardown>
</test>