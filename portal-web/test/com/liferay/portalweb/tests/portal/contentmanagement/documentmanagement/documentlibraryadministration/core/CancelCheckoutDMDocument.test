<test
	name="CancelCheckoutDMDocument"
	description="In the Control Panel Documents and Media Portlet, ensure that the cancel the checkout of a Document will remove any changes made while checked out."
>
	<setup>
		<macro object="CPDocumentsAndMediaDocument" command="add">
			<param name="title" value="DM Document Title" />
			<param name="file" value="Document_1.doc" />
		</macro>

		<macro object="CPDocumentsAndMediaDocument" command="checkout">
			<param name="title" value="DM Document Title" />
		</macro>

		<macro object="CPDocumentsAndMediaDocument" command="editCheckout">
			<param name="oldTitle" value="DM Document Title"  />
			<param name="newTitle" value="DM Document Title Edit"  />
		</macro>
	</setup>
	<steps>
		<macro object="Goto" command="controlPanelPortlet">
			<param name="portlet" value="Documents and Media" />
		</macro>

		<action object="CPDocumentsAndMediaHome" command="assertElementPresent" target="DOCUMENT_IMAGE_LOCK" />
		<action object="CPDocumentsAndMediaHome" command="assertTextEquals" target="DOCUMENT_NAME" value="DM Document Title (Draft)" />

		<action object="CPDocumentsAndMediaHome" command="click" target="DOCUMENT_ACTIONS" />
		<action object="CPDocumentsAndMediaHome" command="click" target="DOCUMENT_ACTIONS_CANCEL_CHECKOUT" value="Cancel Checkout" />
		<action object="CPDocumentsAndMediaHome" command="assertTextEquals" target="HEADER_SUCCESS_MESSAGE" value="Your request completed successfully." />

		<action object="CPDocumentsAndMediaHome" command="assertElementNotPresent" target="DOCUMENT_IMAGE_LOCK" />
		<action object="CPDocumentsAndMediaHome" command="assertTextEquals" target="DOCUMENT_NAME" value="DM Document Title" />

		<action object="CPDocumentsAndMediaHome" command="click" target="DOCUMENT_NAME" value="DM Document Title" />

		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_INFO_WORKFLOW_STATUS" value="Status: Approved" />
		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_HISTORY_VERSION_1" value="1.0" />
		<action object="CPDocumentsAndMediaDocument" command="assertTextEquals" target="VERSION_HISTORY_STATUS_1" value="Approved" />

		<action object="CPDocumentsAndMediaDocument" command="assertElementNotPresent" target="VERSION_HISTORY_VERSION_2" />
		<action object="CPDocumentsAndMediaDocument" command="assertElementNotPresent" target="VERSION_HISTORY_STATUS_2" />
	</steps>
	<teardown>
		<macro object="CPDocumentsAndMediaDocument" command="tearDown" />
		<macro object="CPRecycleBin" command="empty" />
	</teardown>
</test>