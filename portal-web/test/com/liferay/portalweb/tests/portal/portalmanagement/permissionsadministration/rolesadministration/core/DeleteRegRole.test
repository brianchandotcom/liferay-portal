<test
	name="DeleteSiteRole"
	description="In the &lt;strong&gt;Control Panel Roles Portlet&lt;/strong&gt;, delete a Regular Role."
>
	<setup>
		<macro object="CPRoles" command="addRegRole">
			<param name="name" value="Regrole Name " />
			<param name="title" value="Regrole Title" />
			<param name="description" value="Regrole Description" />
		</macro>
	</setup>
	<steps>
		<macro object="CPRoles" command="delete">
			<param name="title" value="Regrole Title" />
		</macro>
	</steps>
	<teardown>
		<macro object="CPRoles" command="tearDown" />
	</teardown>
</test>