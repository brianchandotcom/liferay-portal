<test
	name="AddWCWebContentCP"
	description="In the &lt;strong&gt;Control Panel Web Content Portlet&lt;/strong&gt;, add a Web Content Article."
>
	<setup>
	</setup>
	<steps>
		<macro name="CPWebContentArticle" command="addCPWebContent">
			<param name="title" value="WC WebContent Title" />
			<param name="content" value="WC WebContent Content" />
		</macro>

		<action name="CPWebContentHome" command="click" path="ENTRIES_ARTICLE_1" value="WC WebContent Title" />

		<action name="CPWebContentEditWebContent" command="assertTextEquals" path="ARTICLE_TITLE" value="WC WebContent Title" />
		<action name="CPWebContentEditWebContent" command="assertTextEquals" path="ARTICLE_CONTENT" value="WC WebContent Content" />
	</steps>
	<teardown>
		<macro name="CPWebContentArticle" command="tearDownCPWebContent" />
	</teardown>
</test>