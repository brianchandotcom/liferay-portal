<macros object="User">
	<macrodef
		command="pgSignIn"
		description="Log into the portal as ${email} with the password ${password}."
	>
		<params>
			<param name="email" description="User's email address" example="test@liferay.com" />
			<param name="password" description="User's password" example="test" />
		</params>
		<steps>
			<action object="PgSignin" command="open" target="/web/guest/home/" />
			<action object="PgSignin" command="type" target="HOME_EMAIL_ADDRESS_FIELD" value="${email}" />
			<action object="PgSignin" command="type" target="HOME_PASSWORD_FIELD" value="${password}" />
			<action object="PgSignin" command="click" target="HOME_REMEMBER_ME_CHECKBOX" />
			<action object="PgSignin" command="click" target="HOME_SIGN_IN_BUTTON" value="Sign In" />
		</steps>
	</macrodef>

	<macrodef
		command="pgSignInFirst"
		description="Log into the portal for the first time as ${email} with the password ${password} and reset the password to ${newPassword}."
	>
		<params>
			<param name="email" description="User's email address" example="test@liferay.com" />
			<param name="password" description="User's password" example="password" />
			<param name="newPassword" description="User's new password" example="test" />
		</params>
		<steps>
			<macro object="User" command="pgSignIn">
				<param name="email" value="${email}" />
				<param name="password" value="${password}" />
			</macro>

			<if object="PgSignin" command="isElementPresent" target="TOS_I_AGREE_BUTTON">
				<action object="PgSignin" command="click" target="TOS_I_AGREE_BUTTON" value="I Agree" />
			</if>

			<if object="PgSignin" command="isElementPresent" target="NEW_HOME_PASSWORD_FIELD">
				<action object="PgSignin" command="type" target="NEW_HOME_PASSWORD_FIELD" value="${newPassword}" />
				<action object="PgSignin" command="type" target="NEW_PASSWORD_ENTER_AGAIN_FIELD" value="${newPassword}" />
				<action object="PgSignin" command="click" target="NEW_PASSWORD_SAVE_BUTTON" value="Save" />
			</if>

			<if object="PgSignin" command="isElementPresent" target="REMINDER_ANSWER_FIELD">
				<action object="PgSignin" command="type" target="REMINDER_ANSWER_FIELD" value="test" />
				<action object="PgSignin" command="click" target="REMINDER_SAVE_BUTTON" value="Save" />
			</if>
		</steps>
	</macrodef>

	<macrodef
		command="pgSignInSA"
		description="Log into the portal as SA user test@liferay.com with the password test. Log out first if already signed in as another user, or do nothing if already signed in as the default user."
	>
		<params>
		</params>
		<steps>
			<action object="PgSignin" command="open" target="/web/guest/home/" />

			<if object="PgSignin" command="isElementPresent" target="USER_NAME_LINK">
				<if object="PgSignin" command="isTextNotEqual" target="USER_NAME_LINK" value="Test Test">
					<macro object="User" command="pgSignOut" />
				</if>
			</if>

			<action object="PgSignin" command="open" target="/web/guest/home/" />

			<if object="PgSignin" command="isElementPresent" target="HOME_EMAIL_ADDRESS_FIELD">
				<macro object="User" command="pgSignIn">
					<param name="email" value="test@liferay.com" />
					<param name="password" value="test" />
				</macro>

				<if object="PgSignin" command="isElementPresent" target="TOS_I_AGREE_BUTTON">
					<action object="PgSignin" command="click" target="TOS_I_AGREE_BUTTON" value="I Agree" />
				</if>

				<if object="PgSignin" command="isElementPresent" target="REMINDER_ANSWER_FIELD">
					<action object="PgSignin" command="type" target="REMINDER_ANSWER_FIELD" value="test" />
					<action object="PgSignin" command="click" target="REMINDER_SAVE_BUTTON" value="Save" />
				</if>

				<action object="PgSignin" command="assertTextEquals" target="HOME_SIGNED_IN_AS" value="You are signed in as Test Test." />
			</if>
		</steps>
	</macrodef>

	<macrodef
		command="pgSignOut"
		description="Log out of the portal."
	>
		<params>
		</params>
		<steps>
			<action object="PgSignin" command="open" target="/web/guest/home/" />
			<action object="PgSignin" command="click" target="SIGN_OUT_LINK" value="Sign Out" />
		</steps>
	</macrodef>
</macros>