<definition default="highlightValue" summary="Selecting all text at '${locator1}'">
	<command name="highlightValue">
		<execute function="Click" />

		<execute selenium="highlightAll" />

		<execute selenium="assertJavaScriptErrors" />

		<execute selenium="assertLiferayErrors" />
	</command>

	<command name="highlightValueNoError">
		<execute function="Click" />

		<execute selenium="highlight" />
	</command>
</definition>