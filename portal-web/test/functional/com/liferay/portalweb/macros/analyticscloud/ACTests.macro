definition {

	@summary = "Default summary"
	macro deleteABTest(testName = null) {
		if (isSet(testName)) {
			ACNavigation.openItem(itemName = ${testName});
		}

		Button.clickDelete();

		SelectWindow(locator1 = "name=undefined");

		Click(locator1 = "ACSettings#CONFIRMATION_BUTTON");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro statusABTest(status = null) {
		AssertTextEquals(
			locator1 = "ACTests#LABEL_STATUS",
			value1 = ${status});
	}

	@summary = "Default summary"
	macro terminateABTest(testName = null) {
		if (isSet(testName)) {
			ACNavigation.openItem(itemName = ${testName});
		}

		Button.click(button = "Terminate");

		SelectWindow(locator1 = "name=undefined");

		Click(locator1 = "ACSettings#CONFIRMATION_BUTTON");

		Alert.viewSuccessMessage();
	}

		Button.click(button = "Terminate Test");

		Button.click(button = "Stop Test");
	}
}