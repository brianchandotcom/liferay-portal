definition {

	@summary = "Default summary"
	macro clickGenericHyperlink(hyperlinkText = null) {
		var key_textValue = ${hyperlinkText};

		if (!(isSet(index))) {
			var index = 1;
		}

		Click(locator1 = "ACUtils#GENERIC_TEXT_ORDER");
	}

	@summary = "Default summary"
	macro clickToAssignSitesAndChannel(propertyName = null) {
		Click(
			key_propertyName = ${propertyName},
			locator1 = "ACUtils#SYNC_ANY_PROPERTIES");

		WaitForPageLoad();
	}

	@summary = "Default summary"
	macro connectAnalyticsCloud(acToken = null, staticExistingSourceToken = null) {
		ACUtils.disconnectDXPFromAnalyticsCloud();

		Click(locator1 = "ACUtils#TOKEN_INPUT_FIELD");

		if (isSet(acToken)) {
			Type(
				locator1 = "ACUtils#TOKEN_INPUT_FIELD",
				value1 = ${acToken});
		}
		else if (isSet(staticExistingSourceToken)) {
			Type(
				locator1 = "ACUtils#TOKEN_INPUT_FIELD",
				value1 = ${staticExistingSourceToken});
		}
		else {
			Type.sendKeys(
				locator1 = "ACUtils#TOKEN_INPUT_FIELD",
				value1 = "keys=CONTROL,v");
		}

		WaitForElementNotPresent(locator1 = "ACUtils#CONNECT_BUTTON_DISABLED");

		Click(locator1 = "ACUtils#CONNECT_BUTTON");

		WaitForVisible(
			key_text = "Next",
			locator1 = "Button#ANY");

		WaitForElementNotPresent(locator1 = "ACUtils#LOADING_ANIMATION");
	}

	@summary = "Default summary"
	macro connectDXPtoAnalyticsCloud() {
		ACUtils.connectAnalyticsCloud();

		var assignedPropertyName = ACUtils.getAssignedPropertyName();

		ACUtils.syncSites(
			propertyName = ${assignedPropertyName},
			siteName = "Guest");

		Click(
			key_text = "Next",
			locator1 = "Button#ANY");

		ACUtils.syncContactsAndAccountstData();

		Click(locator1 = "ACUtils#AC_GENERIC_ADD_OR_CONFIRMATION_BUTTON");

		Click(locator1 = "ACUtils#AC_GENERIC_ADD_OR_CONFIRMATION_BUTTON");

		return ${assignedPropertyName};
	}

	@summary = "Default summary"
	macro createNewProperty(newPropertyNameList = null) {
		for (var newPropertyName : list ${newPropertyNameList}) {
			Click(
				ariaLabel = "Create a New Property",
				locator1 = "Button#ANY_WITH_ARIA_LABEL");

			Type(
				locator1 = "ACUtils#NEW_PROPERTY_NAME",
				value1 = ${newPropertyName});

			Click(
				key_text = "Create",
				locator1 = "Button#ANY");

			WaitForElementNotPresent(locator1 = "Modal#MODAL_CONTENT");
		}
	}

	@summary = "Default summary"
	macro disconnectDXPFromAnalyticsCloud() {
		ACUtils.goToInstanceSettingsAC();

		if (IsElementPresent(locator1 = "ACUtils#DISCONNECT_BUTTON")) {
			ClickNoError(locator1 = "ACUtils#DISCONNECT_BUTTON");

			Click(locator1 = "ACUtils#DISCONNECT_CONFIRMATION_BUTTON");
		}
	}

	@summary = "Default summary"
	macro dismissOnboardingModal() {
		if (IsElementPresent(locator1 = "ACUtils#MODAL_SCREEN")) {
			Click(locator1 = "ACUtils#CLOSE_ONBOARDING_MODAL");
		}
	}

	@summary = "Default summary"
	macro getAssignedPropertyName() {
		WaitForVisible(
			key_text = "Assign",
			locator1 = "Button#ANY");

		static var assignedPropertyName = selenium.getText("ACUtils#FIRST_AVAILABLE_PROPERTY");

		if (${assignedPropertyName} == "Beryl Commerce") {
			static var assignedPropertyName = selenium.getText("ACUtils#SECOND_AVAILABLE_PROPERTY");
		}

		return ${assignedPropertyName};
	}

	@summary = "Default summary"
	macro goToInstanceSettingsAC() {
		PortalSettings.openInstanceSettingsAdmin();

		Click(locator1 = "ACUtils#ANALYTICS_CLOUD_DXP_OPTION");
	}

	@summary = "Default summary"
	macro launchAC() {
		var analyticsCloudURL = PropsUtil.get("analytics.cloud.url");

		Open(value1 = ${analyticsCloudURL});

		WaitForPageLoad();

		var emailAddress = "test@liferay.com";

		if ((IsElementNotPresent(locator1 = "ACUtils#EMAIL_LOGIN_FIELD")) || (IsElementNotPresent(locator1 = "ACUtils#FARO_DEMO_WORKSPACE"))) {
			Refresh();

			WaitForPageLoad();
		}

		if (IsElementPresent(locator1 = "ACUtils#EMAIL_LOGIN_FIELD")) {
			ACUtils.loginAs(emailAddress = ${emailAddress});
		}

		WaitForPageLoad();

		ACUtils.waitForLoading();

		if ((IsElementNotPresent(locator1 = "ACUtils#EMAIL_LOGIN_FIELD")) || (IsElementNotPresent(locator1 = "ACUtils#FARO_DEMO_WORKSPACE"))) {
			Refresh();

			WaitForPageLoad();

			ACUtils.waitForLoading();
		}

		if (IsElementNotPresent(locator1 = "ACUtils#FARO_DEMO_WORKSPACE")) {
			ACUtils.loginAs(
				emailAddress = ${emailAddress},
				password = "test1");
		}

		ACUtils.openWorkspace();
	}

	@summary = "Default summary"
	macro launchDXP() {
		Navigator.openURL();

		if (!(isSet(userEmailAddress))) {
			var userEmailAddress = "test@liferay.com";
		}

		if (IsElementNotPresent(locator1 = "ApplicationsMenu#APPLICATIONS_MENU")) {
			User.firstLoginPG(userEmailAddress = ${userEmailAddress});
		}
	}

	@summary = "Default summary"
	macro loginAs(emailAddress = null) {
		var faroEmailAddress = PropsUtil.get("analytics.cloud.faro.user.login");

		WaitForPageLoad();

		if (${faroEmailAddress} != "null") {
			var faroPassword = PropsUtil.get("analytics.cloud.faro.password");
			var emailAddress = ${faroEmailAddress};
			var password = ${faroPassword};
		}
		else if (!(isSet(password))) {
			var password = PropsUtil.get("default.admin.password");
		}

		Click(locator1 = "ACUtils#EMAIL_LOGIN_FIELD");

		Type(
			locator1 = "ACUtils#EMAIL_LOGIN_FIELD",
			value1 = ${emailAddress});

		Click(locator1 = "ACUtils#PASSWORD_LOGIN_FIELD");

		Type(
			locator1 = "ACUtils#PASSWORD_LOGIN_FIELD",
			value1 = ${password});

		Click(locator1 = "ACUtils#LOGIN_BUTTON");
	}

	@summary = "Default summary"
	macro openWorkspace(workspaceName = null) {
		var faroWorkspaceName = PropsUtil.get("analytics.cloud.faro.workspace.name");

		if (${faroWorkspaceName} != "null") {
			var key_workspaceName = ${faroWorkspaceName};

			Click(locator1 = "ACUtils#WORKSPACE_NAME");
		}
		else if (isSet(workspaceName)) {
			var key_workspaceName = ${workspaceName};

			Click(locator1 = "ACUtils#WORKSPACE_NAME");
		}
		else if (!(isSet(workspaceName))) {
			Click(locator1 = "ACUtils#FARO_DEMO_WORKSPACE");
		}

		ACUtils.dismissOnboardingModal();
	}

	@summary = "Default summary"
	macro searchACItemInAssignModal(searchItem = null) {
		Click(locator1 = "ACUtils#SYNCED_SITES_SEARCH_FIELD");

		Type(
			locator1 = "ACUtils#SYNCED_SITES_SEARCH_FIELD",
			value1 = ${searchItem});

		KeyPress(
			locator1 = "ACUtils#SYNCED_SITES_SEARCH_FIELD",
			value1 = "\ENTER");
	}

	@summary = "Default summary"
	macro switchTab(tabName = null) {
		var key_tab = ${tabName};

		Click(locator1 = "Modal#TAB_LINK");
	}

	@summary = "Default summary"
	macro syncContactsAndAccountstData() {
		if (IsElementPresent(index = 1, locator1 = "ACUtils#TOGGLE_ICON_ENABLE")) {
			Check.checkToggleSwitch(locator1 = "ACUtils#TOGGLE_ICON");
		}

		Check.checkToggleSwitch(locator1 = "ACUtils#TOGGLE_ICON");
	}

	@summary = "Default summary"
	macro syncSites(newPropertyName = null, siteName = null) {
		if (isSet(newPropertyName)) {
			ACUtils.createNewProperty(newPropertyNameList = ${newPropertyName});

			var propertyName = ${newPropertyName};
		}

		ACUtils.clickToAssignSitesAndChannel(propertyName = ${propertyName});

		ACUtils.switchTab(tabName = "Sites");

		if (isSet(siteName)) {
			ACUtils.searchACItemInAssignModal(searchItem = ${siteName});
		}

		Click.clickAtNotVisible(locator1 = "ACUtils#AC_GENERIC_CHECKBOX");

		Click(
			key_name = "Assign",
			locator1 = "Button#GENERAL_BUTTON_MODAL_FOOTER");

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro takeTokenFromAnalyticsCloud() {
		if (IsElementNotPresent(locator1 = "ACUtils#SETTINGS_PAGE")) {
			var key_sidebarOption = "settings";

			WaitForVisible(locator1 = "ACUtils#GENERIC_SIDEBAR_OPTION");

			Click(locator1 = "ACUtils#GENERIC_SIDEBAR_OPTION");
		}

		var key_settingsNavigation = "data-source";

		Click(locator1 = "ACUtils#SETTINGS_NAVIGATION");

		Click(locator1 = "ACUtils#AC_GENERIC_ADD_OR_CONFIRMATION_BUTTON");

		Click(locator1 = "ACUtils#DXP_DATA_SOURCE_OPTION");

		Click(locator1 = "ACUtils#COPY_TOKEN_BUTTON");
	}

	@summary = "Default summary"
	macro waitForLoading() {
		WaitForElementNotPresent(locator1 = "ACUtils#LOADING_ANIMATION");
	}

}