definition {

	@summary = "Default summary"
	macro expandCategory(category = null) {
		if (IsElementPresent(key_category = ${category}, locator1 = "ApplicationsMenu#COLLAPSED_CATEGORY")) {
			Click(
				key_category = ${category},
				locator1 = "ApplicationsMenu#COLLAPSED_CATEGORY");

			WaitForElementNotPresent(
				key_category = ${category},
				locator1 = "ApplicationsMenu#COLLAPSED_CATEGORY");
		}
	}

	@summary = "Default summary"
	macro gotoPanel(panel = null) {
		ApplicationsMenuHelper.openApplicationsMenu();

		Click(
			key_panel = ${panel},
			locator1 = "ApplicationsMenu#PANEL");

		WaitForElementPresent(locator1 = "ApplicationsMenu#SIDE_NAVIGATION");
	}

	@summary = "Default summary"
	macro gotoPortlet(portlet = null, panel = null, category = null) {
		ApplicationsMenu.gotoPanel(panel = ${panel});

		ApplicationsMenu.expandCategory(category = ${category});

		ApplicationsMenuHelper.gotoPortlet(
			category = ${category},
			portlet = ${portlet});
	}

	@summary = "Default summary"
	macro gotoSite(site = null) {
		ApplicationsMenuHelper.openApplicationsMenu();

		if (IsElementPresent(key_site = ${site}, locator1 = "ApplicationsMenu#SITE_LINK")) {
			Click(
				key_site = ${site},
				locator1 = "ApplicationsMenu#SITE_LINK");
		}
		else if (IsElementPresent(locator1 = "ApplicationsMenu#VIEW_ALL_LINK")) {
			Click(locator1 = "ApplicationsMenu#VIEW_ALL_LINK");

			SelectFrame(locator1 = "IFrame#MODAL_BODY");

			Navigator.gotoNavItem(navItem = "All Sites");

			SiteSelector.selectSite(site = ${site});
		}
		else {
			ApplicationsMenuHelper.closeApplicationsMenu();

			Navigator.openSiteURL(siteName = ${site});
		}
	}

}