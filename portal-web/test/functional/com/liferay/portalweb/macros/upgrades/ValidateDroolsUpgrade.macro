definition {

	@summary = "Default summary"
	macro viewDroolsAppManager() {
		AppManager.openAppManagerAdmin();

		AppManager.viewApp(
			appName = "Liferay Drools",
			appStatus = "Active",
			searchTerm = "Drools");

		AppManager.viewApp(
			appName = "Liferay Portal Rules Engine Drools",
			appStatus = "Active",
			searchTerm = "Drools");
	}

}