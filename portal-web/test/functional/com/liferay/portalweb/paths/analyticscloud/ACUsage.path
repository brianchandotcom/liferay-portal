<html>
<head>
<title>ACUsage</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">ACUsage</td></tr>
</thead>

<tbody>
<tr>
	<td>USAGE_ADDONS_LIMITS</td>
	<td>//h4[contains(.,'Add-ons')]/..//b[contains(@class,'details-label')and contains(.,'${key_planName}')]/../..//span[contains(@class,'limit-amount') and contains(.,'${key_planLimit}')]</td>
	<td></td>
</tr>
<tr>
	<td>USAGE_ADDONS_PRICE</td>
	<td>//b[contains(@class,'details-label')and contains(.,'${key_planName}')]/../../../..//div[contains(@class,'annual-price') and contains(.,'${key_planValue}')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>