<html>
<head>
<title>ACUtils</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">ACUtils</td></tr>
</thead>

<tbody>
<tr>
	<td>GENERIC_TEXT_ORDER</td>
	<td>xpath=(//*[normalize-space(text())='${key_textValue}'])[${index}]</td>
	<td></td>
</tr>
<tr>
	<td>TOGGLE_ICON</td>
	<td>//*[contains(@class, 'toggle-switch-check')]</td>
	<td></td>
</tr>
<tr>
	<td>LOADING_ANIMATION</td>
	<td>//span[contains(@class,'loading-animation')]</td>
	<td></td>
</tr>

<!-- GENERIC ADD OR CONFIRMATION BUTTON -->

<tr>
	<td>AC_GENERIC_ADD_OR_CONFIRMATION_BUTTON</td>
	<td>//*[contains(@class, 'btn-primary')]</td>
	<td></td>
</tr>
<tr>
	<td>MODAL_SCREEN</td>
	<td>//div[contains(@class,'onboarding-base-screen-root')]</td>
	<td></td>
</tr>
<tr>
	<td>CLOSE_ONBOARDING_MODAL</td>
	<td>//button[contains(@class,'close')]</td>
	<td></td>
</tr>
<tr>
	<td>WORKSPACE_NAME</td>
	<td>//*[contains(@class,'workspace-name')]//span[contains(text(),'${key_workspaceName}')]</td>
	<td></td>
</tr>

<!-- LOGIN SCREEN FIELDS -->

<tr>
	<td>EMAIL_LOGIN_FIELD</td>
	<td>//input[contains(@id, '_com_liferay_login_web_portlet_LoginPortlet_login')]</td>
	<td></td>
</tr>
<tr>
	<td>LOGIN_BUTTON</td>
	<td>//*[contains(@class, 'btn-primary')]</td>
	<td></td>
</tr>
<tr>
	<td>PASSWORD_LOGIN_FIELD</td>
	<td>//*[contains(@id, '_com_liferay_login_web_portlet_LoginPortlet_password')]</td>
	<td></td>
</tr>

<!-- SETTINGS -->

<tr>
	<td>COPY_TOKEN_BUTTON</td>
	<td>//button[@aria-label='Click to Copy']</td>
	<td></td>
</tr>
<tr>
	<td>DXP_DATA_SOURCE_OPTION</td>
	<td>//button[contains(@class,'dropdown-item') and contains(text(),'Liferay DXP')]</td>
	<td></td>
</tr>
<tr>
	<td>SETTINGS_NAVIGATION</td>
	<td>//*[@class='button-root' and contains(@href,'${key_settingsNavigation}')]</td>
	<td></td>
</tr>
<tr>
	<td>SETTINGS_PAGE</td>
	<td>//h2[text()='Settings']</td>
	<td></td>
</tr>

<!-- SIDEBAR FIELDS/OPTIONS -->

<tr>
	<td>GENERIC_SIDEBAR_OPTION</td>
	<td>//*[contains(@class,'sidebar-item-root')]//*[contains(@href,'${key_sidebarOption}')]</td>
	<td></td>
</tr>

<!-- SYNCS SITES TO PROPERTY SCREEN -->

<tr>
	<td>FIRST_AVAILABLE_PROPERTY</td>
	<td>//td[@class='table-column-text-start']</td>
	<td></td>
</tr>
<tr>
	<td>SECOND_AVAILABLE_PROPERTY</td>
	<td>//tr[2]/td[@class='table-column-text-start']</td>
	<td></td>
</tr>
<tr>
	<td>TOGGLE_ICON_ENABLE</td>
	<td>xpath=(//input[contains(@data-testid,'true')])[${index}]</td>
	<td></td>
</tr>

<!-- WORKSPACE LIST SCREEN FIELDS -->

<tr>
	<td>FARO_DEMO_WORKSPACE</td>
	<td>//*[contains(@class, 'workspace-link')]</td>
	<td></td>
</tr>
<tr>
	<td>AC_GENERIC_CHECKBOX</td>
	<td>//div[contains(@class,'fade show')]//*[contains(@type, 'checkbox')]</td>
	<td></td>
</tr>
<tr>
	<td>ANALYTICS_CLOUD_DXP_OPTION</td>
	<td>//*[contains(@href, 'analytics-cloud-connection')]</td>
	<td></td>
</tr>
<tr>
	<td>CONNECT_BUTTON</td>
	<td>//button[@type='button' and text()='Connect']</td>
	<td></td>
</tr>
<tr>
	<td>CONNECT_BUTTON_DISABLED</td>
	<td>//button[@disabled='' and contains(@class,'btn-primary')]</td>
	<td></td>
</tr>
<tr>
	<td>DISCONNECT_BUTTON</td>
	<td>//button[@type='button' and text()='Disconnect']</td>
	<td></td>
</tr>
<tr>
	<td>DISCONNECT_CONFIRMATION_BUTTON</td>
	<td>//button[contains(@class,'btn-warning') and text()='Disconnect']</td>
	<td></td>
</tr>
<tr>
	<td>NEW_PROPERTY_NAME</td>
	<td>//input[@id='inputPropertyName']</td>
	<td></td>
</tr>
<tr>
	<td>SYNC_ANY_PROPERTIES</td>
	<td>//tr[@data-testid='${key_propertyName}']//button[@role='assign-button']</td>
	<td></td>
</tr>
<tr>
	<td>SYNCED_SITES_SEARCH_FIELD</td>
	<td>//div[contains(@class,'active')]//input[@aria-label='Search']</td>
	<td></td>
</tr>
<tr>
	<td>TOKEN_INPUT_FIELD</td>
	<td>//input[contains(@id,'inputToken')]</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>