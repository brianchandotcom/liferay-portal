<html>
<head>
<title>ApplicationsMenu</title>
</head>

<body>
<table border="1" cellpadding="1" cellspacing="1">
<thead>
<tr><td rowspan="1" colspan="3">ApplicationsMenu</td></tr>
</thead>

<tbody>
<tr>
	<td>CATEGORY</td>
	<td>//div[@data-qa-id='sideNavigation']//ul[@role='menubar']//button[@role='menuitem' and normalize-space()='${key_category}']</td>
	<td></td>
</tr>
<tr>
	<td>COLLAPSED_CATEGORY</td>
	<td>//div[@data-qa-id='sideNavigation']//ul[@role='menubar']//button[@role='menuitem' and normalize-space()='${key_category}' and @aria-expanded='false']</td>
	<td></td>
</tr>
<tr>
	<td>APPLICATIONS_MENU</td>
	<td>//div[contains(@class, 'global-menu') and contains(@class, 'show')]</td>
	<td></td>
</tr>
<tr>
	<td>PANEL</td>
	<td>//ul[@role='menu' and contains(@class, 'categories-list')]//a[@role='menuitem' and normalize-space()='${key_panel}']</td>
	<td></td>
</tr>
<tr>
	<td>PORTLET</td>
	<td>//div[@data-qa-id='sideNavigation']//ul[@role='menubar']//button[@role='menuitem' and contains(., '${key_category}')]/following-sibling::ul//a[@role='menuitem' and normalize-space()='${key_portlet}']</td>
	<td></td>
</tr>
<tr>
	<td>SIDE_NAVIGATION</td>
	<td>//div[@data-qa-id='sideNavigation']</td>
	<td></td>
</tr>
<tr>
	<td>SITE_LINK</td>
	<td>//ul[@role='menu' and contains(@class, 'sites-list')]//a[normalize-space(text())='${key_site}']</td>
	<td></td>
</tr>
<tr>
	<td>TOGGLE</td>
	<td>//button[@data-qa-id='globalMenu']</td>
	<td></td>
</tr>
<tr>
	<td>VIEW_ALL_LINK</td>
	<td>//ul[@role='menu' and contains(@class, 'sites-list')]//button[@role='menuitem' and contains(.,'View All')]</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>