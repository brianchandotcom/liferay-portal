<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<title>PgSignin</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">PgSignin</td></tr>
</thead><tbody>
<tr>
	<td>PAGE_NAME</td>
	<td></td>
	<td>Portlet Sign In Home Page</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--HOME-->
<tr>
	<td>HOME_EMAIL_ADDRESS_FIELD</td>
	<td>//input[@id='_58_login']</td>
	<td>Email Address Field</td>
</tr>
<tr>
	<td>HOME_PASSWORD_FIELD</td>
	<td>//input[@id='_58_password']</td>
	<td>Password Field</td>
</tr>
<tr>
	<td>HOME_REMEMBER_ME_CHECKBOX</td>
	<td>//input[@id='_58_rememberMeCheckbox']</td>
	<td>Remember Me Checkbox</td>
</tr>
<tr>
	<td>HOME_SIGN_IN_BUTTON</td>
	<td>//input[@value='Sign In']</td>
	<td>Sign In Button</td>
</tr>
<tr>
	<td>HOME_SIGNED_IN_AS</td>
	<td>//div[@class='portlet-body']</td>
	<td>Portlet Body</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--TOS-->
<tr>
	<td>TOS_I_AGREE_BUTTON</td>
	<td>//input[@value='I Agree']</td>
	<td>I Agree Button</td>
</tr>
<tr>
	<td>TOS_I_DISAGREE_BUTTON</td>
	<td>//input[@value='I Disagree']</td>
	<td>I Disagree Button</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--REMINDER-->
<tr>
	<td>REMINDER_ANSWER_FIELD</td>
	<td>//input[@id='reminderQueryAnswer']</td>
	<td>Reminder Question Answer Field</td>
</tr>
<tr>
	<td>REMINDER_QUESTION_FIELD</td>
	<td>//select[@id='reminderQueryQuestion']</td>
	<td>Reminder Question Selection Field</td>
</tr>
<tr>
	<td>REMINDER_SAVE_BUTTON</td>
	<td>//input[@value='Save']</td>
	<td>Save</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--NEW_PASSWORD-->
<tr>
	<td>NEW_PASSWORD_FIELD</td>
	<td>//input[@id='password1']</td>
	<td>New Password</td>
</tr>
<tr>
	<td>NEW_PASSWORD_ENTER_AGAIN_FIELD</td>
	<td>//input[@id='password2']</td>
	<td>Enter New Password Again</td>
</tr>
<tr>
	<td>NEW_PASSWORD_SAVE_BUTTON</td>
	<td>//input[@value='Save']</td>
	<td>Save</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--SIGN_OUT-->
<tr>
	<td>SIGN_OUT_LINK</td>
	<td>//span[@class='sign-out']/a</td>
	<td>Sign Out</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--USER_NAME-->
<tr>
	<td>USER_NAME_LINK</td>
	<td>//span[@class='user-full-name']</td>
	<td>Sign In</td>
</tr>
</tbody></table>
</body>
</html>