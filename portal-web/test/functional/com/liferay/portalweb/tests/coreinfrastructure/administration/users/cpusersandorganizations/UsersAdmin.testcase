	@description = "This is a use case for LRQA-68315 and LPS-176074 TC-3. This test asserts that a user can update the password changed notification subject and body. The notification also send when set password via json."
	@priority = 3
	test ViewPasswordChangedNotificationTemplateUpdated {
		property osgi.module.configuration.file.names = "com.liferay.mail.settings.configuration.MailSettingSystemConfiguration.config";
		property osgi.module.configurations = "sendBlacklist=[\"noreply@liferay.com\",\"noreply@domain.invalid\",\"test@domain.invalid\"]";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";
		property test.smtp.server.enabled = "true";

		task ("Given: Add the user's first name in the password changed notification template") {
			var portalURL = PropsUtil.get("portal.url");

			Navigator.openURL();

			PortalSettings.viewEmailNotificationsPasswordChangedNotificationCP();

			PortalSettings.gotoConfiguration(
				configurationCategory = "Email",
				configurationName = "Email Sender",
				configurationScope = "Virtual Instance Scope");

			PortalSettings.configureEmailSender(
				emailAddress = "test@liferay.com",
				emailSenderName = "Joe Bloggs");

			PortalSettings.editConfigurationUsersEmailNotificationsCP(
				configurationName = "Password Changed Notification",
				notificationsBody = '''
					Dear [$TO_FIRST_NAME$]/[$TO_NAME$],<br /><br />

					This is a new template for [$TO_FIRST_NAME$] password change test.<br /><br />

					Your([$TO_FIRST_NAME$]) password for [$PORTAL_URL$] has been changed.<br /><br />

					The request from [$TO_FIRST_NAME$] for a new password was made from [$REMOTE_ADDRESS$] / [$REMOTE_HOST$].<br /><br />

					Sincerely,<br />
					[$FROM_NAME$]<br />
					[$FROM_ADDRESS$]<br />
					[$PORTAL_URL$]
				''',
				notificationsSubject = "[$PORTAL_URL$]: Dear [$TO_FIRST_NAME$], your Password Has Been Changed");
		}

		task ("When: Add a new user and change password") {
			User.openUsersAdmin();

			User.addCP(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			User.openUsersAdmin();

			User.editPasswordCP(
				userEmailAddress = "userea@liferay.com",
				userScreenName = "usersn");
		}

		task ("Then: Assert the subject, salutation and each paragraph in the body of the Password Changed Notification are include user's first name") {
			MockMock.viewMail(
				asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				content = "This is a new template for userfn password change test.",
				recipient = "userfn userln",
				sender = "Joe Bloggs",
				subject = "${portalURL}: Dear userfn, your Password Has Been Changed");

			MockMock._gotoMailMessage(
				asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				recipient = "userfn userln");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Dear userfn/userfn userln,");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Your(userfn) password for ${portalURL} has been changed.");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Dear userfn, your Password Has Been Changed",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "The request from userfn for a new password");
		}
	}

