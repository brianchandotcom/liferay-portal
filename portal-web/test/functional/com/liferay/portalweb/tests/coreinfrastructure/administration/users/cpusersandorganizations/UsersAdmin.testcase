	@description = "This is a use case for LPS-176074. TC-2: Email verification notification template could be set to include user's first name."
	@priority = 4
	test ViewEmailVerificationNotificationTemplateUpdated {
		property custom.properties = "company.security.strangers.verify=true${line.separator}jsonws.web.service.paths.excludes=";
		property osgi.module.configuration.file.names = "com.liferay.mail.settings.configuration.MailSettingSystemConfiguration.config";
		property osgi.module.configurations = "sendBlacklist=[\"noreply@liferay.com\",\"noreply@domain.invalid\",\"test@domain.invalid\"]";
		property test.liferay.virtual.instance = "false";
		property test.run.type = "single";
		property test.smtp.server.enabled = "true";

		task ("Given: Add a new user and add the user's first name in the email verification notification template") {
			var portalURL = PropsUtil.get("portal.url");

			PortalSettings.openInstanceSettingsAdmin();

			SystemSettings.gotoConfiguration(
				configurationCategory = "User Authentication",
				configurationName = "General",
				configurationScope = "Virtual Instance Scope");

			FormFields.viewCheckboxChecked(fieldName = "strangers-verify");

			PortalSettings.gotoConfiguration(
				configurationCategory = "Email",
				configurationName = "Email Sender",
				configurationScope = "Virtual Instance Scope");

			PortalSettings.configureEmailSender(
				emailAddress = "test@liferay.com",
				emailSenderName = "Joe Bloggs");

			PortalSettings.editConfigurationUsersEmailNotificationsCP(
				configurationName = "Email Verification Notification",
				notificationsBody = '''
					Dear [$TO_FIRST_NAME$],<br /><br />

					Please verify your([$TO_FIRST_NAME$]) email address for [$PORTAL_URL$] at [$EMAIL_VERIFICATION_URL$].<br /><br />

					Your([$TO_FIRST_NAME$]) verification code is [$EMAIL_VERIFICATION_CODE$]<br /><br />

					Sincerely,<br />
					[$FROM_NAME$]<br />
					[$FROM_ADDRESS$]<br />
					[$PORTAL_URL$]<br />
				''',
				notificationsSubject = "[$PORTAL_URL$]: Email Address Verification For [$TO_FIRST_NAME$]");

			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				newPassword = PropsUtil.get("default.admin.password"),
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");

			UserBar.signOut();
		}

		task ("When: Log in as new user and send the verification code") {
			User.firstLoginUI(
				password = PropsUtil.get("default.admin.password"),
				userEmailAddress = "userea@liferay.com");

			Button.click(button = "Send New Verification Code");
		}

		task ("Then: Assert the subject, salutation and each paragraph in the body of the Email Address Verification are include user's first name") {
			MockMock.viewMail(
				asset = "${portalURL}: Email Address Verification For userfn",
				content = "Your(userfn) verification code is",
				recipient = "userfn userln",
				sender = "Joe Bloggs",
				subject = "${portalURL}: Email Address Verification For userfn");

			MockMock._gotoMailMessage(
				asset = "${portalURL}: Email Address Verification For userfn",
				recipient = "userfn userln");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Email Address Verification For userfn",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Dear userfn,");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Email Address Verification For userfn",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Please verify your(userfn) email address");
		}
	}

	@description = "This is a use case for LPS-85534 and LPS-176074 TC-1. Account created notification template could be set to include user's first name."
	@priority = 4
