				key_asset = "${portalURL}: Your New Account userfn",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "Dear userfn,");

			AssertTextEquals.assertPartialText(
				key_asset = "${portalURL}: Your New Account userfn",
				locator1 = "MockMock#MOCKMOCK_MESSAGE_BODY",
				value1 = "You recently created an account named userfn");
		}
	}

