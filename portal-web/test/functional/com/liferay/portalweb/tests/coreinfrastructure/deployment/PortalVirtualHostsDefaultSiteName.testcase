@component-name = "portal-core-infra"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property skip.start.app.server = "true";
	property testray.main.component.name = "Deployment";

	@description = "This is a use case for LPD-74656. It asserts that the first request to a fresh portal with empty virtual.hosts.default.site.name redirects to the home URL instead of throwing an exception."
	@priority = 5
	test NoExceptionOnFirstRequestWithEmptyDefaultSiteName {
		property custom.properties = "setup.wizard.enabled=false${line.separator}virtual.hosts.default.site.name=";
		property test.liferay.virtual.instance = "false";
		property test.prepare.bundle.properties = "true";
		property test.run.type = "single";

		task ("Given a freshly started portal") {
			AntCommands.runCommand("build-test.xml", "start-app-server -Dskip.wait.server.startup.url=true");
		}

		task ("When the first request targeting "/" hits the portal") {
			Navigator.openSpecificURL(url = "http://localhost:8080/");
		}

		task ("Then it should redirect to the home URL and no exception should be thrown") {
			Smoke.viewWelcomeContentPage();

			AssertConsoleTextNotPresent(value1 = "Cannot invoke \"jakarta.portlet.PortletRequest.getAttribute(String)\" because \"portletRequest\" is null");
		}
	}

}