@component-name = "portal-util-misc"
definition {

	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "Ext";

	tearDown {
		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if ("${testPortalInstance}" == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@priority = "4"
	test CanOverridePortalUUID {
		property deploy.spring.bean.override = "true";

		AssertConsoleTextNotPresent(value1 = "No bean named");

		AssertConsoleTextPresent(value1 = "Unique ID generated by ExtPortalUUID");
	}

}