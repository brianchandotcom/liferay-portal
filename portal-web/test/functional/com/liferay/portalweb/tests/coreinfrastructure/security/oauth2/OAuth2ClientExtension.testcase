@component-name = "portal-security"
definition {

	property ci.retries.disabled = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.main.component.name = "OAuth 2";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginUI();
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			PagesAdmin.tearDownCP();
		}
	}

	@description = "This is a use case for LPS-190491. Verify that oAuthApplication* client extension scopes will not lose in a clustered environment. Blocked by LPS-192126."
	@ignore = "true"
	@priority = 4
	test OAuthApplicationScopesWorkWithClusteredPortals {
		property app.server.bundles.size = "1";
		property cluster.enabled = "true";
		property minimum.slave.ram = "24";
		property remote.elasticsearch.enabled = "true";
		property test.liferay.virtual.instance = "false";

		task ("Given: Deploy client extension on node1") {
			FileInstall.deployFileOnServer(jarFile = "liferay-sample-batch-0.zip");

			WaitForConsoleTextPresent(value1 = "STARTED liferaysamplebatch0_7.4.13");

			// We need this pause for waiting for the Client Extension to present. See more details in LPS-190491.

			Pause(locator1 = 10000);
		}

		task ("And: Verify oAuthApplication* are present in scopes on node1") {
			var baseURL = PropsUtil.get("portal.url");

			OAuth2.openOAuth2Admin();

			Refresh();

			OAuth2.viewScopes(
				applicationName = "LPS-190491 Liferay Sample Batch 0 OAuth Application Headless Server",
				resourceCheckedList = "Liferay.Headless.Admin.Address.everything.read,Liferay.Headless.Admin.Content.everything.read,Liferay.Headless.Admin.List.Type.everything.read,Liferay.Headless.Admin.Taxonomy.everything.read,Liferay.Headless.Admin.Workflow.everything.read,Liferay.Headless.Admin.User.everything.read",
				resourcePanels = "Liferay.Headless.Admin.Address,Liferay.Headless.Admin.Content,Liferay.Headless.Admin.List.Type,Liferay.Headless.Admin.Taxonomy,Liferay.Headless.Admin.Workflow,Liferay.Headless.Admin.User");
		}

		task ("When: Shut down node1 and restart node2") {
			Clustering.shutdownSpecificServer(nodePort = 8080);

			Clustering.shutdownSpecificServer(nodePort = 9080);

			Clustering.startSpecificServer(
				deleteLiferayHome = "false",
				nodePort = 9080);
		}

		task ("Then: Log in node2 and oAuthApplication* are present in scopes on node2") {
			User.firstLoginUI(
				password = "test",
				specificURL = "http://localhost:9080",
				userEmailAddress = "test@liferay.com");

			OAuth2.openOAuth2Admin(baseURL = "http://localhost:9080");

			OAuth2.viewScopes(
				applicationName = "LPS-190491 Liferay Sample Batch 0 OAuth Application Headless Server",
				resourceCheckedList = "Liferay.Headless.Admin.Address.everything.read,Liferay.Headless.Admin.Content.everything.read,Liferay.Headless.Admin.List.Type.everything.read,Liferay.Headless.Admin.Taxonomy.everything.read,Liferay.Headless.Admin.Workflow.everything.read,Liferay.Headless.Admin.User.everything.read",
				resourcePanels = "Liferay.Headless.Admin.Address,Liferay.Headless.Admin.Content,Liferay.Headless.Admin.List.Type,Liferay.Headless.Admin.Taxonomy,Liferay.Headless.Admin.Workflow,Liferay.Headless.Admin.User");
		}
	}

	@description = "This is a use case for LPS-184771. Verify that SAP can be deleted after an oAuthApplicationHeadlessServer type client extension is deployed."
	@priority = 3
	test SAPCanBeDeleted {
		property liferay.online.properties = "true";
		property test.liferay.virtual.instance = "false";

		task ("Given: Add 2 virtual instances") {
			HeadlessPortalInstanceAPI.addPortalInstance(
				domain = "liferay.com",
				portalInstanceId = "www.able.com",
				virtualHost = "www.able.com");

			HeadlessPortalInstanceAPI.addPortalInstance(
				domain = "liferay.com",
				portalInstanceId = "www.baker.com",
				virtualHost = "www.baker.com");
		}

		task ("And: Deploy client extension to www.able.com instance") {
			FileInstall.deployFileOnServer(jarFile = "liferay-sample-batch-1.zip");

			WaitForConsoleTextPresent(value1 = "STARTED liferaysamplebatch1_7.4.13");

			// We need this pause for waiting for the Client Extension to present. See more details in LPS-184771.

			Pause(locator1 = 10000);
		}

		task ("And: Add the same SAP in two virtual instances") {
			UserBar.signOut();

			User.firstLoginUI(
				password = "test",
				specificURL = "http://www.able.com:8080",
				userEmailAddress = "test@liferay.com");

			OAuth2.openOAuth2Admin(baseURL = "http://www.able.com:8080");

			OAuth2.viewApplicationInTable(
				applicationName = "LPS-184771 Liferay Sample Batch 1 OAuth Application Headless Server",
				description = "");

			ServiceAccessPolicy.openServiceAccessPolicyAdmin(baseURL = "http://www.able.com:8080");

			ServiceAccessPolicy.addServiceAccessPolicy(
				policyName = "aa",
				title = "aa");

			UserBar.signOut();

			User.firstLoginUI(
				password = "test",
				specificURL = "http://www.baker.com:8080",
				userEmailAddress = "test@liferay.com");

			ServiceAccessPolicy.openServiceAccessPolicyAdmin(baseURL = "http://www.baker.com:8080");

			ServiceAccessPolicy.addServiceAccessPolicy(
				policyName = "aa",
				title = "aa");
		}

		task ("When: Delete SAP from the www.baker.com instance") {
			ServiceAccessPolicy.deleteServiceAccessPolicy(policyName = "aa");
		}

		task ("Then: SAP should be deleted without any issue") {
			ServiceAccessPolicy.openServiceAccessPolicyAdmin(baseURL = "http://www.baker.com:8080");

			AssertElementNotPresent(
				key_policyName = "aa",
				locator1 = "ServiceAccessPolicy#POLICY_NAME");
		}
	}

}