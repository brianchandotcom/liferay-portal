@component-name = "portal-analytics-cloud"
definition {

	property analytics.cloud.release = "true";
	property analytics.cloud.upstream = "true";
	property custom.properties = "jsonws.web.service.paths.excludes=";
	property portal.release = "false";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property testray.main.component.name = "Analytics Cloud";

	setUp {
		task ("Copy the token from AC") {
			ACUtils.launchAC();

			ACSettings.takeTokenFromAnalyticsCloud();
		}

		task ("Set up instance and sign in DXP") {
			TestCase.setUpPortalInstance();

			ACUtils.launchDXP();
		}

		task ("Add a new site with a public widget page") {
			ACUtils.addSiteAndPage();
		}

		task ("Add a new user") {
			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");
		}

		task ("Connect the DXP to AC") {
			ACDXPSettings.connectDXPtoAnalyticsCloud(siteName = "Site Name");
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		ACUtils.tearDownDXP();

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			JSONGroup.deleteGroupByName(groupName = "Site Name");
		}

		ACUtils.tearDownAC();
	}

	@description = "Feature ID: LRAC-13424 | Automation ID: LRAC-14041 | Test Summary: Check that it is not possible to create a dynamic segment with a name that is already in use"
	@priority = 4
	test CheckNotPossibleCreateDynamicSegmentWithNameAlreadyInUse {
		task ("View the site page with new user") {
			ACUtils.navigateToSitePageWithUser(
				actionType = "View WC",
				documentTitleList = "1,2,3,4",
				emailList = "userea@liferay.com",
				pageName = "AC Page",
				siteName = "Site Name");
		}

		task ("Close sessions and wait for 30 seconds") {
			ACUtils.closeAllSessionsAndWait();
		}

		task ("Switch to new property in AC") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});
		}

		for (var segmentName : list "Segment Name Already Exists,segment name already exists") {
			task ("Add two new dynamic segments") {
				ACNavigation.goToSegments();

				ACSegments.createDynamicSegment();

				ACUtils.setItemName(itemName = ${segmentName});
			}

			task ("Add an email field") {
				ACSegments.goToSidebarAttributes(criterion = "Individual Attributes");

				ACSegments.addSegmentField(segmentField = "email");

				ACSegments.editTextCriterion(textInput = "userea@liferay.com");
			}

			task ("Save the Segment") {
				Click(locator1 = "ACSegments#SAVE_SEGMENT");
			}
		}

		task ("Assert that the warning pop-up appears") {
			Alert.viewWarningSpecific(warningMessage = "Warning:This segment name is currently in use. Please try a different one");
		}

		task ("Cancel the creation") {
			ACSegments.cancelSegment();

			Button.click(button = "Leave Page");
		}

		task ("Check that only one segment is present in the list") {
			ACUtils.viewResultsMessage(results = "Showing 1 to 1 of 1 entry.");
		}

		task ("Add a new Dynamic segment") {
			ACSegments.createDynamicSegmentAndFillFields(
				criterion = "Individual Attributes",
				segmentField = "email",
				segments = "Segment Name Already Exists 2");

			ACSegments.editTextCriterion(textInput = "test@liferay.com");
		}

		task ("Save the Segment") {
			ACSegments.saveSegment();
		}

		task ("Add a new dynamic segment") {
			ACNavigation.goToSegments();

			ACSegments.createDynamicSegment();

			ACUtils.setItemName(itemName = "segment name already exists 2");
		}

		task ("Add an email field") {
			ACSegments.goToSidebarAttributes(criterion = "Individual Attributes");

			ACSegments.addSegmentField(segmentField = "email");

			ACSegments.editTextCriterion(textInput = "userea@liferay.com");
		}

		task ("Save the Segment") {
			Click(locator1 = "ACSegments#SAVE_SEGMENT");
		}

		task ("Assert that the warning pop-up appears") {
			Alert.viewWarningSpecific(warningMessage = "Warning:This segment name is currently in use. Please try a different one");
		}

		task ("Cancel the creation") {
			ACSegments.cancelSegment();

			Button.click(button = "Leave Page");
		}

		task ("Check that only two segments are present in the list") {
			ACUtils.viewResultsMessage(results = "Showing 1 to 2 of 2 entries.");
		}
	}

	@description = "Feature ID: LRAC-13424 | Automation ID: LRAC-14043 | Test Summary: Check that it is not possible to edit the segment name to an existing one"
	@priority = 3
	test CheckNotPossibleEditSegmentNameToExistsOne {
		task ("View the site page with new user") {
			ACUtils.navigateToSitePageWithUser(
				actionType = "View WC",
				documentTitleList = "1,2,3,4",
				emailList = "userea@liferay.com",
				pageName = "AC Page",
				siteName = "Site Name");
		}

		task ("Close sessions and wait for 30 seconds") {
			ACUtils.closeAllSessionsAndWait();
		}

		task ("Switch to new property in AC") {
			ACUtils.launchAC();

			ACProperties.switchProperty(propertyName = ${assignedPropertyName});
		}

		for (var segmentName : list "Segment Name Already Exists,segment name already exists 2") {
			task ("Add two new dynamic segments") {
				ACNavigation.goToSegments();

				ACSegments.createDynamicSegment();

				ACUtils.setItemName(itemName = ${segmentName});
			}

			task ("Add an email field") {
				ACSegments.goToSidebarAttributes(criterion = "Individual Attributes");

				ACSegments.addSegmentField(segmentField = "email");

				ACSegments.editTextCriterion(textInput = "userea@liferay.com");
			}

			task ("Save the Segment") {
				ACSegments.saveSegment();
			}
		}

		task ("Edit the first segment") {
			ACNavigation.goToSegments();

			ACSegments.editSegment(segmentName = "Segment Name Already Exists");
		}

		task ("Change the segment name to be equal to the second segment name") {
			ACUtils.setItemName(itemName = "segment name already exists 2");
		}

		task ("Save the Segment") {
			Click(locator1 = "ACSegments#SAVE_SEGMENT");
		}

		task ("Assert that the warning pop-up appears") {
			Alert.viewWarningSpecific(warningMessage = "Warning:This segment name is currently in use. Please try a different one");
		}

		task ("Cancel the creation") {
			ACSegments.cancelSegment();

			Button.click(button = "Leave Page");
		}

		task ("Check that no segment names have been changed") {
			ACNavigation.goToSegments();

			for (var segmentName : list "Segment Name Already Exists,segment name already exists 2") {
				ACSegments.assertSegmentPresent(segmentName = ${segmentName});
			}
		}
	}

}