@component-name = "portal-frontend-infrastructure"
definition {

	property osgi.modules.includes = "frontend-data-set-sample-web";
	property portal.acceptance = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Frontend Dataset";
	property testray.main.component.name = "Frontend Dataset";

	setUp {
		TestCase.setUpPortalInstance();

		User.firstLoginPG();

		task ("Given Frontend Dataset sample portlet") {
			JSONLayout.addPublicLayout(
				groupName = "Guest",
				layoutName = "Frontend Data Set Test Page");

			JSONLayout.addWidgetToPublicLayout(
				groupName = "Guest",
				layoutName = "Frontend Data Set Test Page",
				widgetName = "Frontend Data Set Sample");

			JSONLayout.updateLayoutTemplateOfPublicLayout(
				groupName = "Guest",
				layoutName = "Frontend Data Set Test Page",
				layoutTemplate = "1 Column");

			Navigator.gotoPage(pageName = "Frontend Data Set Test Page");

			Refresh();
		}
	}

	tearDown {
		var testPortalInstance = PropsUtil.get("test.portal.instance");

		if ("${testPortalInstance}" == "true") {
			PortalInstances.tearDownCP();
		}
		else {
			JSONLayout.deletePublicLayout(
				groupName = "Guest",
				layoutName = "Frontend Data Set Test Page");
		}
	}

	@description = "LPS-155455: When hovering over the first line item and the quick action menu is displayed on the 1st line"
	@priority = "5"
	test CanDisplayOnHover {
		task ("When hovering over the 1st line item") {
			MouseOver(
				key_title = "Sample1",
				locator1 = "FrontendDataSet#ENTRY_TITLE");
		}

		task ("Then the quick action menu is displayed on the 1st line") {
			FDSQuickActions.viewQuickActionMenuIsPresent(title = "Sample1");
		}
	}

	@description = "LPS-155459: When clicking on the ellipsis and hovering over another row, multiple quick action menu are displayed"
	@priority = "3"
	test CanDisplayOnMultipleActiveRows {
		task ("When click on Elipsis button 1st") {
			Click(
				key_title = "Sample1",
				locator1 = "FrontendDataSet#VERTICAL_ELLIPSIS_BUTTON");
		}

		task ("Then the quick action menu is displayed on the 1st line") {
			AssertElementPresent(locator1 = "FrontendDataSet#DROPDOWN_MENU");
		}

		task ("When hovering over the 2nd line item") {
			MouseOver(
				key_title = "Sample2",
				locator1 = "FrontendDataSet#ENTRY_TITLE");
		}

		task ("Then the quick action menu is displayed on the 2nd line") {
			FDSQuickActions.viewQuickActionMenuIsPresent(title = "Sample2");
		}

		task ("Then the quick action menu is displayed on the 1st line") {
			AssertElementPresent(locator1 = "FrontendDataSet#DROPDOWN_MENU");
		}
	}

}