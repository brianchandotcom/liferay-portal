@component-name = "portal-analytics-cloud"
definition {

	property analytics.cloud.release = "true";
	property analytics.cloud.upstream = "true";
	property custom.properties = "jsonws.web.service.paths.excludes=";
	property portal.release = "true";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testray.main.component.name = "Segmentation";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Enable DXP segments deprecation feature flag") {
			Segmentation.enableDXPSegments();
		}

		task ("Open Segmentation Admin") {
			Segmentation.openSegmentsAdmin(siteURLKey = "test-site-name");
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "This is a test for LPS-187282. The segment designer could add a segment based on organization category criteria."
	@priority = 5
	test AddSegmentByOrganizationCategory {
		task ("Given a segment designer has an organization with a global category") {
			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");

			JSONOrganization.addOrganization(organizationName = "Organization Name");

			JSONOrganization.assignUserToOrganization(
				organizationName = "Organization Name",
				userEmailAddress = "userea@liferay.com");

			JSONCategory.addVocabulary(
				groupName = "Global",
				title = "Vocabulary Name");

			var categoryId = JSONCategory.addCategory(
				groupName = "Global",
				title = "Category Name",
				vocabularyName = "Vocabulary Name");

			Organization.openOrganizationsAdmin();

			Organization.gotoEdit(orgName = "Organization Name");

			AssetCategorization.addCategory(
				categoryName = "Category Name",
				vocabularyName = "Vocabulary Name");

			PortletEntry.save();
		}

		task ("When the segment designer adds a segment in a site") {
			Segmentation.openSegmentsAdmin(siteURLKey = "test-site-name");

			LexiconEntry.gotoAdd();
		}

		task ("Then the segment designer could add an organization category criteria") {
			Segmentation.gotoSidebar(fieldType = "Organization");

			Segmentation.addProperties(propertyOption = "Category");

			Segmentation.fillProperty(selectCategory = "Category Name");

			Segmentation.fillTitle(titleField = "New Segment");

			Segmentation.viewMembers(memberName = "userfn userln");

			PortletEntry.save();
		}

		task ("When the segment designer edits the segment one more time") {
			Segmentation.editSegment(entry = "New Segment");
		}

		task ("Then the segment designer should see the organization category criteria") {
			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "Category Name");
		}
	}

	@description = "Test Automation for LPS-130319: Validate if it's posible to create a segment based on Session > Hostname criteria"
	@priority = 5
	@uitest
	test AddSegmentBySessionProperties {
		task ("Add segment") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "Hostname");

			Segmentation.fillTitle(titleField = "AddSegmentBySessionHostname Test");

			Segmentation.fillProperty(criterionValue = "localhost");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentBySessionHostname Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "localhost");
		}

		task ("Add segment with Cookies property") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "Cookies");

			Segmentation.fillTitle(titleField = "AddSegmentBySessionCookies Test");

			Segmentation.fillProperty(
				criterionKey = "GUEST_LANGUAGE_ID",
				criterionValue = "en_US");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Cookies segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentBySessionCookies Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "en_US");

			AssertValue(
				locator1 = "Segmentation#CRITERION_KEY_ANY",
				value1 = "GUEST_LANGUAGE_ID");
		}

		task ("Add segment with IP Geocoder Country property") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "IP Geocoder Country");

			Segmentation.fillProperty(optionsValue = "Spain");

			Segmentation.fillTitle(titleField = "AddSegmentBySessionIPGeocoderCountry Test");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the IP Geocoder Country segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentBySessionIPGeocoderCountry Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "ES");
		}

		task ("Add segment with Referrer URL property") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "Referrer URL");

			Segmentation.fillTitle(titleField = "AddSegmentBySessionReferrerURL Test");

			Segmentation.fillProperty(criterionValue = "http://localhost:8080");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Referrer URL segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentBySessionReferrerURL Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "http://localhost:8080");
		}

		task ("Add segment with Request Parameters property") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "Request Parameters");

			Segmentation.fillTitle(titleField = "AddSegmentBySessionRequestParameters Test");

			Segmentation.fillProperty(
				criterionKey = "languageId",
				criterionValue = "en_US");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Request Parameters segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentBySessionRequestParameters Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "en_US");

			AssertValue(
				locator1 = "Segmentation#CRITERION_KEY_ANY",
				value1 = "languageId");
		}

		task ("Add segment with User Agent property") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "User Agent");

			Segmentation.fillTitle(titleField = "AddSegmentBySessionUserAgent Test");

			Segmentation.changeCriterionInput(criterionInputOption = "Contains");

			Segmentation.fillProperty(criterionValue = "Chrome");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the User Agent segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentBySessionUserAgent Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "Chrome");

			AssertValue(
				locator1 = "Segmentation#CRITERION_OPERATOR",
				value1 = "contains");
		}

		task ("Add segment with Signed In property") {
			LexiconEntry.gotoAdd();

			Segmentation.gotoSidebar(fieldType = "Session");

			Segmentation.addProperties(propertyOption = "Signed In");

			Segmentation.fillTitle(titleField = "Signed In Test");

			Select(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "False");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Signed In segment is correctly created") {
			Segmentation.editSegment(entry = "Signed In Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "false");
		}
	}

	@description = "Test Automation for LPS-130291: Validate if it's posible to create a segment based on User > Email Adress criteria"
	@priority = 5
	@uitest
	test AddSegmentByUserEmailAddressOperators {
		task ("Add user") {
			JSONUser.addUser(
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");

			JSONUser.setFirstPassword(
				agreeToTermsAndAnswerReminderQuery = "true",
				requireReset = "false",
				userEmailAddress = "userea@liferay.com");
		}

		task ("Add segment and check the user Belongs To the segment") {
			LexiconEntry.gotoAdd();

			Segmentation.addProperties(propertyOption = "Email Address");

			Segmentation.fillTitle(titleField = "AddSegmentByUserEmailAddress Test");

			Segmentation.changeCriterionInput(criterionInputOption = "Contains");

			Segmentation.fillProperty(criterionValue = "liferay");

			Segmentation.viewMembers(memberName = "userfn userln");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentByUserEmailAddress Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "liferay");
		}

		task ("Add segment with Equals operator") {
			LexiconEntry.gotoAdd();

			Segmentation.addProperties(propertyOption = "Email Address");

			Segmentation.fillTitle(titleField = "AddSegmentUserEmailAddressEquals Test");

			Segmentation.changeCriterionInput(criterionInputOption = "Equals");

			Segmentation.fillProperty(criterionValue = "liferay");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Equals segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentUserEmailAddressEquals Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "liferay");

			AssertValue(
				locator1 = "Segmentation#CRITERION_OPERATOR",
				value1 = "eq");
		}

		task ("Add segment with Not Contains operator") {
			LexiconEntry.gotoAdd();

			Segmentation.addProperties(propertyOption = "Email Address");

			Segmentation.fillTitle(titleField = "AddSegmentUserEmailAddressNotContains Test");

			Segmentation.changeCriterionInput(criterionInputOption = "Not Contains");

			Segmentation.fillProperty(criterionValue = "liferay");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Not Contains segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentUserEmailAddressNotContains Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "liferay");

			AssertValue(
				locator1 = "Segmentation#CRITERION_OPERATOR",
				value1 = "not-contains");
		}

		task ("Add segment with Not Equals operator") {
			LexiconEntry.gotoAdd();

			Segmentation.addProperties(propertyOption = "Email Address");

			Segmentation.fillTitle(titleField = "AddSegmentUserEmailAddressNotEquals Test");

			Segmentation.changeCriterionInput(criterionInputOption = "Not Equals");

			Segmentation.fillProperty(criterionValue = "liferay");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Assert the Not Equals segment is correctly created") {
			Segmentation.editSegment(entry = "AddSegmentUserEmailAddressNotEquals Test");

			AssertValue(
				locator1 = "Segmentation#CRITERION_INPUT_ANY",
				value1 = "liferay");

			AssertValue(
				locator1 = "Segmentation#CRITERION_OPERATOR",
				value1 = "not-eq");
		}
	}

