@component-name = "portal-analytics-cloud"
definition {

	property analytics.cloud.release = "true";
	property analytics.cloud.upstream = "true";
	property custom.properties = "jsonws.web.service.paths.excludes=";
	property portal.release = "true";
	property portal.upstream = "true";
	property property.group = "analytics.cloud.profile";
	property test.liferay.virtual.instance = "false";
	property test.run.type = "single";
	property testray.main.component.name = "Segmentation";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}

		task ("Enable DXP segments deprecation feature flag") {
			Segmentation.enableDXPSegments();
		}

		task ("Open Segmentation Admin") {
			Segmentation.openSegmentsAdmin(siteURLKey = "test-site-name");
		}
	}

	tearDown {
		var testLiferayVirtualInstance = PropsUtil.get("test.liferay.virtual.instance");

		if (${testLiferayVirtualInstance} == "true") {
			PortalInstances.tearDownCP();
		}
	}

	@description = "LPS-130917 Given Instance Settings > Segments When the user clicks on Analytics Cloud Segments tab Then help text of Anonymous User Segments Cache Expiration Time will be: Define the time (in seconds) before clearing the Anonymous Segment cache."
	@priority = 3
	test CheckAnalyticsCloudSegmentsHelpTexts {
		task ("Go to Instance Settings > Segments") {
			PortalSettings.openInstanceSettingsAdmin();

			SystemSettings.gotoConfiguration(
				configurationCategory = "Segments",
				configurationName = "Analytics Cloud Segments",
				configurationScope = "Virtual Instance Scope");
		}

		task ("Assert the text is present") {
			AssertTextEquals(
				locator1 = "FormFields#HELP_TEXT",
				value1 = "Define the time (in seconds) before clearing the Anonymous Segment cache.");
		}

		task ("Assert the Interest Terms cache help text is present") {
			AssertTextEquals(
				locator1 = "FormFields#HELP_TEXT",
				value1 = "Define the time (in seconds) before clearing the Interest Terms cache.");
		}
	}

	@description = "LPS-135495 Validate if, The criteria default language must be tagged as such in the language selection dropdown."
	@priority = 3
	test CheckDefaultLanguageTag {
		var defaultLanguage = Segmentation.getPortalInstanceDefaultLanguageId();

		task ("Go to add segment screen") {
			LexiconEntry.gotoAdd();
		}

		task ("Open localizations dropdwon") {
			Click.clickNoMouseOver(
				key_currentLocale = "en-us",
				locator1 = "Button#TRANSLATIONS_LOCALIZATION");
		}

		task ("Validate tag text") {
			AssertTextEquals(
				key_locale = StringUtil.replace(${defaultLanguage}, "_", "-"),
				locator1 = "Translation#TRANSLATION_LANGUAGE_STATUS_LABEL",
				value1 = "Default");
		}
	}

	@description = "LPS-135495 Validate if, Input title values can only be changed in edit mode."
	@priority = 3
	test CheckTranslatedSegment {
		task ("Create a segment") {
			JSONSegmentsentry.addSegment(
				fieldName = "Screen Name",
				groupName = "Test Site Name",
				operator = "contains",
				segmentName = "Original Segment",
				text = "Test");

			Refresh();
		}

		task ("Create segment's translation") {
			Segmentation.editSegment(entry = "Original Segment");

			Segmentation.changeLocale(locale = "pt-BR");

			Segmentation.fillTitle(titleField = "Segmento Traduzido");

			Button.clickSave();

			Alert.viewSuccessMessage();
		}

		task ("Check if title displayed is in english") {
			AssertElementPresent(
				key_rowEntry = "Original Segment",
				locator1 = "ContentRow#ENTRY_CONTENT_ENTRY_NAME");
		}

		task ("Assert if Titile is 'readonly' when edit toggle is disabled") {
			LexiconEntry.gotoEntry(rowEntry = "Original Segment");

			Segmentation.changeLocale(locale = "pt-BR");

			AssertElementPresent(locator1 = "Segmentation#TITLE_FIELD_READ_ONLY");

			Click(
				ariaLabel = "Enter Edit Mode",
				locator1 = "Button#ANY_WITH_ARIA_LABEL");

			AssertElementNotPresent(locator1 = "Segmentation#TITLE_FIELD_READ_ONLY");
		}
	}

	@description = "LPS-153507 - Test Automation for LPS-95412: Members count is not updated when conjunctions are changed"
	@priority = 4
	test SegmentationCheckMembersWithConditions {
		task ("Add user with devoleper job title") {
			JSONUser.addUser(
				jobTitle = "Developer",
				userEmailAddress = "userea@liferay.com",
				userFirstName = "userfn",
				userLastName = "userln",
				userScreenName = "usersn");
		}

		task ("Add segment with conditions") {
			Segmentation.openSegmentsAdmin(siteURLKey = "test-site-name");

			LexiconEntry.gotoAdd();

			Segmentation.addProperties(propertyOption = "Job Title");

			Segmentation.fillProperty(criterionValue = "Developer");

			Segmentation.addSecondProperty(propertyOption = "First Name");

			Segmentation.fillProperty(
				criterionValue = "Test",
				indexNumber = 2);

			Segmentation.fillTitle(titleField = "SegmentationCheckMembersWithConditions Test");
		}

		task ("Check the number of members") {
			AssertTextEquals(
				locator1 = "Segmentation#MEMBERS_MATCHED",
				value1 = "0 Members");
		}

		task ("Change the conjunction and check the number of members") {
			Segmentation.changeCriterionConjunction(criterionConjunctionItem = "Or");

			AssertTextEquals(
				locator1 = "Segmentation#MEMBERS_MATCHED",
				value1 = "2 Members");
		}
	}

	@description = "LPS-153509 Bug: Segment name is not localizable but it works as if it were"
	@priority = 4
	@uitest
	test SegmentAvailableInAnyLocale {
		var portalURL = PropsUtil.get("portal.url");

		task ("Navigate to Segment Admin using not default language") {
			Navigator.openSpecificURL(url = "${portalURL}/es/group/test-site-name/~/control_panel/manage/-/segments/entries");
		}

		task ("Create a Segment") {
			Button.click(button = "Nuevo");

			Segmentation.addProperties(propertyOption = "Apellido");

			Segmentation.fillProperty(criterionValue = "Test");

			Segmentation.fillTitle(titleField = "Segmento Espanol");

			Click.mouseDownMouseUp(
				key_text = "Guardar",
				locator1 = "Button#ANY");

			Alert.viewSuccessMessage();
		}

		task ("Navigate to Segment Admin using another language") {
			Navigator.openSpecificURL(url = "${portalURL}/pt/group/test-site-name/~/control_panel/manage/-/segments/entries");
		}

		task ("Check that the segment still present") {
			AssertTextEquals(
				key_tableEntry = "Segmento Espanol",
				locator1 = "LexiconTable#TABLE_ENTRY_TITLE_LINK",
				value1 = "Segmento Espanol");
		}
	}

	@description = "LPS-135969 Validate if, on Segmentation, the user can't drag and drop fields into different Property section."
	@priority = 3
	test ValidatePropertyDragAndDropToSections {
		task ("Create a segment") {
			JSONSegmentsentry.addSegment(
				fieldName = "Screen Name",
				groupName = "Test Site Name",
				operator = "contains",
				segmentName = "Segment With Multiple Conditions",
				text = "Test");

			Refresh();
		}

		task ("Try to drag property to wrong section") {
			Segmentation.editSegment(entry = "Segment With Multiple Conditions");

			Segmentation.gotoSidebar(fieldType = "Organization");

			DragAndDrop.javaScriptDragAndDropToObject(
				key_propertyOption = "Country",
				locator1 = "Segmentation#ADD_FIELD_TYPE_VISIBLE",
				locator2 = "Segmentation#ADD_FIELD_POSITION_EDIT",
				value1 = "Country");
		}

		task ("Assert that property was not added") {
			AssertElementNotPresent(
				locator1 = "Segmentation#CONDITIONS_PROPERTY_NAME",
				propertyName = "Country");

			Refresh();
		}

		task ("Try to drag property to right section") {
			Segmentation.gotoSidebar(fieldType = "Organization");

			DragAndDrop.javaScriptDragAndDropToObject(
				key_propertyOption = "Country",
				locator1 = "Segmentation#ADD_FIELD_TYPE_VISIBLE",
				locator2 = "Segmentation#ADD_FIELD_POSITION_EMPTY",
				value1 = "Country");

			AssertElementPresent(
				locator1 = "Segmentation#CONDITIONS_PROPERTY_NAME",
				propertyName = "Country");
		}
	}

	@description = "LPS-135969 Validate if, on Segmentation, when the user clicks in a different Property section the contributor area of this section will be displayed."
	@priority = 3
	test ValidatePropertyVisibilityBySection {
		task ("Click on USER field type and asser if its properties are displayed.") {
			LexiconEntry.gotoAdd();

			AssertVisible(
				key_propertyOption = "Date of Birth",
				locator1 = "Segmentation#ADD_FIELD_TYPE");
		}

		task ("Click on ORGANIZATION field type and asser if its properties are displayed.") {
			Segmentation.gotoSidebar(fieldType = "Organization");

			AssertVisible(
				key_propertyOption = "Country",
				locator1 = "Segmentation#ADD_FIELD_TYPE");
		}

		task ("Click on SESSION field type and asser if its properties are displayed.") {
			Segmentation.gotoSidebar(fieldType = "Session");

			AssertVisible(
				key_propertyOption = "Browser",
				locator1 = "Segmentation#ADD_FIELD_TYPE");
		}

		task ("Click on SEGMENTS field type and asser if its properties are displayed.") {
			Segmentation.gotoSidebar(fieldType = "Segments");

			AssertVisible(
				key_propertyOption = "Segment",
				locator1 = "Segmentation#ADD_FIELD_TYPE");
		}

		task ("Click on USER field type and assert if other properties are not displayed") {
			Segmentation.gotoSidebar(fieldType = "User");

			for (var option : list "Country,Browser,Segment") {
				AssertNotVisible(
					key_propertyOption = ${option},
					locator1 = "Segmentation#ADD_FIELD_TYPE");
			}
		}

		task ("Click on ORGANIZATION field type and assert if other properties are not displayed") {
			Segmentation.gotoSidebar(fieldType = "Organization");

			for (var option : list "Date of Birth,Browser,Segment") {
				AssertNotVisible(
					key_propertyOption = ${option},
					locator1 = "Segmentation#ADD_FIELD_TYPE");
			}
		}

		task ("Click on SESSION field type and assert if other properties are not displayed") {
			Segmentation.gotoSidebar(fieldType = "Session");

			for (var option : list "Date of Birth,Country,Segment") {
				AssertNotVisible(
					key_propertyOption = ${option},
					locator1 = "Segmentation#ADD_FIELD_TYPE");
			}
		}

		task ("Click on SEGMENTS field type and assert if other properties are not displayed") {
			Segmentation.gotoSidebar(fieldType = "Segments");

			for (var option : list "Date of Birth,Country,Browser") {
				AssertNotVisible(
					key_propertyOption = ${option},
					locator1 = "Segmentation#ADD_FIELD_TYPE");
			}
		}
	}

	@description = "This is a test for LPS-177714. The tooltip of the back button is Go to Segments in the page editor of Segments."
	@priority = 3
	test ViewBackButtonTooltipForSegmentsAdmin {
		task ("Given a site administrator adds a segment") {
			LexiconEntry.gotoAdd();

			WaitForVisible(locator1 = "Segmentation#ADD_FIELD_POSITION");
		}

		task ("When the site administrator hovers over the back button") {
			MouseOver(locator1 = "Icon#BACK");
		}

		task ("Then the site administrator could see the tooltip message") {
			AssertVisible(
				key_content = "Go to Segments",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}

		task ("Given a site administrator edits the segment") {
			JSONSegmentsentry.addSegment(
				fieldName = "Regular Role",
				groupName = "Test Site Name",
				operator = "equals",
				segmentName = "Test Segment Name",
				selectedOption = "Power User");

			Navigator.gotoBack();

			Segmentation.editSegment(entry = "Test Segment Name");

			WaitForElementPresent(locator1 = "Segmentation#CRITERION_INPUT_ANY");
		}

		task ("When the site administrator hovers over the back button") {
			MouseOver(locator1 = "Icon#BACK");
		}

		task ("Then the site administrator could see the tooltip message") {
			AssertVisible(
				key_content = "Go to Segments",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

	@description = "This is a test for LPS-177714. When adding a segment to a new experience, the tooltip of the back button is Go to [pageName] where [pageName] is the name of the page in the Page Editor view."
	@priority = 3
	test ViewBackButtonTooltipOfNewSegmentFromNewExperience {
		task ("Given a site administrator accesses to the segment editor from new experience") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.openNewExperienceEditor();

			Click(
				key_text = "New Segment",
				locator1 = "Button#ANY");

			WaitForVisible(locator1 = "Segmentation#ADD_FIELD_POSITION");
		}

		task ("When the site administrator hovers over the back button") {
			MouseOver(locator1 = "Icon#BACK");
		}

		task ("Then the site administrator could see the tooltip message") {
			AssertVisible(
				key_content = "Go to Test Page Name",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

	@description = "This is a test for LPS-94651. The draggable area should be default and the already existent conditions not disabled until one item from the properties sidebar is selected."
	@priority = 3
	test ViewDraggableAreaWhenDraggingPropertyItem {
		task ("Given a segment designer accesses to the segment entry editor") {
			LexiconEntry.gotoAdd();

			WaitForPageLoad();
		}

		task ("When the segment designer drags a property item") {
			DragOver.dragOver(
				key_propertyOption = "User",
				locator1 = "Segmentation#ADD_FIELD_TYPE_VISIBLE",
				locator2 = "Segmentation#ADD_FIELD_TYPE_VISIBLE");
		}

		task ("Then the segment designer could see the draggable area") {
			AssertVisible(locator1 = "Segmentation#EMPTY_DROP_ZONE_DASHED");
		}

		task ("When the segment designer drops the property item in draggable area") {
			DragAndDrop.javaScriptDragAndDropToObject(
				key_propertyOption = "User",
				locator1 = "Segmentation#ADD_FIELD_TYPE_VISIBLE",
				locator2 = "Segmentation#ADD_FIELD_POSITION");

			AssertElementPresent(
				locator1 = "Segmentation#CONDITIONS_PROPERTY_NAME",
				propertyName = "User");
		}

		task ("Then the segment designer cannot see the draggable area") {
			AssertElementNotPresent(locator1 = "Segmentation#EMPTY_DROP_ZONE_DASHED");
		}

		task ("When the segment designer drags a property item from another section") {
			Segmentation.gotoSidebar(fieldType = "Organization");

			DragOver.dragOver(
				key_propertyOption = "Country",
				locator1 = "Segmentation#ADD_FIELD_TYPE_VISIBLE",
				locator2 = "Segmentation#ADD_FIELD_TYPE_VISIBLE");
		}

		task ("Then the segment designer could see the draggable area") {
			AssertVisible(locator1 = "Segmentation#EMPTY_DROP_ZONE_DASHED");
		}

		task ("When the segment designer drops the property item in draggable area") {
			DragAndDrop.javaScriptDragAndDropToObject(
				indexNumber = 2,
				key_propertyOption = "Country",
				locator1 = "Segmentation#ADD_FIELD_TYPE_VISIBLE",
				locator2 = "Segmentation#ADD_FIELD_POSITION_N");

			AssertElementPresent(
				locator1 = "Segmentation#CONDITIONS_PROPERTY_NAME",
				propertyName = "Country");
		}

		task ("Then the segment designer cannot see the draggable area") {
			AssertElementNotPresent(locator1 = "Segmentation#EMPTY_DROP_ZONE_DASHED");
		}
	}

}