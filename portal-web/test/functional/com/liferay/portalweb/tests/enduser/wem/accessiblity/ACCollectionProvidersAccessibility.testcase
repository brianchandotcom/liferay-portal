		task ("Then the User's Personalized Content Recommendations collection provider should have correct accessibility") {
			NavItem.click(navItem = "Collection Providers");

			AssertElementAccessible(locator1 = "//dd[contains(@class,'card-page-item')][.//p[contains(@class,'card-title')][normalize-space()=\"User's Personalized Content Recommendations\"]]");
		}
	}

}