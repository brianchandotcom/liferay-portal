@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Page Audit";

	setUp {
		task ("Set up virtual instance") {
			TestCase.setUpPortalInstance();
		}

		task ("Sign in") {
			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a test for LPS-192049. The page creator could access to details view of item on Performance list via keyboard."
	@priority = 3
	test GoToDetailsOfItemOnPerformancePanelViaKeyboard {
		property custom.properties = "feature.flag.LPS-187284=true${line.separator}feature.flag.LPS-187285=true";

		task ("Given a page creator has a Heading fragment on a content page") {
			JSONLayout.addPublicLayout(
				groupName = "Test Site Name",
				layoutName = "Test Page Name",
				type = "content");

			ContentPagesNavigator.openEditContentPage(
				pageName = "Test Page Name",
				siteName = "Test Site Name");

			PageEditor.addFragment(
				collectionName = "Basic Components",
				fragmentName = "Heading");
		}

		task ("When the page creator navigates to the content page at view mode") {
			PageEditor.publish();
		}

		task ("Then the page creator could go to the details of Heading fragment via keyboard") {
			KeyPress(
				key_text = "test",
				locator1 = "Icon#ANY",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "PageAudit#PAGE_AUDIT_BUTTON");

			KeyPress(
				locator1 = "PageAudit#PAGE_AUDIT_BUTTON",
				value1 = "\ENTER");

			WaitForElementPresent(locator1 = "PageAudit#PANEL_TITLE");

			AssertElementFocused(locator1 = "PageAudit#SIDEBAR");

			KeyPress(
				locator1 = "Icon#CLOSE_ALERT",
				value1 = "\TAB");

			AssertElementFocused(
				ariaLabel = "Select Heading",
				locator1 = "PageAudit#PAGE_AUDIT_ELEMENT");

			KeyPress(
				ariaLabel = "Select Heading",
				locator1 = "PageAudit#PAGE_AUDIT_ELEMENT",
				value1 = "\ENTER");

			AssertElementFocused(locator1 = "PageAudit#SIDEBAR");

			AssertTextEquals(
				key_panel = "Warnings",
				locator1 = "Panel#PANEL_ALERT_FEEDBACK",
				value1 = "No issues found in this component.");

			for (var itemName : list "Server Render Time,Component Type,Origin,Cache Status") {
				AssertVisible(
					key_itemName = ${itemName},
					key_panel = "Basic Information",
					locator1 = "Panel#PANEL_INFO_ITEM");
			}

			KeyPress(
				locator1 = "PageAudit#SIDEBAR",
				value1 = "\TAB");

			AssertElementFocused(
				key_text = "angle-left",
				locator1 = "Icon#ANY");

			KeyPress(
				key_text = "angle-left",
				locator1 = "Icon#ANY",
				value1 = "\TAB");

			KeyPress(
				locator1 = "//button[*[name()='svg'][contains(@class,'lexicon-icon-times')]]",
				value1 = "\TAB");

			AssertElementFocused(
				key_panel = "Warnings",
				locator1 = "Panel#PANEL");

			Type.sendKeys(
				key_panel = "Warnings",
				locator1 = "Panel#PANEL",
				value1 = "keys=SHIFT,TAB");

			Type.sendKeys(
				locator1 = "//button[*[name()='svg'][contains(@class,'lexicon-icon-times')]]",
				value1 = "keys=SHIFT,TAB");

			KeyPress(
				key_text = "angle-left",
				locator1 = "Icon#ANY",
				value1 = "\ENTER");

			AssertElementFocused(locator1 = "//body");
		}
	}

}