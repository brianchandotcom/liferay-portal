@component-name = "portal-wcm"
definition {

	property ci.retries.disabled = "true";
	property portal.accessibility = "true";
	property portal.release = "true";
	property portal.upstream = "true";
	property testray.component.names = "Echo Accessibility";
	property testray.main.component.name = "Templates";

	setUp {
		task ("Set up instance and sign in") {
			TestCase.setUpPortalInstance();

			User.firstLoginPG();
		}

		task ("Add a site") {
			HeadlessSite.addSite(siteName = "Test Site Name");
		}
	}

	@description = "This is a use case for LPS-177722. Via Keyboard navigation is possible to access the edit mode of Widget Template and the tooltip of the back button is 'Go to Templates'"
	@priority = 2
	test ViewBackButtonTooltipInWidgetTemplateEditorViaKeyboard {
		task ("Given access to the Widget Template editor") {
			WidgetTemplates.openWidgetTemplatesAdmin(siteURLKey = "test-site-name");

			Navigator.gotoNavTab(navTab = "Widget Templates");

			LexiconEntry.gotoAdd();

			MenuItem.click(menuItem = "Asset Publisher Template");

			SiteAdmin.viewPortletTitle(portletTitle = "Add Asset Publisher Template");

			PortletEntry.inputName(name = "Test Widget Template");

			Click(
				key_fieldName = "Asset Entry",
				locator1 = "DDMEditTemplate#SCRIPT_FIELD");
		}

		task ("When hover on the back button via keyboard") {
			KeyPress(
				locator1 = "ProductMenu#TOGGLE",
				value1 = "\TAB");

			AssertElementFocused(locator1 = "Icon#BACK");
		}

		task ("Then see the tooltip message") {
			AssertVisible(
				key_content = "Go to Templates",
				locator1 = "Tooltip#FLOATING_TOOLTIP_CONTENT");
		}
	}

}