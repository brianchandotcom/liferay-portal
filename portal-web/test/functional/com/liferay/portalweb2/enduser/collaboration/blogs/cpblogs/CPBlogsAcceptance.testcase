<definition name="CPBlogsAcceptance">
	<var name="title" value="Title" />

	<command name="AddBlogsEntry">
		<execute macro="BlogsEntry#cpAdd" />

		<var name="title" value="Blogs Title" />

		<execute macro="BlogsEntry#cpAdd" />

		<execute macro="BlogsEntry#cpAdd">
			<param name="title" value="Blogs Entry Title" />
		</execute>
	</command>
	<tear-down>
		<execute macro="BlogsEntry#cpTearDown" />
	</tear-down>
</definition>