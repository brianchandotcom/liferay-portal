<html>
<head>
<title>CPSitepagesExport</title>
</head>
<body>
<table cellpadding="1" cellspacing="1" border="1">
<thead>
<tr><td rowspan="1" colspan="3">CPSitepagesExport</td></tr>
</thead>
<tbody>
<tr>
	<td>PAGE_NAME</td>
	<td></td>
	<td>CPSitepagesExport</td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<tr>
	<td>EXPORT_IFRAME</td>
	<td>//iframe[@id='_156_exportDialog_iframe_']</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<tr>
	<td>EXPORT_FILE_NAME</td>
	<td>//input[@id='_156_exportFileName']</td>
	<td></td>
</tr>
<tr>
	<td>EXPORT_BUTTON</td>
	<td>//button[contains(.,'Export')]</td>
	<td></td>
</tr>
<tr>
	<td>CANCEL_BUTTON</td>
	<td>//button[contains(.,'Cancel')]</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--NAVIGATION-->
<tr>
	<td>NAVIGATION_NEW_EXPORT_PROCESS</td>
	<td>//ul[contains(@class,'nav') and contains(@class,'nav-tabs')]/li/a[contains(.,'New Export Process')]</td>
	<td></td>
</tr>
<tr>
	<td>NAVIGATION_CURRENT_AND_PREVIOUS</td>
	<td>//ul[contains(@class,'nav') and contains(@class,'nav-tabs')]/li/a[contains(.,'Current and Previous')]</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--CONFIGURATION-->
<tr>
	<td>APPLICATION_CONFIGURATION_ALL_APPLICATIONS</td>
	<td>//label[contains(.,'All Applications')]/input</td>
	<td></td>
</tr>
<tr>
	<td>APPLICATION_CONFIGURATION_CHOOSE_APPLICATIONS</td>
	<td>//label[contains(.,'Choose Applications')]/input</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--CONTENT-->
<tr>
	<td>CONTENT_ALL_CONTENT</td>
	<td>//label[contains(.,'All Content')]/input</td>
	<td></td>
</tr>
<tr>
	<td>CONTENT_CHOOSE_CONTENT</td>
	<td>//label[contains(.,'Choose Content')]/input</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--PERMISSIONS-->
<tr>
	<td>PERMISSIONS_CHECK_BOX</td>
	<td>//label[contains(.,'Permissions')]/input[2]</td>
	<td></td>
</tr>
<tr>
	<td></td>
	<td></td>
	<td></td>
</tr>
<!--CURRENT_AND_PREVIOUS-->
<tr>
	<td>CURRENT_AND_PREVIOUS_INFO_MESSAGE</td>
	<td>//div[@class='incomplete-process-message']/div</td>
	<td></td>
</tr>
<tr>
	<td>CURRENT_AND_PREVIOUS_USER</td>
	<td>//tr[contains(.,'${key_larFileName}')]/td[1]</td>
	<td></td>
</tr>
<tr>
	<td>CURRENT_AND_PREVIOUS_STATUS</td>
	<td>//tr[contains(.,'${key_larFileName}')]/td[2]/strong</td>
	<td></td>
</tr>
<tr>
	<td>CURRENT_AND_PREVIOUS_CREATE_DATE</td>
	<td>//tr[contains(.,'${key_larFileName}')]/td[3]/span</td>
	<td></td>
</tr>
<tr>
	<td>CURRENT_AND_PREVIOUS_COMPLETION_DATE</td>
	<td>//tr[contains(.,'${key_larFileName}')]/td[4]/span</td>
	<td></td>
</tr>
<tr>
	<td>CURRENT_AND_PREVIOUS_DOWNLOAD</td>
	<td>//tr[contains(.,'${key_larFileName}')]/td[5]/span/a</td>
	<td></td>
</tr>
<tr>
	<td>CURRENT_AND_PREVIOUS_CLEAR</td>
	<td>//tr[contains(.,'${key_larFileName}')]/td[6]/span/a</td>
	<td></td>
</tr>
</tbody>
</table>
</body>
</html>