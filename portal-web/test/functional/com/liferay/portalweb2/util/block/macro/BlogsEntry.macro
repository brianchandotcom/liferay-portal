<definition>
	<command name="cpAdd">
		<execute action="CPBlogs#Click" locator-key="ADD_ENTRY"/>

		<execute action="CPBlogs#Type" locator-key="ENTRY_TITLE" value="${title}" />

		<execute action="CPBlogs#Type" locator-key="ENTRY_CONTENT" value="${content}" />

		<execute action="CPBlogs#Click" locator-key="SAVE" />
	</command>
	<command name="cpTearDown">
		<execute action="CPBlogs#Click" locator-key="DELETE_ENTRY" />
	</command>
</definition>