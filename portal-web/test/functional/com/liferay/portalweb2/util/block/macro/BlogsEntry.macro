<definition>
	<command name="cpAdd">
		<params>
			<param name="title" />
			<param name="content" />
		</params>
		<steps>
			<execute macro="CPBlogs#advancedSearch" />

			<execute action="CPBlogs#Click" locator-key="ADD_ENTRY" />
		</steps>
	</command>

	<command name="cpTearDown">
		<steps>
			<execute action="CPBlogs#Click" locator-key="DELETE_ENTRY" />
		</steps>
	</command>
</definition>