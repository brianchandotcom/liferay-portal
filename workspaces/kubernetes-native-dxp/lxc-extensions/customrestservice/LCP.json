{
  "kind": "Deployment",
  "id": "customrestservice",
  "image": "customrestservice",
  "cpu": 0.5,
  "scale": 1,
  "memory": 200,
  "loadBalancer": {
    "targetPort": 8081,
    "cdn": true
  },
  "environments": {
    "infra": {
      "deploy": false
    },
    "dev": {
      "loadBalancer": {
        "targetPort": 8081,
        "cdn": false
      }
    }
  }
}