{
	"cpu": 0.1,
	"environments": {
		"dev": {
			"loadBalancer": {
				"cdn": false,
				"targetPort": 80
			}
		},
		"infra": {
			"deploy": false
		}
	},
	"id": "liferaychatcustomelement",
	"kind": "Deployment",
	"livenessProbe": {
		"failureThreshold": 5,
		"httpGet": {
			"path": "/index.js",
			"port": 80
		},
		"initialDelaySeconds": 120,
		"periodSeconds": 60,
		"timeoutSeconds": 60
	},
	"loadBalancer": {
		"cdn": true,
		"targetPort": 80
	},
	"memory": 50,
	"readinessProbe": {
		"httpGet": {
			"path": "/index.js",
			"port": 80
		},
		"initialDelaySeconds": 30,
		"periodSeconds": 10,
		"successThreshold": 2,
		"timeoutSeconds": 5
	},
	"scale": 1
}