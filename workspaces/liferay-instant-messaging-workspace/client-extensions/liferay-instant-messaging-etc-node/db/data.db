{"clientId":"bot_44772","type":"MessageNotification","name":"Chat","data":{"from":"31323334353637383930313233343536:05fba74b47bedbb984e1a8583b06a5d3","to":"31323334353637383930313233343536:2ff52ef52e56036e82199f8c3ddc813d","message":"context: 'Our aim is to deliver exceptional customer experiences, drive business growth, and foster a culture of excellence across our organization. We strive to achieve this by continuously improving our processes, enhancing our services, and ensuring that our customers receive the best possible support. We aim to be a trusted and reliable partner for our customers, providing them with the best possible solutions and services. We are committed to delivering results that are aligned with our values and goals, and we are dedicated to continuously improving and growing our business.'","chatMessageType":"Text","date":1739791085426},"_id":"IQSmD7n9R4AL8GGf"}
{"clientId":"bot_54701","type":"MessageNotification","name":"Chat","data":{"from":"31323334353637383930313233343536:1222827d9784c14eb902377528ec606b","to":"31323334353637383930313233343536:d0a00e49305c0b081e75997d3326eafb","message":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n\t<meta charset=\"UTF-8\">\n\t<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\t<title>Bootstrap Card Example</title>\n</head>\n<body>\n\t<div class=\"card\">\n\t\t<div class=\"card-header\">\n\t\t\t<h2 class=\"card-title\">Bootstrap Card Example</h2>\n\t\t</div>\n\t\t<div class=\"card-body\">\n\t\t\t<h3 class=\"card-title\">Bootstrap Card Example</h3>\n\t\t\t<p class=\"card-text\">This is a basic bootstrap card example with image and text.</p>\n\t\t</div>\n\t\t<div class=\"card-footer\">\n\t\t\t<button class=\"btn btn-primary\">Click me</button>\n\t\t</div>\n\t</div>\n</body>\n</html>\n\n<script src=\"card.js\"></script>\n\n<script>\nimport { useState, useEffect } from 'react';\nimport { Card, Button } from 'react-material-ui';\n\nfunction CardExample() {\n\tconst [isLoading, setIsLoading] = useState(true);\n\tconst [data, setData] = useState([]);\n\n\tuseEffect(() => {\n\t\tfetch('https://example.com/api/data')\n\t\t\t.then(response => response.json())\n\t\t\t.then(data => setData(data))\n\t\t\t.catch(error => console.error('Error:', error));\n\t}, []);\n\n\treturn (\n\t\t<div class=\"card\">\n\t\t\t<div class=\"card-header\">\n\t\t\t\t<h2 class=\"card-title\">Bootstrap Card Example</h2>\n\t\t\t</div>\n\t\t\t<div class=\"card-body\">\n\t\t\t\t<h3 class=\"card-title\">Bootstrap Card Example</h3>\n\t\t\t\t<p class=\"card-text\">This is a basic bootstrap card example with image and text.</p>\n\t\t\t</div>\n\t\t\t<div class=\"card-footer\">\n\t\t\t\t<button class=\"btn btn-primary\">Click me</button>\n\t\t\t</div>\n\t\t</div>\n\t);\n}\n\nexport default CardExample;\n</script>","chatMessageType":"Text","date":1739197602443},"_id":"ISn6Q5UjJjdAMEIe"}
