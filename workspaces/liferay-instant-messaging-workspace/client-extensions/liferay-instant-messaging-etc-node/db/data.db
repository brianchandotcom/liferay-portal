{"clientId":"bot_55389","type":"MessageNotification","name":"Chat","data":{"from":"31323334353637383930313233343536:13a402f55c5598575ac91b5fdc621ac6","to":"31323334353637383930313233343536:d0a00e49305c0b081e75997d3326eafb","message":"<!DOCTYPE html>\n<html>\n<head>\n\t<title>Card Example</title>\n\t<style>\n\t\t.card {\n\t\t\twidth: 100%;\n\t\t\theight: 100%;\n\t\t\tbackground-color: #f2f2f2;\n\t\t\tcolor: #fff;\n\t\t\tmargin: 0;\n\t\t\tpadding: 0;\n\t\t\tborder: 0;\n\t\t\tbox-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n\t\t}\n\n\t\t.header {\n\t\t\tbackground-color: #f2f2f2;\n\t\t\tcolor: #fff;\n\t\t\tfont-size: 24px;\n\t\t\tline-height: 1.5;\n\t\t\tmargin: 0;\n\t\t\tpadding: 0;\n\t\t\tborder: 0;\n\t\t\tbox-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n\t\t}\n\n\t\t.description {\n\t\t\tfont-size: 18px;\n\t\t\tline-height: 1.5;\n\t\t\tmargin: 0;\n\t\t\tpadding: 0;\n\t\t\tborder: 0;\n\t\t\tbox-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n\t\t}\n\n\t\t.card-header {\n\t\t\ttext-align: center;\n\t\t\tmargin-top: 20px;\n\t\t}\n\n\t\t.card-body {\n\t\t\tmargin-top: 20px;\n\t\t\tpadding: 10px;\n\t\t}\n\n\t\t.card-text {\n\t\t\ttext-align: center;\n\t\t\tmargin-top: 20px;\n\t\t}\n\t</style>\n</head>\n<body>\n\t<div class=\"card\">\n\t\t<div class=\"header\">\n\t\t\t<h1>Card Example</h1>\n\t\t\t<p>This is a card with an image, header, and description.</p>\n\t\t</div>\n\t\t<div class=\"description\">\n\t\t\tThis is a card with an image, header, and description.\n\t\t</div>\n\t</div>\n</body>\n</html>","chatMessageType":"Text","date":1739199489327},"_id":"8txmiVXS29KuicOv"}
