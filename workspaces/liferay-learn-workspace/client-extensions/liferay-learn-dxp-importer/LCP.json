{
	"concurrencyPolicy": "Forbid",
	"cpu": 4,
	"env": {
		"LIFERAY_DATA_DEFINITION_KEY": "LEARN-ARTICLE",
		"LIFERAY_GROUP_FRIENDLY_URL_PATH": "guest",
		"LIFERAY_LEARN_GITHUB_BRANCH": "master",
		"LIFERAY_LEARN_GITHUB_DEPLOY_KEY": "@liferay-learn-github-deploy-key",
		"LIFERAY_LEARN_GITHUB_REPO": "@liferay-learn-github-repo",
		"LIFERAY_OAUTH_CLIENT_ID": "@liferay-oauth-client-id",
		"LIFERAY_OAUTH_CLIENT_SECRET": "@liferay-oauth-client-secret",
		"LIFERAY_URL": "@liferay-url",
		"MARKDOWN_IMPORT_DIR": "../docs",
		"SLACK_CHANNEL": "#is-sites-learn-devops",
		"SLACK_ENDPOINT": "@slack-endpoint"
	},
	"environments": {
		"extprd": {
			"env": {
				"SLACK_CHANNEL": "#is-sites-learn-devops-prd"
			}
		},
		"infra": {
			"deploy": false
		}
	},
	"id": "liferaylearndxpimporter",
	"kind": "CronJob",
	"memory": 3000,
	"scale": 1,
	"schedule": "0 14 * * *"
}