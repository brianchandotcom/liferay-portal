				<default>true</default>
			</transition>
			<transition>
				<labels>
					<label language-id="en_US">
						Escalate to Documentation
					</label>
				</labels>
				<name>official-documentation-knowledge-article</name>
				<target>In Documentation</target>
				<default>false</default>
			</transition>
