exports[`SelectItemsModal renders 1`] = `
<div>
  <div
    aria-modal="true"
    class="modal-dialog searchable-modal-root modal-lg"
    role="dialog"
  >
    <div
      class="modal-content"
    >
      <div
        class="modal-header has-title"
      >
        <div
          class="h4 modal-title"
        >
          Select Fields
        </div>
        <button
          aria-label="Close"
          class="button-root close btn btn-secondary"
          type="button"
        >
          <svg
            class="lexicon-icon lexicon-icon-times icon-root"
            role="presentation"
          >
            <use
              href="#times"
            />
          </svg>
        </button>
      </div>
      <div
        class="toolbar-root"
      >
        <nav
          class="navbar navbar-root management-bar management-bar-light navbar-expand"
        >
          <div
            class="container-fluid"
          >
            <ul
              class="nav-root front-nav navbar-nav"
              role="tablist"
            />
            <div
              class="mx-2 navbar-form navbar-form-autofit"
            >
              <div
                class="input-group search"
              >
                <div
                  class="input-group-item"
                >
                  <input
                    class="input-root form-control input-group-inset input-group-inset-after"
                    placeholder="Search"
                    type="text"
                    value=""
                  />
                  <div
                    class="input-group-inset-item input-group-inset-item-after"
                  >
                    <button
                      aria-label="Search"
                      class="button-root btn btn-unstyled"
                      type="button"
                    >
                      <svg
                        class="lexicon-icon lexicon-icon-search icon-root"
                        role="presentation"
                      >
                        <use
                          href="#search"
                        />
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </nav>
      </div>
      <div
        class="scroll-container"
      >
        <span
          aria-hidden="true"
          class="loading-root center loading-animation"
        />
      </div>
      <div
        class="modal-footer"
      >
        <div
          class="modal-footer"
        >
          <button
            class="button-root btn btn-secondary"
            type="button"
          >
            Cancel
          </button>
          <button
            class="button-root btn btn-primary"
            disabled=""
            type="button"
          >
            Select
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
`;

