{
	"compilerOptions": {
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"baseUrl": "./src/main/js",
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"jsx": "react-jsx",
		"module": "esnext",
		"moduleResolution": "node",
		"outDir": "build",
		"paths": {
			"@liferay/frontend-data-set-web": [
				"../../../../../../../modules/apps/frontend-data-set/frontend-data-set-web/src/main/resources/META-INF/resources/index.ts"
			]
		},
		"skipLibCheck": true,
