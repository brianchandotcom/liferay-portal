definition {

	@summary = "Default summary"
	macro activityCollapseButton(button = null) {
		Click.mouseDownMouseUp(
			key_textButton = ${button},
			locator1 = "PRMMDFRequest#TEXT_BUTTON");
	}

	@summary = "Default summary"
	macro addNewActivity() {
		Click(
			key_buttonText = "Add Activity",
			locator1 = "PRMMDFRequest#ADD_BUTTON");
	}

	@summary = "Default summary"
	macro assertClaimMessage(claimMessage = null) {
		var key_claimMessage = ${claimMessage};

		AssertTextEquals.assertPartialText(
			locator1 = "PRMMDFRequest#CLAIM_MESSAGE",
			value1 = ${claimMessage});
	}

	@summary = "Default summary"
	macro CanNotViewStateManager() {
		AssertElementNotPresent(locator1 = "PRMMDFRequest#STATUS_DROPDOWN");
	}

	@summary = "Default summary"
	macro changeMDFStatus(statusButton = null) {
		var key_statusButton = ${statusButton};

		if (${statusButton} == "Cancel") {
			ClickNoError(locator1 = "Button#CANCEL");

			Confirm.acceptAlert();
		}
		else {
			ScrollWebElementIntoView(locator1 = "PRMMDFRequest#STATUS_DROPDOWN");

			ClickNoError(locator1 = "PRMMDFRequest#STATUS_DROPDOWN");

			ClickNoError(
				key_statusButton = ${statusButton},
				locator1 = "PRMMDFRequest#STATUS_OPTION_DROPDOWN");
		}

		if ((${statusButton} == "Request More Info") || (${statusButton} == "Marketing Director Review") || (${statusButton} == "Rejected")) {
			if (!(isSet(statusChangeMotivation))) {
				var statusChangeMotivation = "Status Change Motivation";
			}

			Type(
				key_fieldId = "descriptionTextArea",
				locator1 = "TextArea#ANY_ID",
				value1 = ${statusChangeMotivation});

			Button.click(button = ${statusButton});

			SelectFrameTop();
		}
	}

	@summary = "Default summary"
	macro createNewRequest(requireLiferay = null,goalsOptions = null,accountName = null,leadList = null,activityName = null,leadFollowUpList = null,tactic = null,additionalOptions = null,followUpStrategy = null,nurtureDripCampaign = null,typeOfActivity = null,targetRolesOptions = null,budgetList = null,campaignDescription = null,targetMarketOptions = null,activityDescription = null,ofWeek = null,targetOfLeads = null,campaignName = null) {
		WaitForPageLoad();

		PRMMDFRequest.fillGoalsPage(
			accountName = ${accountName},
			additionalOptions = ${additionalOptions},
			campaignDescription = ${campaignDescription},
			campaignName = ${campaignName},
			goalsOptions = ${goalsOptions},
			targetMarketOptions = ${targetMarketOptions},
			targetRolesOptions = ${targetRolesOptions});

		Button.click(button = "Continue");

		PRMMDFRequest.newActivity(
			activityDescription = ${activityDescription},
			activityName = ${activityName},
			budgetList = ${budgetList},
			followUpStrategy = ${followUpStrategy},
			leadFollowUpList = ${leadFollowUpList},
			leadList = ${leadList},
			nurtureDripCampaign = ${nurtureDripCampaign},
			ofWeek = ${ofWeek},
			requireLiferay = ${requireLiferay},
			tactic = ${tactic},
			targetOfLeads = ${targetOfLeads},
			typeOfActivity = ${typeOfActivity});

		Button.click(button = "Continue");

		Button.click(button = "Continue");

		ScrollWebElementIntoView(locator1 = "Button#SUBMIT");

		if (isSet(saveAsDraft)) {
			Button.click(button = "Save as Draft");
		}
		else {
			Button.click(button = "Submit");

			WaitForPageLoad();

			Alert.viewSuccessMessage();
		}
	}

	@summary = "Default summary"
	macro editActivity(newActivityName = null,removeBudgetByIndex = null,activityName = null,newBugdetValue = null) {
		Click(
			key_activityName = ${activityName},
			locator1 = "PRMMDFRequest#EDIT_ACTIVITY_BUTTON");

		if (!(isSet(activitiyIndex))) {
			var activityIndex = 1;
		}

		if (!(isSet(budgetIndex))) {
			var budgetIndex = 0;
		}

		if (isSet(newActivityName)) {
			Type(
				key_fieldName = "activities[${activityIndex}].name",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${newActivityName});
		}

		if (isSet(newBugdetValue)) {
			Type(
				key_fieldName = "activities[${activityIndex}].budgets[${budgetIndex}].cost",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${newBugdetValue});
		}

		if (isSet(removeBudgetByIndex)) {
			PRMMDFRequest.removeBudgetValue(index = ${removeBudgetByIndex});

			PRMMDFRequestEdit.viewBudgetNotPresent(budgetIndex = 3);
		}
	}

	@summary = "Default summary"
	macro editButton() {
		Click(locator1 = "PRMMDFRequest#EDIT_MDF_BUTTON");
	}

	@summary = "Default summary"
	macro editGoals(goalsOptions = null,additionalOptions = null,accountName = null,targetRolesOptions = null,campaignDescription = null,targetMarketOptions = null,campaignName = null) {
		PRMMDFRequest.fillGoalsPage(
			accountName = ${accountName},
			additionalOptions = ${additionalOptions},
			campaignDescription = ${campaignDescription},
			campaignName = ${campaignName},
			goalsOptions = ${goalsOptions},
			targetMarketOptions = ${targetMarketOptions},
			targetRolesOptions = ${targetRolesOptions});
	}

	@summary = "Default summary"
	macro editMDF(goalsOptions = null,accountName = null,leadList = null,removeBudgetByIndex = null,activityIndex = null,activityName = null,leadFollowUpList = null,tactic = null,removeActivity = null,additionalOptions = null,followUpStrategy = null,typeOfActivity = null,newActivityName = null,targetRolesOptions = null,budgetList = null,campaignDescription = null,newBugdetValue = null,targetMarketOptions = null,activityDescription = null,newActivity = null,targetOfLeads = null,campaignName = null) {
		PRMMDFRequest.editGoals(
			accountName = ${accountName},
			additionalOptions = ${additionalOptions},
			campaignDescription = ${campaignDescription},
			campaignName = ${campaignName},
			goalsOptions = ${goalsOptions},
			targetMarketOptions = ${targetMarketOptions},
			targetRolesOptions = ${targetRolesOptions});

		Button.click(button = "Continue");

		if (isSet(newActivity)) {
			PRMMDFRequest.newActivity(
				activityDescription = ${activityDescription},
				activityName = ${newActivity},
				budgetList = ${budgetList},
				followUpStrategy = ${followUpStrategy},
				leadFollowUpList = ${leadFollowUpList},
				leadList = ${leadList},
				tactic = ${tactic},
				targetOfLeads = ${targetOfLeads},
				typeOfActivity = ${typeOfActivity});

			Button.click(button = "Continue");
		}

		if (isSet(removeActivity)) {
			Click(
				key_activityName = ${removeActivity},
				locator1 = "PRMMDFRequestEdit#REMOVE_ACTIVITY_ICON");

			AssertElementNotPresent(
				key_activityName = ${removeActivity},
				locator1 = "PRMMDFRequestEdit#ACTIVITY_ON_LIST");
		}

		if (isSet(activityName)) {
			PRMMDFRequest.editActivity(
				activityIndex = ${activityIndex},
				activityName = ${activityName},
				newActivityName = ${newActivityName},
				newBugdetValue = ${newBugdetValue},
				removeBudgetByIndex = ${removeBudgetByIndex});

			Button.click(button = "Continue");
		}

		Button.click(button = "Continue");

		ScrollWebElementIntoView(locator1 = "Button#SUBMIT");

		Button.click(button = "Submit");

		WaitForPageLoad();

		Alert.viewSuccessMessage();
	}

	@summary = "Default summary"
	macro editTotalMDFValue(newValue = null) {
		if (!(isSet(activitiyIndex))) {
			var activityIndex = 0;
		}

		Type(
			key_fieldName = "activities[${activityIndex}].mdfRequestAmount",
			locator1 = "PRMMDFRequest#TEXT_FIELD",
			value1 = ${newValue});

		KeyPress(
			key_fieldName = "activities[${activityIndex}].mdfRequestAmount",
			locator1 = "PRMMDFRequest#TEXT_FIELD",
			value1 = "\TAB");
	}

	@summary = "Default summary"
	macro fillExpenseFields(budgetList = null) {
		var budgetIndex = 0;

		for (var bugdetValues : list ${budgetList}) {
			var expenseOption = StringUtil.extractFirst(${bugdetValues}, "-");
			var bugdetValue = StringUtil.extractLast(${bugdetValues}, "-");

			if (!(isSet(activityIndex))) {
				var activityIndex = 0;
			}

			Click(
				key_buttonText = "Add Expense",
				locator1 = "PRMMDFRequest#ADD_BUTTON");

			Select(
				key_fieldName = "activities[${activityIndex}].budgets[${budgetIndex}].expense",
				locator1 = "PRMMDFRequest#SELECT",
				value1 = ${expenseOption});

			Type(
				key_fieldName = "activities[${activityIndex}].budgets[${budgetIndex}].cost",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${bugdetValue});

			var budgetIndex = ${budgetIndex} + 1;
		}
	}

	@summary = "Default summary"
	macro fillGoalsPage(goalsOptions = null,additionalOptions = null,accountName = null,targetRolesOptions = null,campaignDescription = null,targetMarketOptions = null,campaignName = null) {
		if (isSet(accountName)) {
			Select(
				key_fieldName = "company",
				locator1 = "PRMMDFRequest#SELECT",
				value1 = ${accountName});
		}

		if (isSet(campaignName)) {
			Type(
				key_fieldName = "overallCampaignName",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${campaignName});
		}

		if (isSet(campaignDescription)) {
			Type(
				key_fieldName = "overallCampaignDescription",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${campaignDescription});
		}

		if (isSet(goalsOptions)) {
			for (var goalsList : list ${goalsOptions}) {
				Click.clickAtNotVisible(
					key_fieldName = "liferayBusinessSalesGoals",
					key_optionValue = ${goalsList},
					locator1 = "PRMMDFRequest#CHECKBOX");
			}
		}

		if (isSet(targetMarketOptions)) {
			for (var targetMarketList : list ${targetMarketOptions}) {
				Click.clickAtNotVisible(
					key_fieldName = "targetMarkets",
					key_optionValue = ${targetMarketList},
					locator1 = "PRMMDFRequest#CHECKBOX");
			}
		}

		if (isSet(additionalOptions)) {
			for (var optionsList : list ${additionalOptions}) {
				Click.pauseClickAt(
					key_buttonText = ${optionsList},
					key_fieldName = "additionalOption",
					locator1 = "PRMMDFRequest#INPUT_BUTTON");
			}
		}

		if (isSet(targetRolesOptions)) {
			for (var targetRolesList : list ${targetRolesOptions}) {
				Click.clickAtNotVisible(
					key_fieldName = "targetAudienceRoles",
					key_optionValue = ${targetRolesList},
					locator1 = "PRMMDFRequest#CHECKBOX");
			}
		}
	}

	@summary = "Default summary"
	macro filterMDF(filterOption = null,checkboxName = null) {
		Button.click(button = "Filter");

		Click(
			key_text = ${filterOption},
			locator1 = "Button#ANY_WITH_SPAN");

		Click.clickAtNotVisible(
			checkboxName = ${checkboxName},
			locator1 = "PRMMDFRequest#FILTER_CHECKBOX");

		Click(locator1 = "PRMMDFRequest#APPLY_BUTTON");
	}

	@summary = "Default summary"
	macro formatDate() {
		var nextDayDate = DateUtil.getFormattedDate("+2", "MMddyyyy");

		if (isSet(endDate)) {
			var nextDayDate = DateUtil.getFormattedDate("+3", "MMddyyyy");
		}

		return ${nextDayDate};
	}

	@summary = "Default summary"
	macro getRequestID(requestIndex = null,mdfType = null) {
		var key_index = ${requestIndex};
		var key_mdfType = ${mdfType};

		WaitForElementPresent(locator1 = "PRMMDFRequest#MDF_ID_BY_INDEX");

		var requestID = selenium.getText("PRMMDFRequest#MDF_ID_BY_INDEX");

		var requestID = StringUtil.extractLast(${requestID}, "-");

		return ${requestID};
	}

	@summary = "Default summary"
	macro getValueByFieldName(fieldName = null) {
		Click.pauseClickAt(
			key_fieldName = ${fieldName},
			locator1 = "PRMMDFRequest#TEXT_FIELD");

		var javaScriptCountElement = '''
        
        return document.querySelector("input[name='${fieldName}']").value;

        ''';

		var fieldValue = selenium.getEval(${javaScriptCountElement});

		var fieldDigits = StringUtil.extractDigits(${fieldValue});

		return ${fieldDigits};
	}

	@summary = "Default summary"
	macro goToMDF(requestID = null,campaignName = null) {
		if (isSet(campaignName)) {
			Click(
				key_campaignName = ${campaignName},
				locator1 = "PRMMDFRequest#REQUEST_ID");
		}

		if (isSet(requestID)) {
			Click(
				key_requestID = ${requestID},
				locator1 = "PRMMDFRequest#REQUEST_ID");
		}
	}

	@summary = "Default summary"
	macro insertDate(fieldName = null,dateRange = null,dateFormat = null) {
		if (!(isSet(activityIndex))) {
			var activityIndex = 0;
		}

		var currentDate = DateUtil.getFormattedDate(${dateRange}, ${dateFormat});

		if (${fieldName} == "startDate") {
			Type.sendKeys(
				key_fieldName = "activities[${activityIndex}].startDate",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${currentDate});

			Click(
				key_fieldName = "activities[${activityIndex}].endDate",
				locator1 = "PRMMDFRequest#TEXT_FIELD");
		}

		if (${fieldName} == "endDate") {
			Type.sendKeys(
				key_fieldName = "activities[${activityIndex}].endDate",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${currentDate});

			Click(
				key_fieldName = "activities[${activityIndex}].startDate",
				locator1 = "PRMMDFRequest#TEXT_FIELD");
		}
	}

	@summary = "Default summary"
	macro newActivity(requireLiferay = null,leadList = null,activityName = null,leadFollowUpList = null,tactic = null,nurtureDripCampaign = null,followUpStrategy = null,typeOfActivity = null,budgetList = null,activityDescription = null,ofWeek = null,targetOfLeads = null) {
		if (!(isSet(activityIndex))) {
			var activityIndex = 0;
		}

		Click(
			key_buttonText = "Add Activity",
			locator1 = "PRMMDFRequest#ADD_BUTTON");

		Type(
			key_fieldName = "activities[${activityIndex}].name",
			locator1 = "PRMMDFRequest#TEXT_FIELD",
			value1 = ${activityName});

		Select(
			key_fieldName = "activities[${activityIndex}].typeActivity",
			locator1 = "PRMMDFRequest#SELECT",
			value1 = ${typeOfActivity});

		Select(
			key_fieldName = "activities[${activityIndex}].tactic",
			locator1 = "PRMMDFRequest#SELECT",
			value1 = ${tactic});

		if ((${typeOfActivity} == "Miscellaneous Marketing") && ((${tactic} == "Other") || (${tactic} == "List Purchase"))) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.marketingActivity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${activityDescription});

			Click.clickAtNotVisible(
				key_buttonText = ${leadList},
				key_fieldName = "activities[${activityIndex}].activityDescription.leadGenerated",
				locator1 = "PRMMDFRequest#INPUT_BUTTON");
		}

		if ((${typeOfActivity} == "Miscellaneous Marketing") && ((${tactic} == "Print Advertising") || (${tactic} == "Campaign with Industry Publication"))) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.marketingActivity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${activityDescription});

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.publication",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Publication");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.cta",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity CTA");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.expectedImpressions",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Expected Impressions");
		}

		if ((${typeOfActivity} == "Miscellaneous Marketing") && (${tactic} == "Broadcast Advertising")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.marketingActivity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${activityDescription});

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.broadcastChannel",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Broadcast Channel");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.cta",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity CTA");

			if (isSet(ofWeek)) {
				Type(
					key_fieldName = "activities[${activityIndex}].activityDescription.weeksAiring",
					locator1 = "PRMMDFRequest#TEXT_FIELD",
					value1 = ${ofWeek});
			}

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.guaranteedImpressions",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Guaranteed Impressions");
		}

		if ((${typeOfActivity} == "Miscellaneous Marketing") && (${tactic} == "Co-branded Merchandise")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.marketingActivity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${activityDescription});

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.typeMerchandise",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Type Merchandise");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.quantity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = 5);
		}

		if ((${typeOfActivity} == "Miscellaneous Marketing") && (${tactic} == "Direct Mail")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.marketingActivity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${activityDescription});

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.targetOfSends",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = 5);

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.cta",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity CTA");
		}

		if ((${typeOfActivity} == "Miscellaneous Marketing") && (${tactic} == "Outbound Telemarketing Sales")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.marketingActivity",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${activityDescription});

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.audienceTarget",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Audience Target");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.sourceAndSizeOfCallList",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Call List");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.resourcesNecessaryFromLiferay",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Resources Liferay");
		}

		if ((${typeOfActivity} == "Event") && ((${tactic} == "In-person networking event/seminar/meet-up") || (${tactic} == "In-person industry conference/trade show"))) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.description",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Description");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.location",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Location");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.venueName",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Venue Name");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.liferayBranding",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Required");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.liferayParticipationRequirements",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Partipation");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.sourceAndSizeOfInviteeList",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Invite List");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.activityPromotion",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Promotion");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.targetOfLeads",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = 03);

			for (var leadFollowUp : list ${leadFollowUpList}) {
				Click.clickAtNotVisible(
					key_fieldName = "activities[${activityIndex}].activityDescription.leadFollowUpStrategies",
					key_optionValue = ${leadFollowUp},
					locator1 = "PRMMDFRequest#CHECKBOX");
			}

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.detailsLeadFollowUp",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "FollowUp Strategy");
		}

		if ((${typeOfActivity} == "Event") && (${tactic} == "Webinar")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.description",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Description");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.webinarTopic",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Webinar");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.webinarHostPlatform",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Host");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.liferayBranding",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Required");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.liferayParticipationRequirements",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Partipation");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.sourceAndSizeOfInviteeList",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Invitee List");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.activityPromotion",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Activity Promotion");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.targetOfLeads",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = 03);

			for (var leadFollowUp : list ${leadFollowUpList}) {
				Click.clickAtNotVisible(
					key_fieldName = "activities[${activityIndex}].activityDescription.leadFollowUpStrategies",
					key_optionValue = ${leadFollowUp},
					locator1 = "PRMMDFRequest#CHECKBOX");
			}

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.detailsLeadFollowUp",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "FollowUp Strategy");
		}

		if ((${typeOfActivity} == "Digital Marketing") && (${tactic} == "Digital Advertising/Banner Ad")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.overallMessageContentCTA",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Overall Message");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.specificSites",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Specific Site");

			Click.clickAtNotVisible(
				key_buttonText = "No",
				key_fieldName = "activities[${activityIndex}].activityDescription.assetsLiferayRequired",
				locator1 = "PRMMDFRequest#INPUT_BUTTON");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.howLiferayBrandUsed",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Liferay Brand");
		}

		if (${typeOfActivity} == "Content Marketing") {
			Click.clickAtNotVisible(
				key_buttonText = "No",
				key_fieldName = "activities[${activityIndex}].activityDescription.gatedLandingPage",
				locator1 = "PRMMDFRequest#INPUT_BUTTON");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.primaryThemeOrMessage",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Primary Theme");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.goalOfContent",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Goal of Content");

			Click.clickAtNotVisible(
				key_buttonText = "No",
				key_fieldName = "activities[${activityIndex}].activityDescription.hiringOutsideWriterOrAgency",
				locator1 = "PRMMDFRequest#INPUT_BUTTON");
		}

		if ((${typeOfActivity} == "Digital Marketing") && (${tactic} == "Email Campaign")) {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.overallMessageContentCTA",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Overall Message");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.landingPageCopy",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Landing Page");

			if (isSet(nurtureDripCampaign)) {
				Click.clickAtNotVisible(
					key_buttonText = ${nurtureDripCampaign},
					key_fieldName = "activities[${activityIndex}].activityDescription.nurtureDripCampaign",
					locator1 = "PRMMDFRequest#INPUT_BUTTON");

				if (${nurtureDripCampaign} == "Yes") {
					Type(
						key_fieldName = "activities[${activityIndex}].activityDescription.manySeries",
						locator1 = "PRMMDFRequest#TEXT_FIELD",
						value1 = 200);
				}
			}

			if (isSet(requireLiferay)) {
				Click.clickAtNotVisible(
					key_buttonText = ${requireLiferay},
					key_fieldName = "activities[${activityIndex}].activityDescription.assetsLiferayRequired",
					locator1 = "PRMMDFRequest#INPUT_BUTTON");

				if (${requireLiferay} == "Yes") {
					Type(
						key_fieldName = "activities[${activityIndex}].activityDescription.assetsLiferayDescription",
						locator1 = "PRMMDFRequest#TEXT_FIELD",
						value1 = "Require Liferay");
				}
			}

			Click.clickAtNotVisible(
				key_buttonText = "Yes",
				key_fieldName = "activities[${activityIndex}].activityDescription.usingCIABAssets",
				locator1 = "PRMMDFRequest#INPUT_BUTTON");

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.howLiferayBrandUsed",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = "Liferay Brand");
		}

		if (isSet(leadList)) {
			Click.clickAtNotVisible(
				key_buttonText = ${leadList},
				key_fieldName = "activities[${activityIndex}].activityDescription.leadGenerated",
				locator1 = "PRMMDFRequest#INPUT_BUTTON");
		}

		if (${leadList} == "Yes") {
			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.targetOfLeads",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${targetOfLeads});

			for (var leadFollowUp : list ${leadFollowUpList}) {
				Click.clickAtNotVisible(
					key_fieldName = "activities[${activityIndex}].activityDescription.leadFollowUpStrategies",
					key_optionValue = ${leadFollowUp},
					locator1 = "PRMMDFRequest#CHECKBOX");
			}

			Type(
				key_fieldName = "activities[${activityIndex}].activityDescription.detailsLeadFollowUp",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${followUpStrategy});
		}

		if (!(isSet(startDate))) {
			var startDate = PRMMDFRequest.formatDate();
		}

		Type.sendKeys(
			key_fieldName = "activities[${activityIndex}].startDate",
			locator1 = "PRMMDFRequest#TEXT_FIELD",
			value1 = ${startDate});

		if (!(isSet(endDate))) {
			var endDate = PRMMDFRequest.formatDate(endDate = "true");
		}

		Type.sendKeys(
			key_fieldName = "activities[${activityIndex}].endDate",
			locator1 = "PRMMDFRequest#TEXT_FIELD",
			value1 = ${endDate});

		var budgetIndex = 0;

		for (var bugdetValues : list ${budgetList}) {
			var expenseOption = StringUtil.extractFirst(${bugdetValues}, "-");
			var bugdetValue = StringUtil.extractLast(${bugdetValues}, "-");

			Click(
				key_buttonText = "Add Expense",
				locator1 = "PRMMDFRequest#ADD_BUTTON");

			Select(
				key_fieldName = "activities[${activityIndex}].budgets[${budgetIndex}].expense",
				locator1 = "PRMMDFRequest#SELECT",
				value1 = ${expenseOption});

			Type(
				key_fieldName = "activities[${activityIndex}].budgets[${budgetIndex}].cost",
				locator1 = "PRMMDFRequest#TEXT_FIELD",
				value1 = ${bugdetValue});

			var budgetIndex = ${budgetIndex} + 1;
		}
	}

	@summary = "Default summary"
	macro removeBudgetValue(index = null) {
		Click.pauseClickAt(
			key_index = ${index},
			locator1 = "PRMMDFRequest#REMOVE_ICON_INDEX");
	}

	@summary = "Default summary"
	macro searchMDF(requestID = null,campaignName = null) {
		WaitForElementPresent(
			key_placeHolder = "Search",
			locator1 = "TextInput#ANY_PLACEHOLDER");

		if (isSet(campaignName)) {
			Type(
				key_placeHolder = "Search",
				locator1 = "TextInput#ANY_PLACEHOLDER",
				value1 = ${campaignName});
		}

		if (isSet(requestID)) {
			Type(
				key_placeHolder = "Search",
				locator1 = "TextInput#ANY_PLACEHOLDER",
				value1 = ${requestID});
		}

		KeyPress(
			key_placeHolder = "Search",
			locator1 = "TextInput#ANY_PLACEHOLDER",
			value1 = "\RETURN");
	}

	@summary = "Default summary"
	macro viewActivityInReviewPage(typeOfActivity = null,endDate = null,leadList = null,activityName = null,activityDescription = null,startDate = null,bugdetValue = null,tactic = null,expenseOption = null) {
		Click(
			key_textButton = ${activityName},
			locator1 = "PRMMDFRequest#TEXT_BUTTON");

		ScrollWebElementIntoView(
			key_fieldName = "Activity name",
			key_fieldValue = ${activityName},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertElementPresent(
			key_fieldName = "Activity name",
			key_fieldValue = ${activityName},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		ScrollWebElementIntoView(
			key_fieldName = "Type of Activity",
			key_fieldValue = ${typeOfActivity},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertElementPresent(
			key_fieldName = "Type of Activity",
			key_fieldValue = ${typeOfActivity},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		ScrollWebElementIntoView(
			key_fieldName = "Tactic",
			key_fieldValue = ${tactic},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertElementPresent(
			key_fieldName = "Tactic",
			key_fieldValue = ${tactic},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		ScrollWebElementIntoView(
			key_fieldName = "Marketing activity",
			key_fieldValue = ${activityDescription},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertElementPresent(
			key_fieldName = "Marketing activity",
			key_fieldValue = ${activityDescription},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		ScrollWebElementIntoView(
			key_fieldName = "Start Date",
			key_fieldValue = ${startDate},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertTextEquals.assertPartialText(
			key_fieldName = "Start Date",
			key_fieldValue = ${startDate},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD",
			value1 = ${startDate});

		ScrollWebElementIntoView(
			key_fieldName = "End Date",
			key_fieldValue = ${endDate},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertTextEquals.assertPartialText(
			key_fieldName = "End Date",
			key_fieldValue = ${endDate},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD",
			value1 = ${endDate});

		ScrollWebElementIntoView(
			key_fieldName = ${expenseOption},
			key_fieldValue = ${bugdetValue},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertElementPresent(
			key_fieldName = ${expenseOption},
			key_fieldValue = ${bugdetValue},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		ScrollWebElementIntoView(
			key_fieldName = "Is a lead list an outcome of this activity?",
			key_fieldValue = ${leadList},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");

		AssertElementPresent(
			key_fieldName = "Is a lead list an outcome of this activity?",
			key_fieldValue = ${leadList},
			locator1 = "PRMMDFRequest#SUMMARY_FIELD");
	}

