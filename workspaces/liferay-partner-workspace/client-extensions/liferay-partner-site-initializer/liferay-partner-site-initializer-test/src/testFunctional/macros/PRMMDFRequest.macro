	@summary = "Default summary"
	macro viewExportedMDF(fileName = null,fileContentList = null,fileContentNotPresent = null) {
		DownloadTempFile();

		var directoryPath = PropsUtil.get("output.dir.name");

		var tempFileDir = FileUtil.read("${directoryPath}/${fileName}");

		if (isSet(fileContentList)) {
			for (var fileContent : list ${fileContentList}) {
				if (!(contains(${tempFileDir}, ${fileContent}))) {
					echo(${fileContent});

					fail("The string '${fileContent}' doesn't exists on this file");
				}
				else {
					echo("The string '${fileContent}' exists on this file");
				}
			}
		}

		if (isSet(fileContentNotPresent)) {
			if (contains(${tempFileDir}, ${fileContentNotPresent})) {
				echo(${fileContentNotPresent});

				fail("The string '${fileContentNotPresent}' exists on this file");
			}
			else {
				echo("The string '${fileContentNotPresent}' doesn't exists on this file");
			}
		}

		FileUtil.delete("${directoryPath}/${fileName}");
	}

