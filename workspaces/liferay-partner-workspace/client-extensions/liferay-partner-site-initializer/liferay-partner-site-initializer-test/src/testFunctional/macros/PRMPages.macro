definition {

	@summary = "Default summary"
	macro assertPageTitle(pageTitle = null) {
		AssertElementPresent(
			key_title = ${pageTitle},
			locator1 = "Header#H1_TITLE");
	}

	@summary = "Default summary"
	macro clickBannerButton() {
		Click(locator1 = "PRMPages#VIDEO_BUTTON");
	}

	@summary = "Default summary"
	macro clickBannerLink(linkText = null) {
		Click(
			key_linkText = ${linkText},
			locator1 = "PRMPages#BANNER_LINK");
	}

	@summary = "Default summary"
	macro dismissBanner() {
		Click(
			key_text = "Dismiss",
			locator1 = "Button#ANY");
	}

}