definition {

	@summary = "Default summary"
	macro expandActivityDetails(activityName = null) {
		Click(
			key_textButton = ${activityName},
			locator1 = "PRMMDFRequest#TEXT_BUTTON");
	}

	@summary = "Default summary"
	macro viewBudgetNotPresent(budgetName = null,budgetIndex = null) {
		AssertElementNotPresent(
			key_budgetName = ${budgetName},
			key_index = ${budgetIndex},
			locator1 = "PRMMDFRequestDetailPage#BUDGET_BY_INDEX");
	}

}