{
	"cpu": 1,
	"env": {
		"DXP_METADATA_PATH": "/etc/liferay/lxc/dxp-metadata",
		"EXT_INIT_METADATA_PATH": "/etc/liferay/lxc/ext-init-metadata"
	},
	"environments": {
		"infra": {
			"deploy": false
		}
	},
	"id": "__PROJECT_ID__",
	"kind": "Deployment",
	"livenessProbe": {
		"httpGet": {
			"path": "/ready",
			"port": 3001
		}
	},
	"loadBalancer": {
		"targetPort": 3001
	},
	"memory": 512,
	"readinessProbe": {
		"httpGet": {
			"path": "/ready",
			"port": 3001
		}
	},
	"scale": 1
}