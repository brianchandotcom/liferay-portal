{
	"concurrencyPolicy": "Forbid",
	"cpu": 4,
	"env": {
		"LIFERAY_ROUTES_CLIENT_EXTENSION": "/etc/liferay/lxc/ext-init-metadata",
		"LIFERAY_ROUTES_DXP": "/etc/liferay/lxc/dxp-metadata"
	},
	"environments": {
		"extdev": {
			"schedule": "30 20 * * *"
		},
		"infra": {
			"deploy": false
		}
	},
	"id": "__PROJECT_ID__",
	"kind": "CronJob",
	"memory": 3000,
	"scale": 1,
	"schedule": "30 20 * * *"
}