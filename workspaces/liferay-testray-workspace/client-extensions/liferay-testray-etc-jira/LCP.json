{
  "kind": "Deployment",
  "id": "LXCExtensionJiraCloud",
  "deploy": true,
  "memory": 512,
  "cpu": 1,
  "loadBalancer": {
    "cdn": false,
    "targetPort": 3333
  },
  "ports": [
    {
      "protocol": "TCP",
      "targetPort": 3333,
      "port": 3333,
      "external": true
    }
  ],
  "readinessProbe": {
    "httpGet": {
      "path": "/",
      "port": 3333
    },
    "initialDelaySeconds": 30,
    "periodSeconds": 10,
    "timeoutSeconds": 4,
    "failureThreshold": 3,
    "successThreshold": 1
  },
  "livenessProbe": {
    "httpGet": {
      "path": "/",
      "port": 3333
    },
    "initialDelaySeconds": 20,
    "periodSeconds": 10,
    "timeoutSeconds": 4,
    "failureThreshold": 3,
    "successThreshold": 1
  }
}
